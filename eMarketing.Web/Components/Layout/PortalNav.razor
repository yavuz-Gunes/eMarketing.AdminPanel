<nav class="@(Compact ? "flex gap-2 overflow-x-auto" : "space-y-2 px-4")">
    @foreach (NavItem item in Items)
    {
        <NavLink href="@item.Href" Match="@item.Match" class="@LinkClass">
            <span class="@IconClass">@item.Icon</span>
            <span>@item.Label</span>
        </NavLink>
    }
</nav>

@code {
    [Parameter] public bool Compact { get; set; }

    private string LinkClass => Compact
        ? "inline-flex min-w-max items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 [&.active]:bg-blue-600 [&.active]:text-white"
        : "flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold text-slate-300 transition hover:bg-white/10 hover:text-white [&.active]:bg-blue-600 [&.active]:text-white [&.active]:shadow-lg [&.active]:shadow-blue-950/30";

    private string IconClass => Compact
        ? "flex h-7 w-7 items-center justify-center text-base"
        : "flex h-8 w-8 items-center justify-center text-lg";

    private static readonly NavItem[] Items =
    [
        new("Dashboard", "/", "⌂", NavLinkMatch.All),
        new("Mağaza Seçimi", "/stores", "▤", NavLinkMatch.Prefix),
        new("Ürünler", "/products", "□", NavLinkMatch.Prefix),
        new("Sepet", "/cart", "◫", NavLinkMatch.Prefix),
        new("Siparişler", "/orders", "≡", NavLinkMatch.Prefix),
        new("Ekibim", "/team", "◎", NavLinkMatch.Prefix)
    ];

    private sealed record NavItem(string Label, string Href, string Icon, NavLinkMatch Match);
}
