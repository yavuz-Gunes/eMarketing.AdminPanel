@inject TeamApiClient TeamApi
@inject AuthSession Auth
@inject ActionFeedbackService Feedback

@if (Member is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/45 p-4 backdrop-blur-sm" @onclick="Close">
        <section class="flex max-h-[82vh] w-full flex-col overflow-hidden rounded-xl border border-white/70 bg-white shadow-2xl shadow-slate-950/25"
                 style="max-width:1040px; max-height:82vh"
                 @onclick:stopPropagation="true">
            <header class="border-b border-slate-100 bg-white px-4 py-3">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex min-w-0 items-center gap-3">
                        <Avatar Member="Member" Size="md" />
                        <div class="min-w-0">
                            <p class="text-xs font-black uppercase tracking-wide text-blue-700">Personel Detayı</p>
                            <h2 class="mt-0.5 truncate text-xl font-black text-slate-950">@Member.AdSoyad</h2>
                            <p class="mt-0.5 truncate text-xs font-bold text-slate-500">@Member.KullaniciAdi · @EmptyText(Context?.MagazaAdi)</p>
                        </div>
                    </div>
                    <button class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-slate-200 text-slate-500 transition hover:bg-slate-50 hover:text-slate-950"
                            @onclick="Close"
                            title="Kapat">
                        <AppIcon Name="x" CssClass="h-5 w-5" />
                    </button>
                </div>
            </header>

            <div class="min-h-0 flex-1 overflow-y-auto bg-slate-50/70 p-4">
                <div class="mb-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-bold text-amber-800">
                    Yetki değişiklikleri yalnızca admin veya supervisor tarafından yapılır.
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="hidden">@Message</div>
                }

                <div class="grid gap-3 lg:grid-cols-[210px_minmax(0,1fr)_230px]">
                    <aside class="space-y-3">
                        <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                            <div class="flex flex-col items-center text-center">
                                <Avatar Member="Member" Size="lg" />
                                <p class="mt-3 max-w-full truncate text-sm font-black text-slate-950">@Member.AdSoyad</p>
                                <p class="mt-0.5 max-w-full truncate text-xs font-bold text-slate-500">@Member.KullaniciAdi</p>
                                <div class="mt-2 flex flex-wrap justify-center gap-1.5">
                                    <StatusBadge Text="@(IsTargetAdmin ? "Admin" : DutyName(Member.MagazaGorev))" Tone="@(IsTargetAdmin ? "info" : DutyTone(Member.MagazaGorev))" />
                                    <StatusBadge Text="@(Member.AktifMi ? "Aktif" : "Pasif")" Tone="@(Member.AktifMi ? "success" : "danger")" />
                                </div>
                            </div>
                            <div class="mt-3 grid gap-1.5 text-xs font-bold text-slate-500">
                                <span class="truncate">@EmptyText(Member.Email)</span>
                                <span>@EmptyText(Member.Telefon)</span>
                            </div>
                        </section>

                        <section class="rounded-lg border border-slate-200 bg-white p-2 shadow-sm">
                            <button class="@TabClass("identity")" @onclick='() => ActiveTab = "identity"'>
                                <AppIcon Name="user" CssClass="h-4 w-4" />
                                Kimlik
                            </button>
                            <button class="@TabClass("security")" @onclick='() => ActiveTab = "security"'>
                                <AppIcon Name="shield" CssClass="h-4 w-4" />
                                Güvenlik
                            </button>
                            <button class="@TabClass("permissions")" @onclick='() => ActiveTab = "permissions"'>
                                <AppIcon Name="briefcase" CssClass="h-4 w-4" />
                                Mağaza Yetkileri
                            </button>
                        </section>
                    </aside>

                    <main class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                        @if (ActiveTab == "identity")
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Kimlik ve iletişim</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">@ProfileHelpText</p>
                                </div>
                                <div class="grid gap-3 md:grid-cols-2">
                                    <TextField Label="Ad Soyad" Kind="person" MaxLength="150" Required="true" IsInvalid="@ProfileNameInvalid" ErrorText="@ProfileNameError" @bind-Value="ProfileForm.AdSoyad" />
                                    <TextField Label="Telefon" Kind="phone" MaxLength="60" MinDigits="10" MaxDigits="12" IsInvalid="@ProfilePhoneInvalid" ErrorText="@ProfilePhoneError" @bind-Value="ProfileForm.Telefon" />
                                    <TextField Label="E-posta" Kind="email" MaxLength="400" IsInvalid="@ProfileEmailInvalid" ErrorText="@ProfileEmailError" @bind-Value="ProfileForm.Email" />
                                    <label class="block">
                                        <span class="text-xs font-black uppercase text-slate-500">Kullanıcı adı</span>
                                        <input class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-slate-100 px-4 text-sm font-bold text-slate-500"
                                               value="@Member.KullaniciAdi"
                                               disabled />
                                    </label>
                                </div>
                            </div>
                        }
                        else if (ActiveTab == "security")
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Güvenlik</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">Şifre bilgileri rol yetkisine göre güvenli şekilde yönetilir.</p>
                                </div>
                                <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/70">
                                    <div class="flex flex-wrap items-start justify-between gap-3">
                                        <div class="flex min-w-0 items-start gap-3">
                                            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-700 ring-1 ring-blue-100">
                                                <AppIcon Name="shield" CssClass="h-5 w-5" />
                                            </div>
                                            <div class="min-w-0">
                                                <h4 class="text-sm font-black text-slate-950">Şifre Yönetimi</h4>
                                                <p class="mt-1 text-xs font-semibold leading-5 text-slate-500">Admin geçici şifre atar; personel kendi şifresini değiştirir.</p>
                                            </div>
                                        </div>
                                        <span class="inline-flex h-8 items-center gap-1.5 rounded-full border border-emerald-100 bg-emerald-50 px-3 text-xs font-black text-emerald-700">
                                            <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                                            Güvenli
                                        </span>
                                    </div>

                                    <div class="mt-4 grid gap-4 xl:grid-cols-[minmax(0,1fr)_260px]">
                                        <div class="space-y-4">
                                            <label class="block max-w-md">
                                                <span class="flex items-center gap-2 text-xs font-black uppercase text-slate-500">
                                                    Mevcut şifre
                                                    <span class="rounded-full border border-blue-100 bg-blue-50 px-2 py-0.5 text-[10px] font-black normal-case text-blue-700">Gizli tutulur</span>
                                                </span>
                                                <span class="relative mt-1 block">
                                                    <input type="password"
                                                           class="h-12 w-full cursor-not-allowed rounded-xl border border-slate-200 bg-slate-50 px-4 pr-12 text-sm font-black tracking-[0.18em] text-slate-500 outline-none"
                                                           value="••••••••"
                                                           readonly
                                                           disabled />
                                                    <span class="absolute right-2 top-1/2 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-lg text-slate-400"
                                                          style="right:0.5rem; top:50%; transform:translateY(-50%);">
                                                        <AppIcon Name="eye-off" CssClass="h-4 w-4" />
                                                    </span>
                                                </span>
                                                <span class="mt-1 block text-xs font-semibold text-slate-500">Güvenlik için mevcut şifre gösterilmez.</span>
                                            </label>

                                            <label class="block max-w-md" @key="PasswordInputVersion">
                                    <span class="text-xs font-black uppercase text-slate-500">Yeni Şifre</span>
                                    <span class="relative mt-1 block">
                                        <input type="@(ShowPassword ? "text" : "password")"
                                               class="@PasswordInputClass"
                                               value="@PasswordForm.YeniSifre"
                                               @oninput="OnPasswordInput"
                                               name="@PasswordInputName"
                                               autocomplete="new-password"
                                               autocapitalize="off"
                                               spellcheck="false"
                                               disabled="@(!CanManagePassword || Busy)"
                                               placeholder="En az 4 karakter" />
                                        <button type="button"
                                                class="absolute right-2 top-1/2 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-lg text-slate-500 transition hover:bg-slate-100 hover:text-slate-900 disabled:cursor-not-allowed disabled:opacity-40"
                                                style="right:0.5rem; top:50%; transform:translateY(-50%);"
                                                title="@PasswordToggleTitle"
                                                disabled="@(!CanManagePassword || Busy)"
                                                @onclick="TogglePasswordVisibility">
                                            <AppIcon Name="@(ShowPassword ? "eye-off" : "eye")" CssClass="h-4 w-4" />
                                        </button>
                                    </span>
                                    <span class="mt-1 block text-xs font-semibold text-slate-500">En az 4 karakter olmalı. Kayıt sonrası bu alan temizlenir.</span>
                                    @if (!string.IsNullOrWhiteSpace(PasswordError))
                                    {
                                        <span class="mt-1 block text-xs font-bold text-rose-600">@PasswordError</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(PasswordSuccessMessage))
                                    {
                                        <span class="mt-1 block text-xs font-bold text-emerald-600">@PasswordSuccessMessage</span>
                                    }
                                </label>
                                <div class="flex flex-wrap items-center gap-2">
                                    <CommandButton Text="@PasswordSaveText"
                                                   BusyText="Kaydediliyor..."
                                                   Icon="shield"
                                                   Tone="primary"
                                                   Busy="Busy"
                                                   Disabled="@(!CanManagePassword)"
                                                   OnClick="@SavePasswordAsync" />
                                                <span class="text-xs font-semibold text-slate-500">@PasswordActionHelpText</span>
                                            </div>
                                        </div>

                                        <aside class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                            <div class="flex items-center justify-between gap-3">
                                                <p class="text-xs font-black uppercase text-slate-500">Güvenlik Durumu</p>
                                                <span class="rounded-full border border-emerald-100 bg-white px-2 py-1 text-[10px] font-black text-emerald-700">Güvenli</span>
                                            </div>
                                            <div class="mt-3 space-y-3 text-sm">
                                                <InfoRow Label="Son işlem" Value="Bugün" />
                                                <InfoRow Label="Alan durumu" Value="Kayıt sonrası temizlenir" />
                                                <InfoRow Label="Yetki" Value="@PermissionOwnerText" />
                                            </div>
                                        </aside>
                                    </div>
                                </section>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Mağaza yetkileri</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">@PermissionHelpText</p>
                                </div>

                                <div class="grid gap-3 md:grid-cols-2">
                                    <label class="block">
                                        <span class="text-xs font-black uppercase text-slate-500">Görev</span>
                                        <select class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-bold text-slate-700 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100 disabled:bg-slate-100 disabled:text-slate-400"
                                                @bind="SelectedDuty"
                                                disabled="@(!CanManagePermissions || Busy)">
                                            <option value="Personel">Personel</option>
                                            <option value="MagazaMuduru">Mağaza Müdürü</option>
                                            <option value="Supervisor">Supervisor</option>
                                        </select>
                                        @if (IsTargetAdmin)
                                        {
                                            <span class="mt-1 block text-xs font-bold text-blue-700">Admin sistem rolüdür; mağaza görevi bu ekrandan değiştirilemez.</span>
                                        }
                                    </label>

                                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                                        <p class="text-xs font-black uppercase text-slate-500">Sipariş yetkilisi</p>
                                        <button class="@AuthorityButtonClass"
                                                disabled="@(!CanManageAuthority || Busy)"
                                                @onclick="() => SetAuthorityAsync(!Member.SiparisYetkilisiMi)">
                                            <span class="@ToggleKnobClass(Member.SiparisYetkilisiMi)"></span>
                                        </button>
                                        <span class="ml-2 text-sm font-black text-slate-700">@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")</span>
                                    </div>
                                </div>

                                <div class="flex flex-wrap gap-2">
                                    <CommandButton Text="Görevi Kaydet" BusyText="Kaydediliyor..." Icon="briefcase" Tone="primary" Busy="Busy" Disabled="@(!CanManagePermissions)" OnClick="@UpdateDutyAsync" />
                                    <CommandButton Text="Bayiden Çıkar" BusyText="İşleniyor..." Icon="user-x" Tone="danger" Busy="Busy" Disabled="@(!CanManagePermissions)" OnClick="@RemoveAsync" />
                                </div>
                            </div>
                        }
                    </main>

                    <aside class="space-y-3">
                        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                            <p class="text-xs font-black uppercase text-slate-500">Yetki Özeti</p>
                            <div class="mt-3 space-y-3 text-sm">
                                <InfoRow Label="Görev" Value="@(IsTargetAdmin ? "Sistem yöneticisi" : DutyName(Member.MagazaGorev))" />
                                <InfoRow Label="Sipariş yetkisi" Value="@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")" />
                                <InfoRow Label="Değiştirebilir" Value="@PermissionOwnerText" />
                                <InfoRow Label="Kapsam" Value="@EmptyText(Context?.MagazaAdi)" />
                            </div>
                        </section>

                        <section class="rounded-lg border border-blue-100 bg-blue-50 p-3">
                            <p class="text-sm font-black text-blue-950">Kural</p>
                            <p class="mt-1 text-xs font-semibold leading-5 text-blue-800">
                                Kişi kendi yetkisini değiştiremez. Profil bilgisi ve şifre değişimi rol kurallarına göre ayrı yönetilir.
                            </p>
                        </section>
                    </aside>
                </div>
            </div>

            <footer class="flex flex-wrap justify-end gap-2 border-t border-slate-100 bg-white p-3">
                <CommandButton Text="Vazgeç" Icon="x" Tone="secondary" Disabled="Busy" OnClick="@Close" />
                @if (ActiveTab == "identity")
                {
                    <CommandButton Text="Bilgileri Kaydet" BusyText="Kaydediliyor..." Icon="check" Tone="primary" Busy="Busy" Disabled="@(!CanManageProfile)" OnClick="@SaveProfileAsync" />
                }
                else if (ActiveTab != "security")
                {
                    <CommandButton Text="Yetkileri Kaydet" BusyText="Kaydediliyor..." Icon="briefcase" Tone="primary" Busy="Busy" Disabled="@(!CanManagePermissions)" OnClick="@UpdateDutyAsync" />
                }
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public int StoreId { get; set; }
    [Parameter] public StoreTeamContextDto? Context { get; set; }
    [Parameter] public StoreTeamMemberDto? Member { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private StorePersonnelProfileUpdateRequest ProfileForm { get; set; } = new();
    private StorePersonnelPasswordUpdateRequest PasswordForm { get; set; } = new();
    private string SelectedDuty { get; set; } = "Personel";
    private string ActiveTab { get; set; } = "identity";
    private string Message { get; set; } = string.Empty;
    private bool IsError { get; set; }
    private bool Busy { get; set; }
    private bool ShowPassword { get; set; }
    private int? LoadedMemberId { get; set; }
    private int PasswordInputVersion { get; set; }
    private bool ProfileValidationVisible { get; set; }
    private bool PasswordValidationVisible { get; set; }
    private string PasswordSuccessMessage { get; set; } = string.Empty;

    private bool IsSelf => Member is not null && Auth.User?.KullaniciId == Member.KullaniciId;
    private bool IsTargetAdmin => Member is not null
        && (string.Equals(Member.Rol, "Admin", StringComparison.OrdinalIgnoreCase)
            || string.Equals(Member.KullaniciAdi, "admin", StringComparison.OrdinalIgnoreCase));
    private bool CanManageProfile => Member is not null && (IsSelf || Auth.IsAdmin);
    private bool CanManagePassword => Member is not null && (IsSelf || Auth.IsAdmin);
    private bool CanManagePermissions => Member is not null && !IsSelf && !IsTargetAdmin && Context?.GorevYonetebilir == true;
    private bool CanManageAuthority => Member is not null && !IsSelf && !IsTargetAdmin && Context?.SiparisYetkisiYonetebilir == true;
    private string PasswordToggleTitle => ShowPassword ? "Şifreyi gizle" : "Şifreyi göster";
    private string PasswordSaveText => "Yeni Şifreyi Kaydet";
    private string PasswordInputName => $"team-password-{Member?.KullaniciId ?? 0}-{PasswordInputVersion}";
    private string PasswordActionHelpText => IsSelf ? "Yeni şifrenizi kaydeder." : "Seçili personel için yeni geçici şifre belirler.";
    private string ProfileHelpText => CanManageProfile ? "Ad soyad, telefon ve e-posta bilgileri güncellenebilir." : "Bu bilgileri yalnızca personelin kendisi veya admin güncelleyebilir.";
    private string PasswordHelpText => CanManagePassword ? "Personel kendi şifresini değiştirebilir; admin şifre sıfırlayabilir." : "Şifre yönetimi yalnızca personelin kendisi veya admin tarafından yapılır.";
    private string PermissionHelpText => CanManagePermissions || CanManageAuthority ? "Görev ve sipariş yetkisi aktif mağaza kapsamında uygulanır." : "Kendi yetkinizi veya bu personelin mağaza yetkisini değiştiremezsiniz.";
    private string PermissionOwnerText => IsTargetAdmin ? "Sistem" : "Admin / Supervisor";
    private string MessageClass => IsError
        ? "mb-3 rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm font-bold text-rose-700"
        : "mb-3 rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm font-bold text-emerald-700";
    private string ProfileNameError => ProfileValidationVisible ? FormValidators.RequiredError(ProfileForm.AdSoyad, "Ad Soyad") ?? FormValidators.PersonError(ProfileForm.AdSoyad, "Ad Soyad") ?? string.Empty : string.Empty;
    private string ProfilePhoneError => ProfileValidationVisible ? FormValidators.PhoneError(ProfileForm.Telefon) ?? string.Empty : string.Empty;
    private string ProfileEmailError => ProfileValidationVisible ? FormValidators.EmailError(ProfileForm.Email) ?? string.Empty : string.Empty;
    private bool ProfileNameInvalid => !string.IsNullOrWhiteSpace(ProfileNameError);
    private bool ProfilePhoneInvalid => !string.IsNullOrWhiteSpace(ProfilePhoneError);
    private bool ProfileEmailInvalid => !string.IsNullOrWhiteSpace(ProfileEmailError);
    private string PasswordError => PasswordValidationVisible ? ValidatePassword() ?? string.Empty : string.Empty;
    private string PasswordInputClass => !string.IsNullOrWhiteSpace(PasswordError)
        ? "h-12 w-full rounded-xl border border-rose-300 bg-rose-50/40 px-4 pr-12 text-sm font-bold text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-100 disabled:bg-slate-100 disabled:text-slate-400"
        : "h-12 w-full rounded-xl border border-slate-200 bg-white px-4 pr-12 text-sm font-bold text-slate-700 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100 disabled:bg-slate-100 disabled:text-slate-400";
    private string AuthorityButtonClass => Member?.SiparisYetkilisiMi == true
        ? "relative inline-flex h-6 w-11 rounded-full bg-blue-600 align-middle transition disabled:cursor-not-allowed disabled:opacity-60"
        : "relative inline-flex h-6 w-11 rounded-full bg-slate-300 align-middle transition disabled:cursor-not-allowed disabled:opacity-60";

    protected override void OnParametersSet()
    {
        if (Member is null)
        {
            LoadedMemberId = null;
            return;
        }

        if (LoadedMemberId == Member.KullaniciId)
            return;

        LoadedMemberId = Member.KullaniciId;
        ActiveTab = "identity";
        Message = string.Empty;
        IsError = false;
        ProfileValidationVisible = false;
        PasswordValidationVisible = false;
        PasswordSuccessMessage = string.Empty;
        ProfileForm = new StorePersonnelProfileUpdateRequest
        {
            AdSoyad = Member.AdSoyad,
            Telefon = Member.Telefon,
            Email = Member.Email
        };
        PasswordForm = new StorePersonnelPasswordUpdateRequest();
        PasswordInputVersion++;
        ShowPassword = false;
        SelectedDuty = Member.MagazaGorev;
    }

    private async Task SaveProfileAsync()
    {
        if (Member is null || !CanManageProfile)
            return;

        ProfileValidationVisible = true;
        if (!IsProfileValid())
        {
            ShowValidationError();
            return;
        }

        await RunAsync(() => TeamApi.UpdateProfileAsync(Member.KullaniciId, ProfileForm), "Profil bilgileri güncellendi.");
    }

    private async Task SavePasswordAsync()
    {
        if (Member is null || !CanManagePassword)
            return;

        PasswordValidationVisible = true;
        PasswordSuccessMessage = string.Empty;
        if (!string.IsNullOrWhiteSpace(PasswordError))
        {
            ShowValidationError();
            return;
        }

        try
        {
            Busy = true;
            int memberId = Member.KullaniciId;
            StorePersonnelPasswordUpdateRequest request = new()
            {
                YeniSifre = PasswordForm.YeniSifre.Trim()
            };
            await TeamApi.UpdatePasswordAsync(memberId, request);

            ClearPasswordInput();
            ShowPassword = false;
            PasswordValidationVisible = false;
            IsError = false;
            Message = "Şifre güncellendi.";
            PasswordSuccessMessage = "Yeni şifre kaydedildi. Güvenlik için alan temizlendi.";
            Feedback.Success("Şifre güncellendi", "Yeni şifre kaydedildi.");
            await InvokeAsync(StateHasChanged);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = ex.Message;
            Feedback.Error("İşlem tamamlanamadı", ex.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task SetAuthorityAsync(bool active)
    {
        if (Member is null || !CanManageAuthority)
            return;

        await RunAsync(() => TeamApi.SetOrderAuthorityAsync(StoreId, Member.KullaniciId, active, string.Empty), active ? "Sipariş yetkisi verildi." : "Sipariş yetkisi kaldırıldı.");
    }

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private void OnPasswordInput(ChangeEventArgs args)
    {
        PasswordForm.YeniSifre = args.Value?.ToString() ?? string.Empty;
        PasswordSuccessMessage = string.Empty;
    }

    private void ClearPasswordInput()
    {
        PasswordForm = new StorePersonnelPasswordUpdateRequest { YeniSifre = string.Empty };
        PasswordInputVersion++;
    }

    private async Task UpdateDutyAsync()
    {
        if (Member is null || !CanManagePermissions)
            return;

        await RunAsync(() => TeamApi.UpdateDutyAsync(StoreId, Member.KullaniciMagazaId, SelectedDuty), "Bayi görevi güncellendi.");
    }

    private async Task RemoveAsync()
    {
        if (Member is null || !CanManagePermissions)
            return;

        await RunAsync(() => TeamApi.RemovePersonnelAsync(StoreId, Member.KullaniciMagazaId), "Personel bayiden çıkarıldı.");
        await Close();
    }

    private async Task RunAsync(Func<Task> action, string success)
    {
        try
        {
            Busy = true;
            await action();
            IsError = false;
            Message = success;
            Feedback.Success("İşlem başarılı", success);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = ex.Message;
            Feedback.Error("İşlem tamamlanamadı", ex.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private bool IsProfileValid()
    {
        return string.IsNullOrWhiteSpace(ProfileNameError)
            && string.IsNullOrWhiteSpace(ProfilePhoneError)
            && string.IsNullOrWhiteSpace(ProfileEmailError);
    }

    private string? ValidatePassword()
    {
        if (string.IsNullOrWhiteSpace(PasswordForm.YeniSifre))
            return "Şifre zorunludur.";

        if (PasswordForm.YeniSifre.Trim().Length < 4)
            return "Şifre en az 4 karakter olmalı.";

        return null;
    }

    private void ShowValidationError()
    {
        IsError = true;
        Message = "Eksik veya hatalı alanlar var.";
        Feedback.Warning("Eksik veya hatalı alanlar var", "Lütfen kırmızı işaretli alanları kontrol edin.");
    }

    private async Task Close()
    {
        Message = string.Empty;
        await OnClose.InvokeAsync();
    }

    private string TabClass(string tab)
    {
        string state = ActiveTab == tab
            ? "bg-blue-50 text-blue-700 ring-1 ring-blue-100"
            : "text-slate-600 hover:bg-slate-50";
        return $"mb-1 flex h-10 w-full items-center gap-2 rounded-lg px-3 text-left text-xs font-black transition {state}";
    }

    private static string ToggleKnobClass(bool active) =>
        active
            ? "absolute right-1 top-1 h-4 w-4 rounded-full bg-white shadow"
            : "absolute left-1 top-1 h-4 w-4 rounded-full bg-white shadow";

    private static string EmptyText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DutyName(string duty) => duty switch
    {
        "Supervisor" => "Supervisor",
        "MagazaMuduru" => "Mağaza Müdürü",
        _ => "Personel"
    };

    private static string DutyTone(string duty) => duty switch
    {
        "Supervisor" => "supervisor",
        "MagazaMuduru" => "manager",
        _ => "slate"
    };
}
