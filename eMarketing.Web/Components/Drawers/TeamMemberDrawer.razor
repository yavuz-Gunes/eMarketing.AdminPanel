@inject TeamApiClient TeamApi

@if (Member is not null)
{
    <aside class="sticky top-24 flex max-h-[calc(100vh-7rem)] w-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10">
        <header class="border-b border-slate-200 px-5 py-4">
            <div class="flex items-start justify-between gap-4">
                <div class="flex min-w-0 items-center gap-3">
                    <Avatar Member="Member" Size="lg" />
                    <div class="min-w-0">
                        <p class="text-xs font-black uppercase tracking-wide text-blue-700">Personel Detayı</p>
                        <h2 class="mt-1 truncate text-xl font-black text-slate-950">@Member.AdSoyad</h2>
                        <p class="mt-1 truncate text-sm font-bold text-slate-500">@Context?.MagazaAdi</p>
                    </div>
                </div>
                <button class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-slate-200 text-slate-500 transition hover:bg-slate-50 hover:text-slate-950"
                        @onclick="Close"
                        title="Kapat">
                    <AppIcon Name="x" CssClass="h-5 w-5" />
                </button>
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
                @if (IsAdmin)
                {
                    <StatusBadge Text="Admin" Tone="info" />
                    <StatusBadge Text="Sistem yöneticisi" Tone="purple" />
                }
                else
                {
                    <StatusBadge Text="@DutyName(Member.MagazaGorev)" Tone="@DutyTone(Member.MagazaGorev)" />
                    <StatusBadge Text="@(Member.SiparisYetkilisiMi ? "Sipariş Yetkisi" : "Yetkisiz")" Tone="@(Member.SiparisYetkilisiMi ? "info" : "slate")" />
                }
                <StatusBadge Text="@(Member.AktifMi ? "Aktif" : "Pasif")" Tone="@(Member.AktifMi ? "success" : "danger")" />
            </div>
        </header>

        <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-5 py-4">
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="@MessageClass">@Message</div>
            }

            <section class="grid gap-3 rounded-xl border border-slate-200 bg-slate-50/70 p-4 text-sm">
                <InfoRow Label="Kullanıcı adı" Value="@Member.KullaniciAdi" />
                <InfoRow Label="E-posta" Value="@EmptyText(Member.Email)" />
                <InfoRow Label="Telefon" Value="@EmptyText(Member.Telefon)" />
                <InfoRow Label="Bayi görevi" Value="@(IsAdmin ? "Sistem yöneticisi" : DutyName(Member.MagazaGorev))" />
                <InfoRow Label="Durum" Value="@(Member.AktifMi ? "Aktif" : "Pasif")" />
            </section>

            @if (IsAdmin)
            {
                <section class="rounded-xl border border-indigo-200 bg-indigo-50 p-4">
                    <div class="flex gap-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white">
                            <AppIcon Name="shield" CssClass="h-5 w-5" />
                        </div>
                        <div>
                            <h3 class="font-black text-indigo-950">Sistem yöneticisi</h3>
                            <p class="mt-1 text-sm leading-5 text-indigo-800">Admin rolü bayi bazlı sipariş yetkisi gibi yönetilmez.</p>
                        </div>
                    </div>
                </section>
            }
            else if (Context?.SiparisYetkisiYonetebilir == true)
            {
                <section class="space-y-3 rounded-xl border border-blue-100 bg-blue-50/60 p-4">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <h3 class="text-sm font-black uppercase tracking-wide text-slate-700">Sipariş yetkisi</h3>
                            <p class="mt-1 text-sm text-slate-500">Mevcut: <span class="font-black text-slate-900">@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")</span></p>
                        </div>
                        <StatusBadge Text="@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")" Tone="@(Member.SiparisYetkilisiMi ? "info" : "slate")" />
                    </div>
                    <button class="@AuthorityButtonClass" @onclick="() => SetAuthority(!Member.SiparisYetkilisiMi)">
                        <AppIcon Name="shield" CssClass="h-5 w-5" />
                        @(Member.SiparisYetkilisiMi ? "Yetkiyi Kaldır" : "Yetki Ver")
                    </button>
                </section>
            }

            @if (!IsAdmin && Context?.GorevYonetebilir == true)
            {
                <section class="space-y-3 rounded-xl border border-slate-200 bg-white p-4">
                    <div>
                        <h3 class="text-sm font-black uppercase tracking-wide text-slate-700">Görev yönetimi</h3>
                        <p class="mt-1 text-sm text-slate-500">Bu aksiyon aktif bayi kapsamında uygulanır.</p>
                    </div>
                    <label class="block space-y-2 text-sm font-bold text-slate-700">
                        <span>Görevi değiştir</span>
                        <select class="w-full rounded-xl border border-slate-200 px-3 py-3 text-sm outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100" @bind="SelectedDuty">
                            <option value="Personel">Personel</option>
                            <option value="MagazaMuduru">Mağaza Müdürü</option>
                            <option value="Supervisor">Supervisor</option>
                        </select>
                    </label>
                    <button class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-xl bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800"
                            @onclick="UpdateDuty">
                        <AppIcon Name="briefcase" CssClass="h-5 w-5" />
                        Görevi Kaydet
                    </button>
                </section>

                <section class="space-y-3 rounded-xl border border-rose-200 bg-rose-50 p-4">
                    <div>
                        <h3 class="text-sm font-black uppercase tracking-wide text-rose-700">Tehlikeli aksiyon</h3>
                        <p class="mt-1 text-sm text-rose-700">Personelin bu bayi bağlantısını kaldırır.</p>
                    </div>
                    <button class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-xl border border-rose-200 bg-white px-4 text-sm font-black text-rose-700 transition hover:bg-rose-100"
                            @onclick="Remove">
                        <AppIcon Name="user-x" CssClass="h-5 w-5" />
                        Bayiden Çıkar
                    </button>
                </section>
            }
        </div>
    </aside>
}

@code {
    [Parameter] public int StoreId { get; set; }
    [Parameter] public StoreTeamContextDto? Context { get; set; }
    [Parameter] public StoreTeamMemberDto? Member { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string SelectedDuty { get; set; } = "Personel";
    private string Message { get; set; } = string.Empty;
    private bool IsError { get; set; }

    private bool IsAdmin => Member is not null
        && (string.Equals(Member.Rol, "Admin", StringComparison.OrdinalIgnoreCase)
            || string.Equals(Member.KullaniciAdi, "admin", StringComparison.OrdinalIgnoreCase));

    private string MessageClass => IsError
        ? "rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm font-bold text-rose-700"
        : "rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm font-bold text-emerald-700";

    private string AuthorityButtonClass => Member?.SiparisYetkilisiMi == true
        ? "inline-flex h-11 w-full items-center justify-center gap-2 rounded-xl border border-rose-200 bg-white px-4 text-sm font-black text-rose-700 transition hover:bg-rose-50"
        : "inline-flex h-11 w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-4 text-sm font-black text-white shadow-sm shadow-blue-200 transition hover:bg-blue-700";

    protected override void OnParametersSet()
    {
        if (Member is not null)
            SelectedDuty = Member.MagazaGorev;
    }

    private async Task SetAuthority(bool active)
    {
        if (Member is null || IsAdmin)
            return;

        await RunAsync(() => TeamApi.SetOrderAuthorityAsync(StoreId, Member.KullaniciId, active, string.Empty), active ? "Sipariş yetkisi verildi." : "Sipariş yetkisi kaldırıldı.");
    }

    private async Task UpdateDuty()
    {
        if (Member is null || IsAdmin)
            return;

        await RunAsync(() => TeamApi.UpdateDutyAsync(StoreId, Member.KullaniciMagazaId, SelectedDuty), "Bayi görevi güncellendi.");
    }

    private async Task Remove()
    {
        if (Member is null || IsAdmin)
            return;

        await RunAsync(() => TeamApi.RemovePersonnelAsync(StoreId, Member.KullaniciMagazaId), "Personel bayiden çıkarıldı.");
        await Close();
    }

    private async Task RunAsync(Func<Task> action, string success)
    {
        try
        {
            await action();
            IsError = false;
            Message = success;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = ex.Message;
        }
    }

    private async Task Close()
    {
        Message = string.Empty;
        await OnClose.InvokeAsync();
    }

    private static string EmptyText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DutyName(string duty) => duty switch
    {
        "Supervisor" => "Supervisor",
        "MagazaMuduru" => "Mağaza Müdürü",
        _ => "Personel"
    };

    private static string DutyTone(string duty) => duty switch
    {
        "Supervisor" => "supervisor",
        "MagazaMuduru" => "manager",
        _ => "slate"
    };
}
