@inject TeamApiClient TeamApi
@inject AuthSession Auth

@if (Member is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/45 p-4 backdrop-blur-sm" @onclick="Close">
        <section class="flex max-h-[82vh] w-full flex-col overflow-hidden rounded-xl border border-white/70 bg-white shadow-2xl shadow-slate-950/25"
                 style="max-width:1040px; max-height:82vh"
                 @onclick:stopPropagation="true">
            <header class="border-b border-slate-100 bg-white px-4 py-3">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex min-w-0 items-center gap-3">
                        <Avatar Member="Member" Size="md" />
                        <div class="min-w-0">
                            <p class="text-xs font-black uppercase tracking-wide text-blue-700">Personel Detayı</p>
                            <h2 class="mt-0.5 truncate text-xl font-black text-slate-950">@Member.AdSoyad</h2>
                            <p class="mt-0.5 truncate text-xs font-bold text-slate-500">@Member.KullaniciAdi · @EmptyText(Context?.MagazaAdi)</p>
                        </div>
                    </div>
                    <button class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-slate-200 text-slate-500 transition hover:bg-slate-50 hover:text-slate-950"
                            @onclick="Close"
                            title="Kapat">
                        <AppIcon Name="x" CssClass="h-5 w-5" />
                    </button>
                </div>
            </header>

            <div class="min-h-0 flex-1 overflow-y-auto bg-slate-50/70 p-4">
                <div class="mb-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-bold text-amber-800">
                    Yetki değişiklikleri yalnızca admin veya supervisor tarafından yapılır.
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="@MessageClass">@Message</div>
                }

                <div class="grid gap-3 lg:grid-cols-[210px_minmax(0,1fr)_230px]">
                    <aside class="space-y-3">
                        <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                            <div class="flex flex-col items-center text-center">
                                <Avatar Member="Member" Size="lg" />
                                <p class="mt-3 max-w-full truncate text-sm font-black text-slate-950">@Member.AdSoyad</p>
                                <p class="mt-0.5 max-w-full truncate text-xs font-bold text-slate-500">@Member.KullaniciAdi</p>
                                <div class="mt-2 flex flex-wrap justify-center gap-1.5">
                                    <StatusBadge Text="@(IsTargetAdmin ? "Admin" : DutyName(Member.MagazaGorev))" Tone="@(IsTargetAdmin ? "info" : DutyTone(Member.MagazaGorev))" />
                                    <StatusBadge Text="@(Member.AktifMi ? "Aktif" : "Pasif")" Tone="@(Member.AktifMi ? "success" : "danger")" />
                                </div>
                            </div>
                            <div class="mt-3 grid gap-1.5 text-xs font-bold text-slate-500">
                                <span class="truncate">@EmptyText(Member.Email)</span>
                                <span>@EmptyText(Member.Telefon)</span>
                            </div>
                        </section>

                        <section class="rounded-lg border border-slate-200 bg-white p-2 shadow-sm">
                            <button class="@TabClass("identity")" @onclick='() => ActiveTab = "identity"'>
                                <AppIcon Name="user" CssClass="h-4 w-4" />
                                Kimlik
                            </button>
                            <button class="@TabClass("security")" @onclick='() => ActiveTab = "security"'>
                                <AppIcon Name="shield" CssClass="h-4 w-4" />
                                Güvenlik
                            </button>
                            <button class="@TabClass("permissions")" @onclick='() => ActiveTab = "permissions"'>
                                <AppIcon Name="briefcase" CssClass="h-4 w-4" />
                                Mağaza Yetkileri
                            </button>
                        </section>
                    </aside>

                    <main class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                        @if (ActiveTab == "identity")
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Kimlik ve iletişim</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">@ProfileHelpText</p>
                                </div>
                                <div class="grid gap-3 md:grid-cols-2">
                                    <TextField Label="Ad Soyad" Kind="person" MaxLength="150" @bind-Value="ProfileForm.AdSoyad" />
                                    <TextField Label="Telefon" Kind="phone" MaxLength="60" @bind-Value="ProfileForm.Telefon" />
                                    <TextField Label="E-posta" Kind="email" MaxLength="400" @bind-Value="ProfileForm.Email" />
                                    <label class="block">
                                        <span class="text-xs font-black uppercase text-slate-500">Kullanıcı adı</span>
                                        <input class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-slate-100 px-4 text-sm font-bold text-slate-500"
                                               value="@Member.KullaniciAdi"
                                               disabled />
                                    </label>
                                </div>
                                <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300"
                                        disabled="@(!CanManageProfile || Busy)"
                                        @onclick="SaveProfileAsync">
                                    <AppIcon Name="check" CssClass="h-4 w-4" />
                                    Bilgileri Kaydet
                                </button>
                            </div>
                        }
                        else if (ActiveTab == "security")
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Güvenlik</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">@PasswordHelpText</p>
                                </div>
                                <label class="block max-w-md">
                                    <span class="text-xs font-black uppercase text-slate-500">Yeni Şifre</span>
                                    <input type="password"
                                           class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-bold text-slate-700 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100 disabled:bg-slate-100 disabled:text-slate-400"
                                           @bind="PasswordForm.YeniSifre"
                                           disabled="@(!CanManagePassword || Busy)"
                                           placeholder="En az 4 karakter" />
                                </label>
                                <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300"
                                        disabled="@(!CanManagePassword || Busy)"
                                        @onclick="SavePasswordAsync">
                                    <AppIcon Name="shield" CssClass="h-4 w-4" />
                                    Şifreyi Kaydet
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                <div>
                                    <h3 class="text-base font-black text-slate-950">Mağaza yetkileri</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">@PermissionHelpText</p>
                                </div>

                                <div class="grid gap-3 md:grid-cols-2">
                                    <label class="block">
                                        <span class="text-xs font-black uppercase text-slate-500">Görev</span>
                                        <select class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-bold text-slate-700 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100 disabled:bg-slate-100 disabled:text-slate-400"
                                                @bind="SelectedDuty"
                                                disabled="@(!CanManagePermissions || Busy)">
                                            <option value="Personel">Personel</option>
                                            <option value="MagazaMuduru">Mağaza Müdürü</option>
                                            <option value="Supervisor">Supervisor</option>
                                        </select>
                                    </label>

                                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                                        <p class="text-xs font-black uppercase text-slate-500">Sipariş yetkilisi</p>
                                        <button class="@AuthorityButtonClass"
                                                disabled="@(!CanManageAuthority || Busy)"
                                                @onclick="() => SetAuthorityAsync(!Member.SiparisYetkilisiMi)">
                                            <span class="@ToggleKnobClass(Member.SiparisYetkilisiMi)"></span>
                                        </button>
                                        <span class="ml-2 text-sm font-black text-slate-700">@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")</span>
                                    </div>
                                </div>

                                <div class="flex flex-wrap gap-2">
                                    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300"
                                            disabled="@(!CanManagePermissions || Busy)"
                                            @onclick="UpdateDutyAsync">
                                        <AppIcon Name="briefcase" CssClass="h-4 w-4" />
                                        Görevi Kaydet
                                    </button>
                                    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-rose-200 bg-white px-4 text-sm font-black text-rose-700 transition hover:bg-rose-50 disabled:cursor-not-allowed disabled:opacity-50"
                                            disabled="@(!CanManagePermissions || Busy)"
                                            @onclick="RemoveAsync">
                                        <AppIcon Name="user-x" CssClass="h-4 w-4" />
                                        Bayiden Çıkar
                                    </button>
                                </div>
                            </div>
                        }
                    </main>

                    <aside class="space-y-3">
                        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                            <p class="text-xs font-black uppercase text-slate-500">Yetki Özeti</p>
                            <div class="mt-3 space-y-3 text-sm">
                                <InfoRow Label="Görev" Value="@(IsTargetAdmin ? "Sistem yöneticisi" : DutyName(Member.MagazaGorev))" />
                                <InfoRow Label="Sipariş yetkisi" Value="@(Member.SiparisYetkilisiMi ? "Yetkili" : "Yetkisiz")" />
                                <InfoRow Label="Değiştirebilir" Value="@PermissionOwnerText" />
                                <InfoRow Label="Kapsam" Value="@EmptyText(Context?.MagazaAdi)" />
                            </div>
                        </section>

                        <section class="rounded-lg border border-blue-100 bg-blue-50 p-3">
                            <p class="text-sm font-black text-blue-950">Kural</p>
                            <p class="mt-1 text-xs font-semibold leading-5 text-blue-800">
                                Kişi kendi yetkisini değiştiremez. Profil bilgisi ve şifre değişimi rol kurallarına göre ayrı yönetilir.
                            </p>
                        </section>
                    </aside>
                </div>
            </div>

            <footer class="flex justify-end gap-2 border-t border-slate-100 bg-white p-3">
                <button class="rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-600 transition hover:bg-slate-50" @onclick="Close">Vazgeç</button>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public int StoreId { get; set; }
    [Parameter] public StoreTeamContextDto? Context { get; set; }
    [Parameter] public StoreTeamMemberDto? Member { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private StorePersonnelProfileUpdateRequest ProfileForm { get; set; } = new();
    private StorePersonnelPasswordUpdateRequest PasswordForm { get; set; } = new();
    private string SelectedDuty { get; set; } = "Personel";
    private string ActiveTab { get; set; } = "identity";
    private string Message { get; set; } = string.Empty;
    private bool IsError { get; set; }
    private bool Busy { get; set; }
    private int? LoadedMemberId { get; set; }

    private bool IsSelf => Member is not null && Auth.User?.KullaniciId == Member.KullaniciId;
    private bool IsTargetAdmin => Member is not null
        && (string.Equals(Member.Rol, "Admin", StringComparison.OrdinalIgnoreCase)
            || string.Equals(Member.KullaniciAdi, "admin", StringComparison.OrdinalIgnoreCase));
    private bool CanManageProfile => Member is not null && (IsSelf || Auth.IsAdmin);
    private bool CanManagePassword => Member is not null && (IsSelf || Auth.IsAdmin);
    private bool CanManagePermissions => Member is not null && !IsSelf && !IsTargetAdmin && Context?.GorevYonetebilir == true;
    private bool CanManageAuthority => Member is not null && !IsSelf && !IsTargetAdmin && Context?.SiparisYetkisiYonetebilir == true;
    private string ProfileHelpText => CanManageProfile ? "Ad soyad, telefon ve e-posta bilgileri güncellenebilir." : "Bu bilgileri yalnızca personelin kendisi veya admin güncelleyebilir.";
    private string PasswordHelpText => CanManagePassword ? "Personel kendi şifresini değiştirebilir; admin şifre sıfırlayabilir." : "Şifre yönetimi yalnızca personelin kendisi veya admin tarafından yapılır.";
    private string PermissionHelpText => CanManagePermissions || CanManageAuthority ? "Görev ve sipariş yetkisi aktif mağaza kapsamında uygulanır." : "Kendi yetkinizi veya bu personelin mağaza yetkisini değiştiremezsiniz.";
    private string PermissionOwnerText => IsTargetAdmin ? "Sistem" : "Admin / Supervisor";
    private string MessageClass => IsError
        ? "mb-3 rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm font-bold text-rose-700"
        : "mb-3 rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm font-bold text-emerald-700";
    private string AuthorityButtonClass => Member?.SiparisYetkilisiMi == true
        ? "relative inline-flex h-6 w-11 rounded-full bg-blue-600 align-middle transition disabled:cursor-not-allowed disabled:opacity-60"
        : "relative inline-flex h-6 w-11 rounded-full bg-slate-300 align-middle transition disabled:cursor-not-allowed disabled:opacity-60";

    protected override void OnParametersSet()
    {
        if (Member is null)
        {
            LoadedMemberId = null;
            return;
        }

        if (LoadedMemberId == Member.KullaniciId)
            return;

        LoadedMemberId = Member.KullaniciId;
        ActiveTab = "identity";
        Message = string.Empty;
        IsError = false;
        ProfileForm = new StorePersonnelProfileUpdateRequest
        {
            AdSoyad = Member.AdSoyad,
            Telefon = Member.Telefon,
            Email = Member.Email
        };
        PasswordForm = new StorePersonnelPasswordUpdateRequest();
        SelectedDuty = Member.MagazaGorev;
    }

    private async Task SaveProfileAsync()
    {
        if (Member is null || !CanManageProfile)
            return;

        await RunAsync(() => TeamApi.UpdateProfileAsync(Member.KullaniciId, ProfileForm), "Profil bilgileri güncellendi.");
    }

    private async Task SavePasswordAsync()
    {
        if (Member is null || !CanManagePassword)
            return;

        await RunAsync(() => TeamApi.UpdatePasswordAsync(Member.KullaniciId, PasswordForm), "Şifre güncellendi.");
        PasswordForm = new StorePersonnelPasswordUpdateRequest();
    }

    private async Task SetAuthorityAsync(bool active)
    {
        if (Member is null || !CanManageAuthority)
            return;

        await RunAsync(() => TeamApi.SetOrderAuthorityAsync(StoreId, Member.KullaniciId, active, string.Empty), active ? "Sipariş yetkisi verildi." : "Sipariş yetkisi kaldırıldı.");
    }

    private async Task UpdateDutyAsync()
    {
        if (Member is null || !CanManagePermissions)
            return;

        await RunAsync(() => TeamApi.UpdateDutyAsync(StoreId, Member.KullaniciMagazaId, SelectedDuty), "Bayi görevi güncellendi.");
    }

    private async Task RemoveAsync()
    {
        if (Member is null || !CanManagePermissions)
            return;

        await RunAsync(() => TeamApi.RemovePersonnelAsync(StoreId, Member.KullaniciMagazaId), "Personel bayiden çıkarıldı.");
        await Close();
    }

    private async Task RunAsync(Func<Task> action, string success)
    {
        try
        {
            Busy = true;
            await action();
            IsError = false;
            Message = success;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task Close()
    {
        Message = string.Empty;
        await OnClose.InvokeAsync();
    }

    private string TabClass(string tab)
    {
        string state = ActiveTab == tab
            ? "bg-blue-50 text-blue-700 ring-1 ring-blue-100"
            : "text-slate-600 hover:bg-slate-50";
        return $"mb-1 flex h-10 w-full items-center gap-2 rounded-lg px-3 text-left text-xs font-black transition {state}";
    }

    private static string ToggleKnobClass(bool active) =>
        active
            ? "absolute right-1 top-1 h-4 w-4 rounded-full bg-white shadow"
            : "absolute left-1 top-1 h-4 w-4 rounded-full bg-white shadow";

    private static string EmptyText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DutyName(string duty) => duty switch
    {
        "Supervisor" => "Supervisor",
        "MagazaMuduru" => "Mağaza Müdürü",
        _ => "Personel"
    };

    private static string DutyTone(string duty) => duty switch
    {
        "Supervisor" => "supervisor",
        "MagazaMuduru" => "manager",
        _ => "slate"
    };
}
