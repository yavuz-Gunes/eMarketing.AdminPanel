@inject OrderApiClient OrdersApi

@if (OrderId.HasValue)
{
    <div class="fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-sm" @onclick="Close"></div>
    <aside class="fixed inset-y-0 right-0 z-50 flex w-full max-w-2xl flex-col border-l border-slate-200 bg-white shadow-2xl">
        <header class="border-b border-slate-200 p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase text-slate-500">Sipariş Detayı</p>
                    <h2 class="mt-1 text-2xl font-bold text-slate-950">@(Detail?.Order.OrderNo ?? "Yükleniyor")</h2>
                    @if (Detail is not null)
                    {
                        <p class="mt-1 text-sm text-slate-500">@Detail.Order.MagazaAdi · @Detail.Order.YetkiliAdi</p>
                    }
                </div>
                <button class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 text-xl text-slate-500 hover:bg-slate-50" @onclick="Close">×</button>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-6">
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">@Message</div>
            }
            else if (Detail is null)
            {
                <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-500">Sipariş yükleniyor...</div>
            }
            else
            {
                <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 p-4 text-sm">
                    <InfoRow Label="Durum" Value="@Detail.Order.SiparisDurumu" />
                    <InfoRow Label="Tarih" Value="@DateText" />
                    <InfoRow Label="Sipariş türü" Value="@Detail.Order.OrderType" />
                    <InfoRow Label="Kaynak" Value="@Detail.Order.OrderSource" />
                    <InfoRow Label="Toplam" Value="@Detail.Order.ToplamTutar.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))" />
                </div>

                <section class="mt-6 space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <h3 class="text-lg font-bold text-slate-950">Ürün Kalemleri</h3>
                        <StatusBadge Text="@($"{Detail.Items.Count} ürün")" Tone="info" />
                    </div>
                    @foreach (OrderDetailItemDto item in Detail.Items)
                    {
                        <article class="flex gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/60">
                            @if (!string.IsNullOrWhiteSpace(item.GorselUrl))
                            {
                                <img class="h-20 w-20 shrink-0 rounded-xl object-cover" src="@item.GorselUrl.Replace("\\", "/")" alt="@item.UrunAdi" />
                            }
                            else
                            {
                                <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-lg font-bold text-slate-400">@Initials(item.UrunAdi)</div>
                            }
                            <div class="min-w-0 flex-1">
                                <p class="font-semibold text-slate-950">@item.UrunAdi</p>
                                <p class="mt-1 text-sm text-slate-500">@item.KategoriAdi</p>
                                <div class="mt-3 flex flex-wrap items-center gap-3 text-sm">
                                    <span class="rounded-lg bg-slate-100 px-2.5 py-1 font-semibold text-slate-700">@item.Quantity adet</span>
                                    <span class="text-slate-500">Birim: @item.UnitPrice.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</span>
                                    <span class="ml-auto font-bold text-slate-950">@item.LineTotal.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</span>
                                </div>
                            </div>
                        </article>
                    }
                </section>
            }
        </div>
    </aside>
}

@code {
    [Parameter] public int? OrderId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private OrderDetailResponseDto? Detail { get; set; }
    private string Message { get; set; } = string.Empty;
    private int? LoadedOrderId { get; set; }
    private string DateText => Detail?.Order.SiparisTarihi?.ToString("dd.MM.yyyy HH:mm", CultureInfo.GetCultureInfo("tr-TR")) ?? "-";

    protected override async Task OnParametersSetAsync()
    {
        if (!OrderId.HasValue)
        {
            Detail = null;
            LoadedOrderId = null;
            Message = string.Empty;
            return;
        }

        if (LoadedOrderId == OrderId.Value)
            return;

        LoadedOrderId = OrderId.Value;
        Detail = null;
        Message = string.Empty;

        try
        {
            Detail = await OrdersApi.GetOrderDetailAsync(OrderId.Value);
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private Task Close() => OnClose.InvokeAsync();

    private static string Initials(string text)
    {
        return string.Join("", text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
    }
}
