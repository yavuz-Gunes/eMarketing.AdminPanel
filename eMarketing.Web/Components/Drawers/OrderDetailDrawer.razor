@inject OrderApiClient OrdersApi
@inject AuthSession Auth

@if (OrderId.HasValue)
{
    <div class="fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-sm" @onclick="Close"></div>
    <aside class="fixed inset-y-0 right-0 z-50 flex w-full max-w-2xl flex-col border-l border-slate-200 bg-white shadow-2xl">
        <header class="border-b border-slate-200 p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase text-slate-500">Sipariş Detayı</p>
                    <h2 class="mt-1 text-2xl font-bold text-slate-950">@(Detail?.Order.OrderNo ?? "Yükleniyor")</h2>
                    @if (Detail is not null)
                    {
                        <p class="mt-1 text-sm text-slate-500">@Detail.Order.MagazaAdi · @Detail.Order.YetkiliAdi</p>
                    }
                </div>
                <button class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 text-xl text-slate-500 hover:bg-slate-50" @onclick="Close">×</button>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-6">
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">@Message</div>
            }
            else if (Detail is null)
            {
                <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-500">Sipariş yükleniyor...</div>
            }
            else
            {
                <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 p-4 text-sm">
                    <InfoRow Label="Durum" Value="@DisplayStatus(Detail.Order.SiparisDurumu)" />
                    <InfoRow Label="Tarih" Value="@DateText" />
                    <InfoRow Label="Sipariş türü" Value="@Detail.Order.OrderType" />
                    <InfoRow Label="Kaynak" Value="@Detail.Order.OrderSource" />
                    <InfoRow Label="Toplam" Value="@Detail.Order.ToplamTutar.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))" />
                </div>

                @if (CanManageOrders)
                {
                    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="flex flex-wrap items-end gap-3">
                            <label class="min-w-52 flex-1">
                                <span class="mb-1 block text-xs font-bold uppercase tracking-wide text-slate-500">Sipariş Durumu</span>
                                <select class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-800 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100"
                                        @bind="SelectedStatus">
                                    <option value="Hazirlaniyor">Hazırlanıyor</option>
                                    <option value="Kargoda">Kargoda</option>
                                    <option value="Teslim Edildi">Teslim Edildi</option>
                                    <option value="Iptal">İptal</option>
                                </select>
                            </label>

                            <button type="button"
                                    class="inline-flex h-11 items-center justify-center rounded-xl bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-50"
                                    disabled="@Saving"
                                    @onclick="SaveStatusAsync">
                                Kaydet
                            </button>
                        </div>

                        <p class="mt-3 text-xs leading-5 text-slate-500">
                            “Teslim Edildi” seçildiğinde mevcut backend akışı sipariş kalemlerini bayi stoğuna işler. “İptal” seçimi merkez stok iadesi kurallarını çalıştırır.
                        </p>
                    </section>
                }

                <section class="mt-6 space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <h3 class="text-lg font-bold text-slate-950">Ürün Kalemleri</h3>
                        <StatusBadge Text="@($"{Detail.Items.Count} ürün")" Tone="info" />
                    </div>
                    @foreach (OrderDetailItemDto item in Detail.Items)
                    {
                        <article class="flex gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/60">
                            @if (!string.IsNullOrWhiteSpace(item.GorselUrl))
                            {
                                <img class="h-20 w-20 shrink-0 rounded-xl object-cover" src="@item.GorselUrl.Replace("\\", "/")" alt="@item.UrunAdi" />
                            }
                            else
                            {
                                <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-lg font-bold text-slate-400">@Initials(item.UrunAdi)</div>
                            }
                            <div class="min-w-0 flex-1">
                                <p class="font-semibold text-slate-950">@item.UrunAdi</p>
                                <p class="mt-1 text-sm text-slate-500">@item.KategoriAdi</p>
                                <div class="mt-3 flex flex-wrap items-center gap-3 text-sm">
                                    <span class="rounded-lg bg-slate-100 px-2.5 py-1 font-semibold text-slate-700">@item.Quantity adet</span>
                                    <span class="text-slate-500">Birim: @item.UnitPrice.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</span>
                                    <span class="ml-auto font-bold text-slate-950">@item.LineTotal.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</span>
                                </div>
                            </div>
                        </article>
                    }
                </section>
            }
        </div>
    </aside>
}

@code {
    [Parameter] public int? OrderId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private OrderDetailResponseDto? Detail { get; set; }
    private string Message { get; set; } = string.Empty;
    private int? LoadedOrderId { get; set; }
    private string SelectedStatus { get; set; } = "Hazirlaniyor";
    private bool Saving { get; set; }
    private string DateText => Detail?.Order.SiparisTarihi?.ToString("dd.MM.yyyy HH:mm", CultureInfo.GetCultureInfo("tr-TR")) ?? "-";
    private bool CanManageOrders => Auth.User?.Rol is "Admin" or "Yonetici" or "StoreManager";

    protected override async Task OnParametersSetAsync()
    {
        if (!OrderId.HasValue)
        {
            Detail = null;
            LoadedOrderId = null;
            Message = string.Empty;
            return;
        }

        if (LoadedOrderId == OrderId.Value)
            return;

        await LoadOrderAsync(OrderId.Value);
    }

    private async Task LoadOrderAsync(int orderId)
    {
        LoadedOrderId = orderId;
        Detail = null;
        Message = string.Empty;

        try
        {
            Detail = await OrdersApi.GetOrderDetailAsync(orderId);
            SelectedStatus = NormalizeStatus(Detail.Order.SiparisDurumu);
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private async Task SaveStatusAsync()
    {
        if (Detail is null || Saving)
            return;

        if (!CanTransition(Detail.Order.SiparisDurumu, SelectedStatus))
            return;

        try
        {
            Saving = true;
            Message = string.Empty;

            if (SelectedStatus == "Iptal")
                await OrdersApi.CancelOrderAsync(Detail.Order.SiparisId);
            else
                await OrdersApi.UpdateOrderStatusAsync(Detail.Order.SiparisId, SelectedStatus);

            await LoadOrderAsync(Detail.Order.SiparisId);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
        finally
        {
            Saving = false;
        }
    }

    private Task Close() => OnClose.InvokeAsync();

    private static bool CanTransition(string currentStatus, string nextStatus)
    {
        currentStatus = NormalizeStatus(currentStatus);

        if (currentStatus == nextStatus)
            return true;

        if (currentStatus == "Iptal")
            return false;

        if (currentStatus == "Kargoda" && nextStatus == "Hazirlaniyor")
            return false;

        if (currentStatus == "Teslim Edildi" && nextStatus != "Iptal")
            return false;

        return true;
    }

    private static string NormalizeStatus(string status)
    {
        return status switch
        {
            "Hazırlanıyor" => "Hazirlaniyor",
            "İptal" => "Iptal",
            _ => status
        };
    }

    private static string DisplayStatus(string status)
    {
        return NormalizeStatus(status) switch
        {
            "Hazirlaniyor" => "Hazırlanıyor",
            "Iptal" => "İptal",
            var value => value
        };
    }

    private static string Initials(string text)
    {
        return string.Join("", text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
    }
}
