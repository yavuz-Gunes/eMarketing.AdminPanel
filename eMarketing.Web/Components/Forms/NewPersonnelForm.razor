@inject TeamApiClient TeamApi
@inject ActionFeedbackService Feedback

<aside class="sticky top-24 flex max-h-[calc(100vh-7rem)] w-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10">
    <EditForm Model="Model" OnSubmit="SubmitAsync" class="flex min-h-0 flex-1 flex-col">
        <DataAnnotationsValidator />

        <header class="border-b border-slate-200 px-5 py-4">
            <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                    <p class="text-xs font-black uppercase tracking-wide text-blue-700">Yeni Personel</p>
                    <h2 class="mt-1 text-2xl font-black tracking-normal text-slate-950">Personel ekle</h2>
                    <p class="mt-1 truncate text-sm font-bold text-slate-500">@StoreName</p>
                </div>
                <button type="button"
                        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-slate-200 text-slate-500 transition hover:bg-slate-50 hover:text-slate-950"
                        @onclick="Cancel"
                        title="Kapat">
                    <AppIcon Name="x" CssClass="h-5 w-5" />
                </button>
            </div>
        </header>

        <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-5 py-4">
            <div class="flex gap-3 rounded-xl border border-blue-200 bg-blue-50 p-3 text-sm text-blue-900">
                <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-blue-600 text-white">
                    <AppIcon Name="shield" CssClass="h-4 w-4" />
                </div>
                <div>
                    <p class="font-black">Bu bayi adına işlem yapacak.</p>
                    <p class="mt-1 leading-5 text-blue-800">Yeni personel yalnızca aktif bayi kapsamına bağlanır.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="@MessageClass">@Message</div>
            }

            <section class="space-y-3">
                <h3 class="text-xs font-black uppercase tracking-wide text-slate-500">Kimlik</h3>
                <TextField Label="Ad Soyad" Kind="person" MaxLength="150" Required="true" IsInvalid="@NameInvalid" ErrorText="@NameError" Placeholder="Ad Soyad" @bind-Value="Model.AdSoyad" />
                <TextField Label="Kullanıcı adı" MaxLength="100" Required="true" IsInvalid="@UsernameInvalid" ErrorText="@UsernameError" Placeholder="Kullanıcı adı" @bind-Value="Model.KullaniciAdi" />
                <label class="block">
                    <span class="@PasswordLabelClass">Geçici şifre</span>
                    <InputText type="password" class="@PasswordInputClass" @bind-Value="Model.Sifre" placeholder="Şifre" />
                    @if (!string.IsNullOrWhiteSpace(PasswordError))
                    {
                        <span class="mt-1 block text-xs font-bold text-rose-600">@PasswordError</span>
                    }
                </label>
            </section>

            <section class="space-y-3">
                <h3 class="text-xs font-black uppercase tracking-wide text-slate-500">İletişim</h3>
                <TextField Label="Telefon" Kind="phone" MaxLength="60" MinDigits="10" MaxDigits="12" IsInvalid="@PhoneInvalid" ErrorText="@PhoneError" Placeholder="05XX XXX XX XX" @bind-Value="Model.Telefon" />
                <TextField Label="E-posta" Kind="email" MaxLength="400" IsInvalid="@EmailInvalid" ErrorText="@EmailError" Placeholder="ornek@domain.com" @bind-Value="Model.Email" />
            </section>

            <section class="space-y-3">
                <h3 class="text-xs font-black uppercase tracking-wide text-slate-500">Yetki</h3>
                <label class="block space-y-1 text-sm font-bold text-slate-700">
                    <span>Görev</span>
                    <InputSelect class="@InputClass" @bind-Value="Model.Gorev">
                        <option value="Personel">Personel</option>
                        <option value="MagazaMuduru">Mağaza Müdürü</option>
                        <option value="Supervisor">Supervisor</option>
                    </InputSelect>
                </label>
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-600">
                    Sipariş yetkisi, personel kaydedildikten sonra ekip kartından veya detay panelinden yönetilir.
                </div>
            </section>

            <ValidationSummary class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm font-bold text-rose-700" />
        </div>

        <footer class="flex gap-2 border-t border-slate-200 bg-white px-5 py-4">
            <CommandButton Text="İptal" Icon="x" Tone="secondary" Size="lg" Disabled="Busy" OnClick="@Cancel" />
            <CommandButton Text="Kaydet" BusyText="Kaydediliyor..." Icon="check" Tone="primary" Size="lg" Type="submit" Busy="Busy" />
        </footer>
    </EditForm>
</aside>

@code {
    [Parameter] public int StoreId { get; set; }
    [Parameter] public string StoreName { get; set; } = "Aktif bayi";
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private StorePersonnelCreateRequest Model { get; set; } = new();
    private string Message { get; set; } = string.Empty;
    private bool IsError { get; set; }
    private bool Busy { get; set; }
    private bool ValidationVisible { get; set; }

    private const string InputClass = "h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm outline-none transition placeholder:text-slate-400 focus:border-blue-300 focus:ring-4 focus:ring-blue-100";

    private string MessageClass => IsError
        ? "rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm font-bold text-rose-700"
        : "rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm font-bold text-emerald-700";
    private string NameError => ValidationVisible ? FormValidators.RequiredError(Model.AdSoyad, "Ad Soyad") ?? FormValidators.PersonError(Model.AdSoyad, "Ad Soyad") ?? string.Empty : string.Empty;
    private string UsernameError => ValidationVisible ? FormValidators.RequiredError(Model.KullaniciAdi, "Kullanıcı adı") ?? string.Empty : string.Empty;
    private string PasswordError => ValidationVisible ? ValidatePassword() ?? string.Empty : string.Empty;
    private string PhoneError => ValidationVisible ? FormValidators.PhoneError(Model.Telefon) ?? string.Empty : string.Empty;
    private string EmailError => ValidationVisible ? FormValidators.EmailError(Model.Email) ?? string.Empty : string.Empty;
    private bool NameInvalid => !string.IsNullOrWhiteSpace(NameError);
    private bool UsernameInvalid => !string.IsNullOrWhiteSpace(UsernameError);
    private bool PhoneInvalid => !string.IsNullOrWhiteSpace(PhoneError);
    private bool EmailInvalid => !string.IsNullOrWhiteSpace(EmailError);
    private string PasswordLabelClass => !string.IsNullOrWhiteSpace(PasswordError)
        ? "text-xs font-black uppercase text-rose-600"
        : "text-xs font-black uppercase text-slate-500";
    private string PasswordInputClass => !string.IsNullOrWhiteSpace(PasswordError)
        ? "mt-1 h-12 w-full rounded-xl border border-rose-300 bg-rose-50/40 px-4 text-sm font-semibold text-slate-900 outline-none transition placeholder:text-rose-300 focus:border-rose-400 focus:ring-4 focus:ring-rose-100"
        : "mt-1 h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-800 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100";

    private async Task SubmitAsync()
    {
        ValidationVisible = true;
        if (!IsFormValid())
        {
            Message = "Eksik veya hatalı alanlar var.";
            IsError = true;
            Feedback.Warning("Eksik veya hatalı alanlar var", "Lütfen kırmızı işaretli alanları kontrol edin.");
            return;
        }

        Busy = true;
        try
        {
            await TeamApi.CreatePersonnelAsync(StoreId, Model);
            Model = new StorePersonnelCreateRequest();
            ValidationVisible = false;
            Feedback.Success("Personel eklendi", "Yeni personel aktif bayi kapsamına bağlandı.");
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Message = ex.Message;
            IsError = true;
            Feedback.Error("Personel eklenemedi", ex.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private Task Cancel() => OnCancel.InvokeAsync();

    private bool IsFormValid()
    {
        return string.IsNullOrWhiteSpace(NameError)
            && string.IsNullOrWhiteSpace(UsernameError)
            && string.IsNullOrWhiteSpace(PasswordError)
            && string.IsNullOrWhiteSpace(PhoneError)
            && string.IsNullOrWhiteSpace(EmailError);
    }

    private string? ValidatePassword()
    {
        if (string.IsNullOrWhiteSpace(Model.Sifre))
            return "Şifre zorunludur.";

        if (Model.Sifre.Trim().Length < 4)
            return "Şifre en az 4 karakter olmalı.";

        return null;
    }
}
