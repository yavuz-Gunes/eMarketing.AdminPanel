<div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
    <TextField Label="Mağaza adı" @bind-Value="Model.StoreName" />
    <TextField Label="Şehir" @bind-Value="Model.City" />
    <TextField Label="İlçe" @bind-Value="Model.District" />
    <TextField Label="Telefon" @bind-Value="Model.Phone" />

    <section class="rounded-xl border border-slate-200 bg-white p-3 md:col-span-2 xl:col-span-2">
        <div class="flex flex-wrap items-start justify-between gap-2">
            <div>
                <p class="text-xs font-black uppercase tracking-wide text-slate-500">Sorumlu personel</p>
                <p class="mt-1 text-xs font-semibold text-slate-500">Mağazaya bağlı aktif personelden seçilir.</p>
            </div>
            @if (SelectedResponsible is not null)
            {
                <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-black text-emerald-700">@SelectedResponsible.MagazaGorevGorunenAd</span>
            }
        </div>

        @if (PersonnelLoading)
        {
            <div class="mt-3 rounded-xl border border-slate-100 bg-slate-50 px-3 py-3 text-sm font-bold text-slate-500">Personel yükleniyor...</div>
        }
        else if (Personnel.Count == 0)
        {
            <div class="mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-3 text-sm font-bold leading-5 text-amber-800">@PersonnelEmptyText</div>
        }
        else
        {
            <label class="mt-3 block">
                <span class="sr-only">Personel ara</span>
                <input class="h-10 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 text-sm font-semibold text-slate-700 outline-none focus:border-blue-300 focus:bg-white focus:ring-4 focus:ring-blue-100"
                       @bind="PersonnelSearch"
                       @bind:event="oninput"
                       placeholder="Personel ara" />
            </label>
            <select class="mt-2 h-12 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm font-bold text-slate-700 outline-none focus:border-blue-300 focus:ring-4 focus:ring-blue-100"
                    value="@ResponsibleSelectValue"
                    @onchange="OnResponsibleChanged">
                <option value="">Sorumlu personel seçiniz</option>
                @foreach (StoreTeamMemberDto member in FilteredPersonnel)
                {
                    <option value="@member.KullaniciId">@member.AdSoyad - @member.MagazaGorevGorunenAd</option>
                }
            </select>

            @if (SelectedResponsible is not null)
            {
                <div class="mt-3 grid gap-2 rounded-xl border border-blue-100 bg-blue-50 px-3 py-3 text-xs font-bold text-slate-700 sm:grid-cols-3">
                    <span class="truncate">@SelectedResponsible.AdSoyad</span>
                    <span class="truncate text-slate-500">@EmptyText(SelectedResponsible.Telefon)</span>
                    <span class="text-blue-700">@(SelectedResponsible.SiparisYetkilisiMi ? "Sipariş yetkilisi" : "Personel")</span>
                </div>
            }
        }
    </section>

    <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold text-slate-700">
        <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600" @bind="Model.IsActive" />
        Aktif mağaza
    </label>
    <label class="md:col-span-2 xl:col-span-3">
        <span class="text-xs font-black uppercase text-slate-500">Adres</span>
        <textarea class="mt-1 min-h-20 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none focus:border-blue-300 focus:ring-4 focus:ring-blue-100"
                  @bind="Model.Address"></textarea>
    </label>
</div>

@code {
    [Parameter, EditorRequired] public DealerStoreSaveRequest Model { get; set; } = new();
    [Parameter] public IReadOnlyList<StoreTeamMemberDto> Personnel { get; set; } = Array.Empty<StoreTeamMemberDto>();
    [Parameter] public bool PersonnelLoading { get; set; }
    [Parameter] public string PersonnelEmptyText { get; set; } = "Mağaza kaydedildikten sonra personel bağlanabilir.";

    private string PersonnelSearch { get; set; } = string.Empty;
    private string ResponsibleSelectValue => Model.SorumluKullaniciId?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
    private StoreTeamMemberDto? SelectedResponsible => Personnel.FirstOrDefault(member => member.KullaniciId == Model.SorumluKullaniciId);
    private IEnumerable<StoreTeamMemberDto> FilteredPersonnel => Personnel
        .Where(member => string.IsNullOrWhiteSpace(PersonnelSearch)
            || $"{member.AdSoyad} {member.KullaniciAdi} {member.Telefon} {member.MagazaGorevGorunenAd}".Contains(PersonnelSearch, StringComparison.CurrentCultureIgnoreCase));

    private void OnResponsibleChanged(ChangeEventArgs args)
    {
        string value = args.Value?.ToString() ?? string.Empty;
        if (!int.TryParse(value, out int userId))
        {
            Model.SorumluKullaniciId = null;
            Model.ResponsiblePerson = string.Empty;
            return;
        }

        StoreTeamMemberDto? member = Personnel.FirstOrDefault(item => item.KullaniciId == userId);
        Model.SorumluKullaniciId = member?.KullaniciId;
        Model.ResponsiblePerson = member?.AdSoyad ?? string.Empty;
    }

    private static string EmptyText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }
}
