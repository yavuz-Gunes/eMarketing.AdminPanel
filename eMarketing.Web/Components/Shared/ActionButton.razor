<button class="@CssClass" @onclick="OnClick">
    <span class="@IconClass">@Icon</span>
    <span class="flex-1 text-left">@Title</span>
    <span class="text-xl text-slate-400">›</span>
</button>

@code {
    [Parameter] public string Icon { get; set; } = "●";
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Tone { get; set; } = "blue";
    [Parameter] public EventCallback OnClick { get; set; }

    private string CssClass => Tone == "danger"
        ? "flex w-full items-center gap-3 rounded-2xl border border-rose-200 bg-white p-4 font-semibold text-rose-700 shadow-sm transition hover:bg-rose-50"
        : "flex w-full items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 font-semibold text-slate-900 shadow-sm transition hover:border-blue-200 hover:bg-slate-50";

    private string IconClass => Tone switch
    {
        "danger" => "flex h-10 w-10 items-center justify-center rounded-xl bg-rose-50 text-xl text-rose-600",
        "amber" => "flex h-10 w-10 items-center justify-center rounded-xl bg-amber-50 text-xl text-amber-600",
        _ => "flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-xl text-blue-600"
    };
}
