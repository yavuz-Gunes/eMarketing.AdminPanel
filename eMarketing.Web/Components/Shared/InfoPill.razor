<span class="@ContainerClass">
    <span class="@IconClass">
        <AppIcon Name="@Icon" CssClass="h-3.5 w-3.5" />
    </span>
    <span class="min-w-0">
        <span class="text-slate-400">@Label:</span>
        <span class="ml-1 truncate text-slate-700">@Value</span>
    </span>
</span>

@code {
    [Parameter] public string Icon { get; set; } = "circle";
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Tone { get; set; } = "slate";

    private string ContainerClass => $"inline-flex max-w-full items-center gap-1.5 rounded-lg px-2.5 py-1.5 font-bold {ToneClass}";

    private string IconClass => $"inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md {IconToneClass}";

    private string ToneClass => Tone switch
    {
        "blue" => "bg-blue-50 text-blue-800",
        "emerald" => "bg-emerald-50 text-emerald-800",
        "amber" => "bg-amber-50 text-amber-800",
        _ => "bg-slate-50 text-slate-700"
    };

    private string IconToneClass => Tone switch
    {
        "blue" => "bg-blue-100 text-blue-700",
        "emerald" => "bg-emerald-100 text-emerald-700",
        "amber" => "bg-amber-100 text-amber-700",
        _ => "bg-slate-100 text-slate-600"
    };
}
