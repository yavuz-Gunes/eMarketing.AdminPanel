<label class="block">
    <span class="text-xs font-black uppercase text-slate-500">@Label</span>
    <input class="mt-1 h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-800 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100"
           value="@Value"
           @oninput="OnInput"
           placeholder="@Placeholder"
           type="@InputType"
           inputmode="@InputMode"
           pattern="@Pattern"
           maxlength="@MaxLength" />
    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <span class="mt-1 block text-xs font-semibold text-slate-500">@Hint</span>
    }
</label>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Kind { get; set; } = "text";
    [Parameter] public string Hint { get; set; } = string.Empty;
    [Parameter] public int? MaxLength { get; set; }

    private string InputType => Kind == "email" ? "email" : "text";
    private string InputMode => Kind switch
    {
        "numeric" => "numeric",
        "decimal" => "decimal",
        "expiry" => "numeric",
        "phone" => "tel",
        "email" => "email",
        _ => "text"
    };

    private string? Pattern => Kind switch
    {
        "numeric" => "[0-9]*",
        "decimal" => "[0-9,.]*",
        "expiry" => "(0[1-9]|1[0-2])/[0-9]{2}",
        "phone" => "[0-9+()\\-\\s]*",
        "person" => "[^0-9]*",
        _ => null
    };

    private Task OnInput(ChangeEventArgs args)
    {
        return ValueChanged.InvokeAsync(Sanitize(args.Value?.ToString() ?? string.Empty));
    }

    private string Sanitize(string value)
    {
        return Kind switch
        {
            "numeric" => new string(value.Where(char.IsDigit).ToArray()),
            "decimal" => SanitizeDecimal(value),
            "expiry" => SanitizeExpiry(value),
            "phone" => new string(value.Where(IsPhoneCharacter).ToArray()),
            "person" => new string(value.Where(character => !char.IsDigit(character)).ToArray()),
            _ => value
        };
    }

    private static string SanitizeDecimal(string value)
    {
        bool separatorSeen = false;
        var result = new List<char>();

        foreach (char character in value)
        {
            if (char.IsDigit(character))
            {
                result.Add(character);
                continue;
            }

            if ((character == ',' || character == '.') && !separatorSeen)
            {
                result.Add(character);
                separatorSeen = true;
            }
        }

        return new string(result.ToArray());
    }

    private static bool IsPhoneCharacter(char character)
    {
        return char.IsDigit(character)
            || character is '+' or '(' or ')' or '-' or ' ';
    }

    private static string SanitizeExpiry(string value)
    {
        string digits = new(value.Where(char.IsDigit).Take(4).ToArray());
        return digits.Length <= 2 ? digits : $"{digits[..2]}/{digits[2..]}";
    }
}
