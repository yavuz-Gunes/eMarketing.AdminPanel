<a href="@Href" class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/60 transition hover:border-blue-200 hover:shadow-md">
    <div class="@IconClass">@Icon</div>
    <div class="min-w-0 flex-1">
        <p class="font-semibold text-slate-950">@Title</p>
        <p class="mt-1 text-sm leading-5 text-slate-500">@Description</p>
    </div>
    <span class="text-xl text-slate-400 transition group-hover:translate-x-1 group-hover:text-blue-600">›</span>
</a>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = "●";
    [Parameter] public string Tone { get; set; } = "blue";

    private string IconClass => Tone switch
    {
        "emerald" => "flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-emerald-100 text-3xl text-emerald-700",
        "violet" => "flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-violet-100 text-3xl text-violet-700",
        "amber" => "flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-3xl text-amber-700",
        _ => "flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-blue-100 text-3xl text-blue-700"
    };
}
