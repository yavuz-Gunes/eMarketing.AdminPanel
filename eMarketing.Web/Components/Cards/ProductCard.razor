<article class="@CardClass">
    <div class="relative aspect-[16/11] overflow-hidden bg-slate-100">
        @if (!string.IsNullOrWhiteSpace(Product.GorselUrl))
        {
            <img class="h-full w-full object-cover transition duration-300 group-hover:scale-105" src="@ImageUrl" alt="@Product.UrunAdi" />
        }
        else
        {
            <div class="flex h-full items-center justify-center bg-gradient-to-br from-slate-100 to-blue-50 text-3xl font-black text-slate-400">@Initials</div>
        }

        <div class="absolute left-3 top-3">
            <span class="rounded-md bg-white/95 px-2.5 py-1 text-xs font-black text-slate-700 shadow-sm">@Product.KategoriAdi</span>
        </div>

        <div class="absolute right-3 top-3">
            <span class="@StatusBadgeClass">@StatusText</span>
        </div>

        @if (IsCritical && Product.AktifMi)
        {
            <div class="absolute bottom-3 left-3">
                <span class="rounded-md bg-rose-600 px-2.5 py-1 text-xs font-black text-white shadow-sm shadow-rose-950/20">Kritik stok</span>
            </div>
        }
    </div>

    <div class="flex flex-1 flex-col p-3">
        <div class="flex-1">
            <h3 class="line-clamp-1 text-base font-black text-slate-950">@Product.UrunAdi</h3>
            <p class="mt-1 line-clamp-2 min-h-10 text-sm leading-5 text-slate-500">@Product.Aciklama</p>
        </div>

        <div class="mt-3 flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50 px-3 py-2">
            <div>
                <p class="text-[10px] font-black uppercase text-slate-400">Bu bayi</p>
                <p class="@StockTone">@AvailableStock adet</p>
            </div>
            @if (ShowAdminStock)
            {
                <div class="text-right">
                    <p class="text-[10px] font-black uppercase text-slate-400">Merkez</p>
                    <p class="text-sm font-black text-slate-950">@DisplayCentralStock</p>
                </div>
            }
        </div>

        <div class="mt-3 flex items-center justify-between gap-2">
            <div>
                <p class="text-lg font-black text-slate-950">@Product.Fiyat.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                <p class="text-xs font-semibold text-slate-500">@StockStatusText</p>
            </div>

            <div class="flex items-center gap-2">
                <button class="@AddButtonClass"
                        @onclick="() => OnAdd.InvokeAsync(Product)">
                    Sepete ekle
                </button>

                @if (ShowAdminStock)
                {
                    <details class="relative z-30">
                        <summary class="list-none rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-black text-slate-700 transition hover:bg-slate-50">
                            Yönet
                        </summary>
                        <div class="absolute bottom-full right-0 z-50 mb-2 w-48 overflow-hidden rounded-lg border border-slate-200 bg-white py-1 text-xs font-black shadow-xl shadow-slate-300/80">
                            <button class="block w-full px-3 py-2 text-left text-blue-700 hover:bg-blue-50" @onclick="() => OnEdit.InvokeAsync(Product)">Düzenle</button>
                            <button class="@MenuStatusClass" @onclick="() => OnToggleStatus.InvokeAsync(Product)">@(Product.AktifMi ? "Pasife al" : "Aktif yap")</button>
                            @if (Stock is not null && DisplayCentralStock > 0)
                            {
                                <button class="block w-full px-3 py-2 text-left text-emerald-700 hover:bg-emerald-50" @onclick="() => OnTransfer.InvokeAsync(Stock)">Merkezden aktar</button>
                            }
                            <button class="block w-full px-3 py-2 text-left text-slate-700 hover:bg-slate-50" @onclick="() => OnCentralStock.InvokeAsync(Product)">Merkez stok ekle</button>
                            <button class="block w-full px-3 py-2 text-left text-slate-700 hover:bg-slate-50" @onclick="() => OnMovements.InvokeAsync(Product)">Stok hareketleri</button>
                        </div>
                    </details>
                }
            </div>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = new();
    [Parameter] public StockItemDto? Stock { get; set; }
    [Parameter] public int CentralStock { get; set; }
    [Parameter] public bool IsCritical { get; set; }
    [Parameter] public bool ShowAdminStock { get; set; }
    [Parameter] public EventCallback<ProductDto> OnAdd { get; set; }
    [Parameter] public EventCallback<ProductDto> OnEdit { get; set; }
    [Parameter] public EventCallback<StockItemDto> OnTransfer { get; set; }
    [Parameter] public EventCallback<ProductDto> OnToggleStatus { get; set; }
    [Parameter] public EventCallback<ProductDto> OnCentralStock { get; set; }
    [Parameter] public EventCallback<ProductDto> OnMovements { get; set; }

    private string ImageUrl => Product.GorselUrl.Replace("\\", "/");
    private string Initials => string.Join("", Product.UrunAdi.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
    private int AvailableStock => Stock?.BayiStok ?? 0;
    private int DisplayCentralStock => Stock?.MerkezStok ?? CentralStock;
    private string CardClass => IsCritical && Product.AktifMi
        ? "group relative flex h-full flex-col rounded-lg border border-rose-200 bg-rose-50/30 shadow-sm shadow-rose-100/70 ring-1 ring-rose-100 transition hover:z-20 hover:border-rose-300 hover:shadow-md"
        : "group relative flex h-full flex-col rounded-lg border border-slate-200 bg-white shadow-sm shadow-slate-200/60 transition hover:z-20 hover:border-blue-200 hover:shadow-md";
    private string StockStatusText => AvailableStock > 0 ? "Satışa hazır" : "Seçili bayide stok yok";
    private string StockTone => AvailableStock <= 0 ? "text-sm font-black text-rose-600" : "text-sm font-black text-emerald-600";
    private string StatusText => !Product.AktifMi ? "Pasif" : AvailableStock <= 0 ? "Stok yok" : "Aktif";
    private string StatusBadgeClass => !Product.AktifMi
        ? "rounded-full bg-slate-900 px-2.5 py-1 text-[11px] font-black text-white shadow-sm"
        : AvailableStock <= 0
            ? "rounded-full bg-rose-50 px-2.5 py-1 text-[11px] font-black text-rose-700 ring-1 ring-rose-100"
            : "rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-black text-emerald-700 ring-1 ring-emerald-100";
    private string AddButtonClass => AvailableStock <= 0 || !Product.AktifMi
        ? "rounded-lg bg-slate-300 px-3 py-2 text-xs font-black text-white shadow-none transition hover:bg-slate-400"
        : "rounded-lg bg-blue-600 px-3 py-2 text-xs font-black text-white shadow-sm shadow-blue-200 transition hover:bg-blue-700";
    private string MenuStatusClass => Product.AktifMi
        ? "block w-full px-3 py-2 text-left text-rose-600 hover:bg-rose-50"
        : "block w-full px-3 py-2 text-left text-emerald-700 hover:bg-emerald-50";
}
