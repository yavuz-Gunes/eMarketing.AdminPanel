<article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm shadow-slate-200/60 transition hover:border-blue-200 hover:shadow-md">
    <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
        @if (!string.IsNullOrWhiteSpace(Product.GorselUrl))
        {
            <img class="h-full w-full object-cover transition duration-300 group-hover:scale-105" src="@ImageUrl" alt="@Product.UrunAdi" />
        }
        else
        {
            <div class="flex h-full items-center justify-center bg-gradient-to-br from-slate-100 to-blue-50 text-4xl font-bold text-slate-400">@Initials</div>
        }
        <div class="absolute left-3 top-3">
            <StatusBadge Text="@Product.KategoriAdi" Tone="slate" />
        </div>
    </div>
    <div class="flex flex-1 flex-col p-5">
        <div class="flex-1">
            <h3 class="text-lg font-semibold text-slate-950">@Product.UrunAdi</h3>
            <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-500">@Product.Aciklama</p>
        </div>
        <div class="mt-5 flex items-center justify-between gap-3">
            <div>
                <p class="text-xl font-bold text-slate-950">@Product.Fiyat.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                <p class="mt-1 text-xs font-medium text-slate-500">Stok: @Product.Stok</p>
            </div>
            <button class="rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm shadow-blue-200 transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none"
                    disabled="@(Product.Stok <= 0)"
                    @onclick="() => OnAdd.InvokeAsync(Product)">
                Sepete ekle
            </button>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = new();
    [Parameter] public EventCallback<ProductDto> OnAdd { get; set; }

    private string ImageUrl => Product.GorselUrl.Replace("\\", "/");
    private string Initials => string.Join("", Product.UrunAdi.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
}
