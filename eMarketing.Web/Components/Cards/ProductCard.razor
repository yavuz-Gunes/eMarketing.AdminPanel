<article class="group flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm shadow-slate-200/60 transition hover:border-blue-200 hover:shadow-md">
    <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
        @if (!string.IsNullOrWhiteSpace(Product.GorselUrl))
        {
            <img class="h-full w-full object-cover transition duration-300 group-hover:scale-105" src="@ImageUrl" alt="@Product.UrunAdi" />
        }
        else
        {
            <div class="flex h-full items-center justify-center bg-gradient-to-br from-slate-100 to-blue-50 text-4xl font-bold text-slate-400">@Initials</div>
        }

        <div class="absolute left-3 top-3">
            <StatusBadge Text="@Product.KategoriAdi" Tone="slate" />
        </div>

        @if (AvailableStock <= 0)
        {
            <div class="absolute right-3 top-3 rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700 ring-1 ring-rose-100">Stok yok</div>
        }
    </div>

    <div class="flex flex-1 flex-col p-4">
        <div class="flex-1">
            <h3 class="text-base font-black text-slate-950">@Product.UrunAdi</h3>
            <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-500">@Product.Aciklama</p>
        </div>

        <div class="mt-4 rounded-lg border border-slate-100 bg-slate-50 p-3">
            <div class="flex items-center justify-between text-sm">
                <span class="font-bold text-slate-500">Bu bayi</span>
                <span class="@StockTone">@AvailableStock adet</span>
            </div>

            @if (ShowAdminStock)
            {
                <div class="mt-2 flex items-center justify-between border-t border-slate-200 pt-2 text-xs font-bold text-slate-500">
                    <span>Merkez stok</span>
                    <span class="text-slate-800">@DisplayCentralStock adet</span>
                </div>
            }
        </div>

        <div class="mt-4 flex items-end justify-between gap-3">
            <div>
                <p class="text-xl font-black text-slate-950">@Product.Fiyat.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                <p class="mt-1 text-xs font-semibold text-slate-500">@StockStatusText</p>
            </div>

            <div class="flex flex-col items-end gap-2">
                <button class="rounded-xl bg-blue-600 px-4 py-3 text-sm font-black text-white shadow-sm shadow-blue-200 transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none"
                        disabled="@(AvailableStock <= 0)"
                        @onclick="() => OnAdd.InvokeAsync(Product)">
                    Sepete ekle
                </button>

                @if (ShowAdminStock && Stock is not null && DisplayCentralStock > 0)
                {
                    <button class="text-xs font-black text-emerald-700 underline-offset-4 transition hover:text-emerald-800 hover:underline"
                            @onclick="() => OnTransfer.InvokeAsync(Stock)">
                        Merkezden aktar
                    </button>
                }
            </div>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = new();
    [Parameter] public StockItemDto? Stock { get; set; }
    [Parameter] public int CentralStock { get; set; }
    [Parameter] public bool ShowAdminStock { get; set; }
    [Parameter] public EventCallback<ProductDto> OnAdd { get; set; }
    [Parameter] public EventCallback<StockItemDto> OnTransfer { get; set; }

    private string ImageUrl => Product.GorselUrl.Replace("\\", "/");
    private string Initials => string.Join("", Product.UrunAdi.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
    private int AvailableStock => Stock?.BayiStok ?? 0;
    private int DisplayCentralStock => Stock?.MerkezStok ?? CentralStock;
    private string StockStatusText => AvailableStock > 0 ? "Seçili bayide satışa hazır" : "Seçili bayide stok yok";
    private string StockTone => AvailableStock <= 0 ? "font-black text-rose-600" : "font-black text-emerald-600";
}
