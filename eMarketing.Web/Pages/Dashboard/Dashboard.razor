@page "/"
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject DashboardApiClient DashboardApi
@inject TeamApiClient TeamApi

<PageTitle>Dashboard - eMarketing</PageTitle>

<AuthGate>
    <section class="grid gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[1fr_420px] lg:px-8">
        <div class="space-y-6">
            <section class="overflow-hidden rounded-2xl border border-blue-100 bg-white shadow-sm shadow-slate-200/60">
                <div class="grid items-center gap-6 p-6 lg:grid-cols-[1fr_320px]">
                    <div>
                        <h1 class="text-3xl font-bold tracking-normal text-slate-950">Bugünkü bayi operasyonları</h1>
                        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Mağazanızın siparişlerini, ekibinizi ve ürün akışını yönetin. Hızlı aksiyonlar alın, satışları artırın.</p>
                    </div>
                    <div class="hidden rounded-2xl bg-gradient-to-br from-blue-50 to-slate-100 p-5 lg:block">
                        <div class="flex items-end justify-center gap-4">
                            <div class="space-y-2 rounded-xl bg-white p-4 shadow-sm">
                                <div class="h-3 w-24 rounded bg-blue-200"></div>
                                <div class="h-3 w-20 rounded bg-slate-200"></div>
                                <div class="h-3 w-28 rounded bg-slate-200"></div>
                            </div>
                            <div class="grid gap-2">
                                <div class="h-12 w-12 rounded-xl bg-blue-300"></div>
                                <div class="h-16 w-16 rounded-xl bg-slate-300"></div>
                            </div>
                            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-slate-900 text-3xl text-white">◉</div>
                        </div>
                    </div>
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">@Message</div>
            }

            <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <MetricCard Title="Açık Siparişler" Value="@OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Icon="▤" Tone="blue" Trend="vs geçen hafta" TrendPrefix="↗ %12" />
                <MetricCard Title="Onay Bekleyenler" Value="@Summary.BekleyenOdemeSayisi.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Icon="◷" Tone="amber" Trend="vs geçen hafta" TrendPrefix="↗ %20" />
                <MetricCard Title="Kritik Stok" Value="@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Icon="△" Tone="rose" Trend="vs geçen hafta" TrendPrefix="↘ %8" />
                <MetricCard Title="Bu Ay Ciro" Value="@Summary.AylikCiro.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))" Icon="↟" Tone="emerald" Trend="vs geçen ay" TrendPrefix="↗ %18" />
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-slate-950">Son Siparişler</h2>
                        <p class="mt-1 text-sm text-slate-500">Aktif mağazanın en güncel sipariş akışı.</p>
                    </div>
                    <a href="/orders" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Tümünü Gör ›</a>
                </div>
                <div class="mt-4 divide-y divide-slate-100">
                    @foreach (DashboardRecentOrderDto order in RecentOrders.Take(5))
                    {
                        <div class="grid items-center gap-3 py-4 text-sm md:grid-cols-[160px_1fr_130px_150px]">
                            <div class="flex items-center gap-3 font-bold text-blue-700">
                                <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700">▤</span>
                                SP-@order.SiparisId.ToString("D5", CultureInfo.InvariantCulture)
                            </div>
                            <div class="min-w-0">
                                <p class="truncate font-semibold text-slate-800">@order.UrunAdi</p>
                                <p class="mt-1 text-xs text-slate-500">@order.OrderType · @order.YetkiliAdi</p>
                            </div>
                            <div class="font-bold text-slate-950">@order.ToplamTutar.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</div>
                            <StatusBadge Text="@order.SiparisDurumu" Tone="@StatusTone(order.SiparisDurumu)" />
                        </div>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
                <h2 class="text-xl font-bold text-slate-950">Hızlı İşlemler</h2>
                <div class="mt-4 grid gap-4 md:grid-cols-3">
                    <QuickActionCard Href="/products" Title="Yeni Sipariş" Description="Hızlıca yeni bir sipariş oluşturun." Icon="◫" Tone="blue" />
                    <QuickActionCard Href="/products" Title="Ürün Ara" Description="Ürün, parça kodu veya kategori ile arayın." Icon="⌕" Tone="violet" />
                    <QuickActionCard Href="/stores" Title="Mağaza Değiştir" Description="Başka bir mağaza seçin ve yönetin." Icon="▤" Tone="emerald" />
                </div>
            </section>
        </div>

        <aside class="space-y-5">
            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
                <div class="mb-4 flex items-center justify-between gap-3">
                    <h2 class="text-xl font-bold text-slate-950">Ekibim</h2>
                    <StatusBadge Text="@TeamCountText" Tone="slate" />
                </div>
                <div class="space-y-3">
                    @foreach (StoreTeamMemberDto member in TeamResponse?.Members.Take(4) ?? Array.Empty<StoreTeamMemberDto>())
                    {
                        <TeamMemberCard Member="member" OnSelect="SelectMember" />
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5">
                <h3 class="font-bold text-amber-950">Güvenlik Notu</h3>
                <p class="mt-3 text-sm leading-6 text-amber-900">Tek aktif supervisor korunur. Mağaza dışı işlemler API katmanında engellenir.</p>
            </section>
        </aside>

        @if (TeamResponse is not null)
        {
            <TeamMemberDrawer StoreId="@TeamResponse.Context.MagazaId"
                              Context="@TeamResponse.Context"
                              Member="@SelectedMember"
                              OnClose="CloseDrawer"
                              OnChanged="LoadTeamAsync" />
        }
    </section>
</AuthGate>

@code {
    private DashboardSummaryDto Summary { get; set; } = new();
    private IReadOnlyList<DashboardRecentOrderDto> RecentOrders { get; set; } = Array.Empty<DashboardRecentOrderDto>();
    private StoreTeamResponseDto? TeamResponse { get; set; }
    private StoreTeamMemberDto? SelectedMember { get; set; }
    private string Message { get; set; } = string.Empty;
    private int OpenOrders => Summary.ToplamSiparis - Summary.TeslimEdildiSayisi - Summary.IptalSayisi;
    private string TeamCountText => $"{TeamResponse?.Members.Count ?? 0}";

    protected override async Task OnInitializedAsync()
    {
        StoreState.Changed += OnStoreChanged;
        await StoreState.LoadAsync(StoreApi);
        await LoadDashboardAsync();
        await LoadTeamAsync();
    }

    private async void OnStoreChanged()
    {
        await LoadDashboardAsync();
        await LoadTeamAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            Summary = await DashboardApi.GetSummaryAsync(StoreState.SelectedStoreId);
            RecentOrders = await DashboardApi.GetRecentOrdersAsync(StoreState.SelectedStoreId);
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private async Task LoadTeamAsync()
    {
        if (StoreState.SelectedStoreId is not int storeId)
            return;

        try
        {
            TeamResponse = await TeamApi.GetTeamAsync(storeId);
        }
        catch
        {
            TeamResponse = null;
        }
    }

    private void SelectMember(StoreTeamMemberDto member) => SelectedMember = member;
    private void CloseDrawer() => SelectedMember = null;

    private static string StatusTone(string status)
    {
        return status switch
        {
            "Teslim Edildi" => "success",
            "Hazirlaniyor" => "info",
            "Hazırlanıyor" => "info",
            "Iptal" => "danger",
            "İptal" => "danger",
            _ => "warning"
        };
    }
}
