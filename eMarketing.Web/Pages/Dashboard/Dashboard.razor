@page "/"
@implements IDisposable
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject DashboardApiClient DashboardApi
@inject TeamApiClient TeamApi
@inject NotificationApiClient NotificationApi
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using System.Text

<PageTitle>Dashboard - eMarketing</PageTitle>

<AuthGate>
    <section class="mx-auto max-w-[1440px] space-y-5 px-4 py-5 sm:px-6 lg:px-8">
        <CampaignCarousel />

        <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_420px]">
                <div class="border-b border-slate-100 p-5 lg:border-b-0 lg:border-r lg:p-6">
                    <div class="flex flex-wrap items-start justify-between gap-4">
                        <div class="min-w-0">
                            <p class="text-xs font-black uppercase tracking-wide text-blue-700">Operasyon Merkezi</p>
                            <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Bayi canlı durum ekranı</h1>
                            <p class="mt-2 max-w-3xl text-sm font-semibold leading-6 text-slate-600">
                                Sipariş kuyruğu, stok alarmı, ekip ve bildirimleri aktif bayi kapsamında tek ekrandan takip edin.
                            </p>
                        </div>
                        <div class="min-w-[220px] rounded-xl border border-slate-200 bg-slate-50 p-3">
                            <ActiveStoreBadge Compact="true" ShowDescription="false" />
                            <p class="mt-3 text-xs font-black uppercase tracking-wide text-slate-500">@TodayText</p>
                        </div>
                    </div>

                    <div class="mt-5 grid gap-3 md:grid-cols-4">
                        <a href="/orders" class="rounded-xl border border-blue-100 bg-blue-50 p-4 transition hover:border-blue-300">
                            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-white text-blue-700"><AppIcon Name="cart" CssClass="h-5 w-5" /></span>
                            <span class="mt-3 block text-xs font-black uppercase text-blue-700">Açık sipariş</span>
                            <span class="mt-1 block text-2xl font-black text-slate-950">@OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                        </a>
                        <a href="@CriticalProductsHref" class="rounded-xl border border-rose-100 bg-rose-50 p-4 transition hover:border-rose-300">
                            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-white text-rose-700"><AppIcon Name="alert" CssClass="h-5 w-5" /></span>
                            <span class="mt-3 block text-xs font-black uppercase text-rose-700">Kritik stok</span>
                            <span class="mt-1 block text-2xl font-black text-slate-950">@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                        </a>
                        <a href="/orders" class="rounded-xl border border-amber-100 bg-amber-50 p-4 transition hover:border-amber-300">
                            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-white text-amber-700"><AppIcon Name="clock" CssClass="h-5 w-5" /></span>
                            <span class="mt-3 block text-xs font-black uppercase text-amber-700">Onay bekleyen</span>
                            <span class="mt-1 block text-2xl font-black text-slate-950">@Summary.BekleyenOdemeSayisi.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                        </a>
                        <a href="/team" class="rounded-xl border border-emerald-100 bg-emerald-50 p-4 transition hover:border-emerald-300">
                            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-white text-emerald-700"><AppIcon Name="users" CssClass="h-5 w-5" /></span>
                            <span class="mt-3 block text-xs font-black uppercase text-emerald-700">Ekip</span>
                            <span class="mt-1 block text-2xl font-black text-slate-950">@TeamCountText</span>
                        </a>
                    </div>
                </div>

                <div class="bg-slate-950 p-4 text-white lg:p-5">
                    <p class="text-xs font-black uppercase tracking-wide text-blue-200">Günün önceliği</p>
                    <h2 class="mt-2 text-xl font-black">@PriorityTitle</h2>
                    <p class="mt-2 text-sm font-semibold leading-6 text-slate-300">@PriorityDescription</p>
                    <div class="mt-4 grid gap-2">
                        <a href="@CriticalProductsHref" class="inline-flex h-11 items-center justify-center rounded-lg bg-white px-4 text-sm font-black text-slate-950 transition hover:bg-blue-50">
                            Stok alarmını aç
                        </a>
                        <a href="/orders" class="inline-flex h-11 items-center justify-center rounded-lg border border-white/15 px-4 text-sm font-black text-white transition hover:bg-white/10">
                            Sipariş kuyruğuna git
                        </a>
                    </div>
                </div>
            </div>
        </section>

        @if (ShowLegacyHeroRemoved)
        {
        <section class="hidden rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div class="min-w-0">
                    <ActiveStoreBadge Compact="true" />
                    <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Bugün neye bakmalısınız?</h1>
                    <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600 sm:text-base">
                        Siparişleri, kritik stokları, kampanyaları ve ekip durumunu aktif bayiye göre takip edin.
                    </p>
                </div>

                <div class="grid gap-2 sm:grid-cols-3 lg:min-w-[430px]">
                    <a href="/orders" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-blue-200 hover:bg-blue-50">
                        <span class="text-xs font-black uppercase tracking-wide text-slate-500">Açık sipariş</span>
                        <span class="mt-2 block text-2xl font-black text-slate-950">@OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                    </a>
                        <a href="@CriticalProductsHref" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-rose-200 hover:bg-rose-50">
                        <span class="text-xs font-black uppercase tracking-wide text-slate-500">Kritik stok</span>
                        <span class="mt-2 block text-2xl font-black text-slate-950">@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                    </a>
                    <a href="/team" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-emerald-200 hover:bg-emerald-50">
                        <span class="text-xs font-black uppercase tracking-wide text-slate-500">Ekip</span>
                        <span class="mt-2 block text-2xl font-black text-slate-950">@TeamCountText</span>
                    </a>
                </div>
            </div>
        </section>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm font-medium text-rose-700">
                @Message
            </div>
        }

        @if (!StoreState.SelectedStoreId.HasValue)
        {
            <div class="rounded-[1.5rem] border border-amber-200 bg-amber-50 p-6 text-sm font-bold text-amber-800">
                Lütfen aktif bayi seçin. Dashboard özetleri seçili bayiye göre yüklenir.
            </div>
        }
        else
        {

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <DashboardMetric Href="/orders" Icon="cart" Label="Açık Siparişler" Value="@OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Hazırlanan ve bekleyen siparişleri aç." Tone="blue" />
            <DashboardMetric Href="/orders" Icon="clock" Label="Onay Bekleyenler" Value="@Summary.BekleyenOdemeSayisi.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Kontrol bekleyen akışları gör." Tone="amber" />
            <DashboardMetric Href="@CriticalProductsHref" Icon="alert" Label="Kritik Stok" Value="@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Riskteki ürünleri ürün listesinde incele." Tone="rose" />
            <DashboardMetric Href="/team" Icon="users" Label="Personel" Value="@TeamCountText" Detail="Bayi ekibine ve yetkilere git." Tone="emerald" />
        </section>

        <section class="grid gap-6 xl:grid-cols-[1fr_360px]">
            <div class="space-y-6">
                <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-xl font-black text-slate-950">Hızlı Aksiyonlar</h2>
                            <p class="mt-1 text-sm text-slate-500">Personelin en sık kullandığı işlemler.</p>
                        </div>
                        <StatusBadge Text="Kısayollar" Tone="info" />
                    </div>

                    <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                        <QuickLink Href="/products" Icon="cart" Title="Yeni Sipariş" Description="Ürün seçip sepete ekleyin." />
                        <QuickLink Href="/orders" Icon="clock" Title="Siparişler" Description="Aktif bayi siparişlerini açın." />
                        <QuickLink Href="/products" Icon="search" Title="Ürün Ara" Description="Parça, kategori veya açıklama ile arayın." />
                        <QuickLink Href="/team" Icon="users" Title="Ekibim" Description="Takım arkadaşlarını ve yetkileri görün." />
                    </div>
                </section>

                <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-xl font-black text-slate-950">Son Siparişler</h2>
                            <p class="mt-1 text-sm text-slate-500">Aktif bayinin güncel sipariş hareketleri.</p>
                        </div>

                        <a href="/orders" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 transition hover:bg-slate-50">
                            Tümünü Gör
                            <AppIcon Name="chevron-right" CssClass="h-4 w-4" />
                        </a>
                    </div>

                    @if (RecentOrders.Count == 0)
                    {
                        <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 p-8 text-center">
                            <p class="font-bold text-slate-900">Henüz sipariş yok</p>
                            <p class="mt-1 text-sm text-slate-500">Bu bayi için sipariş oluştuğunda burada görünecek.</p>
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 overflow-hidden rounded-2xl border border-slate-100">
                            <div class="hidden grid-cols-[140px_1fr_120px_140px] bg-slate-900 px-4 py-3 text-xs font-bold uppercase tracking-wide text-white md:grid">
                                <span>Sipariş</span>
                                <span>Ürün</span>
                                <span>Tutar</span>
                                <span>Durum</span>
                            </div>

                            <div class="divide-y divide-slate-100">
                                @foreach (DashboardRecentOrderDto order in RecentOrders.Take(5))
                                {
                                    <a href="/orders" class="grid gap-3 px-4 py-4 text-sm transition hover:bg-blue-50/50 md:grid-cols-[140px_1fr_120px_140px] md:items-center">
                                        <div class="flex items-center gap-3 font-bold text-blue-700">
                                            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700">
                                                <AppIcon Name="package" CssClass="h-5 w-5" />
                                            </span>
                                            SP-@order.SiparisId.ToString("D5", CultureInfo.InvariantCulture)
                                        </div>

                                        <div class="min-w-0">
                                            <p class="truncate font-semibold text-slate-900">@DisplayTextNormalizer.Normalize(order.UrunAdi)</p>
                                            <p class="mt-1 text-xs text-slate-500">@DisplayTextNormalizer.Normalize(order.OrderType) / @DisplayTextNormalizer.Normalize(order.YetkiliAdi)</p>
                                        </div>

                                        <div class="font-bold text-slate-950">
                                            @order.ToplamTutar.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))
                                        </div>

                                        <StatusBadge Text="@DisplayStatus(order.SiparisDurumu)" Tone="@StatusTone(order.SiparisDurumu)" />
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </section>
            </div>

            <aside class="space-y-6">
                <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="mb-4 flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-black text-slate-950">Ekibim</h2>
                            <p class="mt-1 text-sm text-slate-500">Bayi ekibi özeti</p>
                        </div>
                        <StatusBadge Text="@TeamCountText" Tone="slate" />
                    </div>

                    @if (TeamResponse?.Members.Count > 0)
                    {
                        <div class="space-y-3">
                            @foreach (StoreTeamMemberDto member in TeamResponse.Members.Take(4))
                            {
                                <button class="flex w-full items-center gap-3 rounded-2xl border border-slate-100 bg-white p-3 text-left transition hover:border-blue-200 hover:bg-blue-50/40"
                                        @onclick="() => SelectMember(member)">
                                    <Avatar Member="member" Size="md" />

                                    <span class="min-w-0 flex-1">
                                        <span class="block truncate font-semibold text-slate-950">@member.AdSoyad</span>
                                        <span class="mt-0.5 block truncate text-sm text-slate-500">@member.MagazaGorevGorunenAd</span>
                                    </span>

                                    <StatusBadge Text="@(member.SiparisYetkilisiMi ? "Sipariş" : "Ekip")" Tone="@(member.SiparisYetkilisiMi ? "info" : "slate")" />
                                </button>
                            }
                        </div>

                        <a href="/team" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50">
                            Ekibin Tümünü Gör
                            <AppIcon Name="chevron-right" CssClass="h-4 w-4" />
                        </a>
                    }
                    else
                    {
                        <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 p-6 text-center">
                            <p class="font-bold text-slate-900">Ekip bilgisi yok</p>
                            <p class="mt-1 text-sm text-slate-500">Bu bayiye personel eklendiğinde burada görünür.</p>
                        </div>
                    }
                </section>

                <section class="rounded-[1.5rem] border border-amber-200 bg-amber-50 p-5 shadow-sm">
                    <div class="flex items-start gap-3">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-white text-amber-600 ring-1 ring-amber-200">
                            <AppIcon Name="alert" CssClass="h-5 w-5" />
                        </div>
                        <div>
                            <h3 class="text-lg font-black text-slate-950">Bildirimler</h3>
                            <p class="mt-2 text-sm leading-6 text-slate-700">
                                Kampanya, mesaj ve kritik stok uyarıları burada görünür.
                            </p>
                            @if (LatestNotifications.Count > 0)
                            {
                                <div class="mt-4 space-y-2">
                                    @foreach (NotificationDto notification in LatestNotifications.Take(3))
                                    {
                                        <a href="@NotificationHref(notification)" class="block rounded-xl bg-white/70 px-3 py-2 text-sm font-bold text-slate-800 transition hover:bg-white">
                                            @notification.Baslik
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </aside>
        </section>

        @if (ShowPriorityPopup)
        {
            <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/45 p-4 backdrop-blur-sm">
                <section class="w-full max-w-md rounded-[1.5rem] border border-white/70 bg-white p-5 shadow-2xl">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-start gap-3">
                            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-rose-50 text-rose-600 ring-1 ring-rose-100">
                                <AppIcon Name="alert" CssClass="h-6 w-6" />
                            </span>
                            <div>
                                <p class="text-xs font-black uppercase tracking-[0.16em] text-rose-600">Önemli Uyarı</p>
                                <h2 class="mt-1 text-xl font-black text-slate-950">Kritik stok var</h2>
                                <p class="mt-2 text-sm leading-6 text-slate-600">
                                    Aktif bayide @Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR")) ürün kritik stok seviyesinde. Öncelikle ürün listesini kontrol edin.
                                </p>
                            </div>
                        </div>

                        <button type="button"
                                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-700"
                                title="Kapat"
                                @onclick="DismissPriorityPopup">
                            <AppIcon Name="x" CssClass="h-5 w-5" />
                        </button>
                    </div>

                    <div class="mt-5 flex flex-wrap gap-3">
                        <button type="button"
                                class="inline-flex h-11 items-center justify-center rounded-xl bg-slate-950 px-4 text-sm font-black text-white transition hover:bg-slate-800"
                                @onclick="GoToPriorityProductsAsync">
                            Ürüne Git
                        </button>
                        <button type="button"
                                class="inline-flex h-11 items-center justify-center rounded-xl border border-slate-200 px-4 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
                                @onclick="DismissPriorityPopup">
                            Sonra Bakacağım
                        </button>
                    </div>
                </section>
            </div>
        }

        @if (TeamResponse is not null)
        {
            <TeamMemberDrawer StoreId="@TeamResponse.Context.MagazaId"
                              Context="@TeamResponse.Context"
                              Member="@SelectedMember"
                              OnClose="CloseDrawer"
                              OnChanged="LoadTeamAsync" />
        }
        }
    </section>
</AuthGate>

@code {
    private DashboardSummaryDto Summary { get; set; } = new();
    private IReadOnlyList<DashboardRecentOrderDto> RecentOrders { get; set; } = Array.Empty<DashboardRecentOrderDto>();
    private IReadOnlyList<DashboardCriticalStockDto> CriticalStocks { get; set; } = Array.Empty<DashboardCriticalStockDto>();
    private IReadOnlyList<NotificationDto> LatestNotifications { get; set; } = Array.Empty<NotificationDto>();
    private StoreTeamResponseDto? TeamResponse { get; set; }
    private StoreTeamMemberDto? SelectedMember { get; set; }
    private string Message { get; set; } = string.Empty;
    private bool PriorityPopupDismissed { get; set; }
    private bool PriorityPopupReady { get; set; }
    private int DashboardLoadVersion { get; set; }
    private int TeamLoadVersion { get; set; }
    private int NotificationLoadVersion { get; set; }

    private int OpenOrders => Math.Max(0, Summary.ToplamSiparis - Summary.TeslimEdildiSayisi - Summary.IptalSayisi);
    private int DashboardTeamCount => TeamResponse?.Members.Count ?? 0;
    private string TeamCountText => DashboardTeamCount.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"));
    private bool ShowLegacyHeroRemoved => false;
    private bool ShowPriorityPopup => false;
    private string TodayText => DateTime.Now.ToString("dd MMMM yyyy, HH:mm", CultureInfo.GetCultureInfo("tr-TR"));
    private string PriorityTitle => Summary.KritikStok > 0
        ? $"{Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))} kritik stok alarmı"
        : OpenOrders > 0
            ? $"{OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))} açık sipariş takipte"
            : "Operasyon dengede";
    private string PriorityDescription => Summary.KritikStok > 0
        ? "Önce kritik stokları kontrol edin; gerekiyorsa merkez stok aktarımı veya ürün kontrolü başlatın."
        : OpenOrders > 0
            ? "Hazırlanan ve kargodaki siparişleri güncel tutarak bayi ekranını temiz bırakın."
            : "Aktif bayide acil aksiyon görünmüyor. Bildirimleri ve kampanyaları izlemeye devam edin.";
    private string CriticalProductsHref => CriticalStocks.Count == 1
        ? $"/products?urunId={CriticalStocks[0].UrunId}"
        : "/products?stok=kritik";

    protected override async Task OnInitializedAsync()
    {
        await StoreState.LoadAsync(StoreApi);
        StoreState.Changed += OnStoreChanged;
        await LoadDashboardAsync();
        await LoadTeamAsync();
        await LoadNotificationsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadPriorityPopupPreferenceAsync();
        PriorityPopupReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private async void OnStoreChanged()
    {
        PriorityPopupReady = false;
        await LoadDashboardAsync();
        await LoadTeamAsync();
        await LoadNotificationsAsync();
        await LoadPriorityPopupPreferenceAsync();
        PriorityPopupReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardAsync()
    {
        int version = ++DashboardLoadVersion;
        int? storeId = StoreState.SelectedStoreId;

        Summary = new();
        RecentOrders = Array.Empty<DashboardRecentOrderDto>();
        CriticalStocks = Array.Empty<DashboardCriticalStockDto>();

        try
        {
            Message = string.Empty;
            if (storeId is not int activeStoreId)
                return;

            DashboardSummaryDto summary = await DashboardApi.GetSummaryAsync(activeStoreId);
            IReadOnlyList<DashboardRecentOrderDto> recentOrders = await DashboardApi.GetRecentOrdersAsync(activeStoreId);
            IReadOnlyList<DashboardCriticalStockDto> criticalStocks = await DashboardApi.GetCriticalStockAsync(activeStoreId);

            if (version != DashboardLoadVersion || StoreState.SelectedStoreId != activeStoreId)
                return;

            Summary = summary;
            RecentOrders = recentOrders;
            CriticalStocks = criticalStocks;
        }
        catch (Exception ex)
        {
            if (version == DashboardLoadVersion)
                Message = ex.Message;
        }
    }

    private async Task LoadTeamAsync()
    {
        int version = ++TeamLoadVersion;
        int? storeId = StoreState.SelectedStoreId;
        TeamResponse = null;
        SelectedMember = null;

        if (storeId is not int activeStoreId)
            return;

        try
        {
            StoreTeamResponseDto response = await TeamApi.GetTeamAsync(activeStoreId);
            if (version != TeamLoadVersion || StoreState.SelectedStoreId != activeStoreId)
                return;

            TeamResponse = response;
        }
        catch
        {
            if (version == TeamLoadVersion)
                TeamResponse = null;
        }
    }

    private async Task LoadNotificationsAsync()
    {
        int version = ++NotificationLoadVersion;
        int? storeId = StoreState.SelectedStoreId;
        LatestNotifications = Array.Empty<NotificationDto>();

        try
        {
            if (storeId is not int activeStoreId)
                return;

            IReadOnlyList<NotificationDto> notifications = await NotificationApi.GetNotificationsAsync(activeStoreId, false, 3);
            if (version != NotificationLoadVersion || StoreState.SelectedStoreId != activeStoreId)
                return;

            LatestNotifications = notifications;
        }
        catch
        {
            if (version == NotificationLoadVersion)
                LatestNotifications = Array.Empty<NotificationDto>();
        }
    }

    private void SelectMember(StoreTeamMemberDto member) => SelectedMember = member;
    private void CloseDrawer() => SelectedMember = null;
    private async Task DismissPriorityPopup()
    {
        PriorityPopupDismissed = true;
        await SavePriorityPopupDismissedAsync();
    }

    private async Task GoToPriorityProductsAsync()
    {
        await DismissPriorityPopup();
        Navigation.NavigateTo(CriticalProductsHref);
    }

    private async Task LoadPriorityPopupPreferenceAsync()
    {
        try
        {
            string key = PriorityPopupStorageKey();
            string? dismissed = await JS.InvokeAsync<string?>("localStorage.getItem", key);
            PriorityPopupDismissed = string.Equals(dismissed, "1", StringComparison.Ordinal);
        }
        catch
        {
            PriorityPopupDismissed = false;
        }
    }

    private async Task SavePriorityPopupDismissedAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", PriorityPopupStorageKey(), "1");
        }
        catch
        {
            // Popup dismissal is a convenience preference.
        }
    }

    private string PriorityPopupStorageKey()
    {
        string storeKey = StoreState.SelectedStoreId?.ToString(CultureInfo.InvariantCulture) ?? "none";
        string today = DateTime.Today.ToString("yyyyMMdd", CultureInfo.InvariantCulture);
        return $"emarketing.critical-stock-popup.{storeKey}.{today}";
    }

    private static string NotificationHref(NotificationDto notification) => string.IsNullOrWhiteSpace(notification.HedefUrl) ? "/notifications" : notification.HedefUrl;

    private static string DisplayText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        string text = value.Trim();
        if (!LooksMojibake(text))
            return text;

        try
        {
            string decoded = Encoding.UTF8.GetString(Encoding.GetEncoding("ISO-8859-1").GetBytes(text));
            return LooksMojibake(decoded) ? text : decoded;
        }
        catch
        {
            return text;
        }
    }

    private static bool LooksMojibake(string value)
    {
        return value.Contains('Ã', StringComparison.Ordinal)
            || value.Contains('Ä', StringComparison.Ordinal)
            || value.Contains('Å', StringComparison.Ordinal)
            || value.Contains('Â', StringComparison.Ordinal);
    }

    private static string DisplayStatus(string status)
    {
        return status switch
        {
            "Hazirlaniyor" => "Hazırlanıyor",
            "Iptal" => "İptal",
            _ => status
        };
    }

    private static string StatusTone(string status)
    {
        return status switch
        {
            "Teslim Edildi" => "success",
            "Hazirlaniyor" => "info",
            "Hazırlanıyor" => "info",
            "Iptal" => "danger",
            "İptal" => "danger",
            _ => "warning"
        };
    }

    public void Dispose()
    {
        StoreState.Changed -= OnStoreChanged;
    }
}
