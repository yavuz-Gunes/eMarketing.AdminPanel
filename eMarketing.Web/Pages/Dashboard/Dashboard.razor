@page "/"
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject DashboardApiClient DashboardApi
@inject TeamApiClient TeamApi

<PageTitle>Dashboard - eMarketing</PageTitle>

<AuthGate>
    <section class="space-y-6 px-4 py-6 sm:px-6 lg:px-8">
        <section class="overflow-hidden rounded-[2rem] bg-[#08172a] text-white shadow-2xl shadow-slate-300/60">
            <div class="grid gap-8 p-6 sm:p-8 xl:grid-cols-[1.08fr_.92fr] xl:p-10">
                <div class="flex min-h-[360px] flex-col justify-between gap-8">
                    <div>
                        <p class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-wide text-blue-100">
                            <AppIcon Name="store" CssClass="h-4 w-4" />
                            @(StoreState.SelectedStore?.MagazaAdi ?? "Aktif mağaza")
                        </p>
                        <h1 class="mt-6 max-w-3xl text-5xl font-black leading-[0.95] tracking-normal text-white sm:text-6xl xl:text-7xl">
                            Bayi Operasyon Merkezi
                        </h1>
                        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
                            Sipariş akışını, ekip durumunu ve stok sağlığını tek ekranda takip edin. Günlük operasyonu hızlıca okuyup doğru aksiyona geçin.
                        </p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-[1fr_auto]">
                        <div class="rounded-2xl bg-slate-100 p-5 text-slate-950">
                            <p class="text-sm font-semibold">Bugünkü ciro</p>
                            <p class="mt-2 text-3xl font-black">@Summary.BugunkuCiro.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))</p>
                        </div>
                        <div class="flex min-h-28 items-center justify-center rounded-2xl bg-[#7f90a7] px-8 text-[#08172a]">
                            <span class="text-7xl font-black leading-none">*</span>
                        </div>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-[1.75rem] border border-blue-400/20 bg-slate-950/70 p-5 shadow-inner shadow-white/5">
                    <div class="absolute inset-x-8 bottom-0 h-28 rounded-full bg-blue-400/20 blur-3xl"></div>
                    <div class="relative mx-auto flex min-h-[350px] max-w-xl items-center justify-center">
                        <div class="w-full rotate-[-2deg] rounded-[1.5rem] border border-white/10 bg-[#121a25] p-4 shadow-2xl shadow-black/50">
                            <div class="flex items-center justify-between border-b border-white/10 pb-3">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Stock cockpit</p>
                                    <p class="mt-1 text-lg font-black text-white">eMarketing.Web</p>
                                </div>
                                <div class="flex gap-1.5">
                                    <span class="h-2.5 w-2.5 rounded-full bg-rose-400"></span>
                                    <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
                                    <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                                </div>
                            </div>
                            <div class="mt-4 grid gap-3 lg:grid-cols-[1fr_150px]">
                                <div class="space-y-3">
                                    <div class="rounded-2xl bg-white/[0.06] p-4">
                                        <div class="mb-4 flex items-center justify-between text-sm">
                                            <span class="font-semibold text-slate-300">Stok hareketi</span>
                                            <span class="text-blue-300">@Summary.AktifUrun aktif ürün</span>
                                        </div>
                                        <div class="flex h-28 items-end gap-2">
                                            @foreach (int height in ChartBars)
                                            {
                                                <span class="flex-1 rounded-t bg-blue-300/80" style="@($"height:{height}%")"></span>
                                            }
                                        </div>
                                    </div>
                                    <div class="grid grid-cols-3 gap-3">
                                        <MiniPanel Label="Sipariş" Value="@Summary.ToplamSiparis.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" />
                                        <MiniPanel Label="Kritik" Value="@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" />
                                        <MiniPanel Label="Personel" Value="@Summary.PersonelSayisi.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" />
                                    </div>
                                </div>
                                <div class="space-y-3">
                                    <div class="rounded-2xl bg-white/[0.06] p-4">
                                        <p class="text-xs font-semibold uppercase text-slate-400">Doluluk</p>
                                        <p class="mt-2 text-3xl font-black text-white">@FillRateText</p>
                                        <div class="mt-4 h-2 overflow-hidden rounded-full bg-white/10">
                                            <div class="h-full rounded-full bg-blue-300" style="@($"width:{FillRatePercent}%")"></div>
                                        </div>
                                    </div>
                                    <div class="rounded-2xl bg-white/[0.06] p-4">
                                        <p class="text-xs font-semibold uppercase text-slate-400">Durum</p>
                                        <p class="mt-2 text-sm font-semibold text-emerald-300">Operasyon aktif</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">@Message</div>
        }

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <DashboardMetric Icon="cart" Label="Açık Siparişler" Value="@OpenOrders.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Hazırlanan ve bekleyen siparişler" Tone="blue" />
            <DashboardMetric Icon="clock" Label="Onay Bekleyenler" Value="@Summary.BekleyenOdemeSayisi.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Kontrol bekleyen akış" Tone="amber" />
            <DashboardMetric Icon="alert" Label="Kritik Stok" Value="@Summary.KritikStok.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Müdahale gerektiren ürünler" Tone="rose" />
            <DashboardMetric Icon="chart" Label="Bu Ay Ciro" Value="@Summary.AylikCiro.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))" Detail="Aylık mağaza performansı" Tone="emerald" />
        </section>

        <section class="grid gap-6 xl:grid-cols-[1fr_380px]">
            <div class="space-y-6">
                <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/70">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-2xl font-black text-slate-950">Son Siparişler</h2>
                            <p class="mt-1 text-sm text-slate-500">Aktif mağazanın güncel sipariş hareketleri.</p>
                        </div>
                        <a href="/orders" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                            Tümünü Gör
                            <AppIcon Name="chevron-right" CssClass="h-4 w-4" />
                        </a>
                    </div>

                    <div class="mt-5 overflow-hidden rounded-2xl border border-slate-100">
                        <div class="hidden grid-cols-[150px_1fr_130px_150px] bg-slate-800 px-4 py-3 text-xs font-bold uppercase tracking-wide text-slate-100 md:grid">
                            <span>Sipariş</span>
                            <span>Ürün</span>
                            <span>Tutar</span>
                            <span>Durum</span>
                        </div>
                        <div class="divide-y divide-slate-100">
                            @foreach (DashboardRecentOrderDto order in RecentOrders.Take(5))
                            {
                                <div class="grid gap-3 px-4 py-4 text-sm transition hover:bg-blue-50/40 md:grid-cols-[150px_1fr_130px_150px] md:items-center">
                                    <div class="flex items-center gap-3 font-bold text-blue-700">
                                        <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700">
                                            <AppIcon Name="package" CssClass="h-5 w-5" />
                                        </span>
                                        SP-@order.SiparisId.ToString("D5", CultureInfo.InvariantCulture)
                                    </div>
                                    <div class="min-w-0">
                                        <p class="truncate font-semibold text-slate-900">@order.UrunAdi</p>
                                        <p class="mt-1 text-xs text-slate-500">@order.OrderType / @order.YetkiliAdi</p>
                                    </div>
                                    <div class="font-bold text-slate-950">@order.ToplamTutar.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</div>
                                    <StatusBadge Text="@order.SiparisDurumu" Tone="@StatusTone(order.SiparisDurumu)" />
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <section class="rounded-[1.5rem] border border-slate-200 bg-[#dde6f0] p-5 shadow-sm shadow-slate-200/70">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h2 class="text-2xl font-black text-slate-950">Hızlı İşlemler</h2>
                            <p class="mt-1 text-sm font-semibold text-[#2d789d]">Operasyon için sık kullanılan adımlar</p>
                        </div>
                        <span class="text-5xl font-black leading-none text-[#2d789d]">*</span>
                    </div>
                    <div class="mt-6 grid gap-4 md:grid-cols-3">
                        <QuickLink Href="/products" Icon="cart" Title="Yeni Sipariş" Description="Ürün seçip sepet oluşturun." />
                        <QuickLink Href="/products" Icon="search" Title="Ürün Ara" Description="Parça, kategori veya açıklama ile arayın." />
                        <QuickLink Href="/stores" Icon="store" Title="Mağaza Değiştir" Description="Bağlı mağazalar arasında geçin." />
                    </div>
                </section>
            </div>

            <aside class="space-y-6">
                <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/70">
                    <div class="mb-4 flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-2xl font-black text-slate-950">Ekibim</h2>
                            <p class="mt-1 text-sm text-slate-500">Mağaza ekibi özeti</p>
                        </div>
                        <StatusBadge Text="@TeamCountText" Tone="slate" />
                    </div>
                    <div class="space-y-3">
                        @foreach (StoreTeamMemberDto member in TeamResponse?.Members.Take(4) ?? Array.Empty<StoreTeamMemberDto>())
                        {
                            <button class="flex w-full items-center gap-3 rounded-2xl border border-slate-100 bg-white p-3 text-left transition hover:border-blue-200 hover:bg-blue-50/40" @onclick="() => SelectMember(member)">
                                <Avatar Member="member" Size="md" />
                                <span class="min-w-0 flex-1">
                                    <span class="block truncate font-semibold text-slate-950">@member.AdSoyad</span>
                                    <span class="mt-0.5 block truncate text-sm text-slate-500">@member.MagazaGorevGorunenAd</span>
                                </span>
                                <StatusBadge Text="@(member.SiparisYetkilisiMi ? "Yetkili" : "Ekip")" Tone="@(member.SiparisYetkilisiMi ? "info" : "slate")" />
                            </button>
                        }
                    </div>
                </section>

                <section class="overflow-hidden rounded-[1.5rem] bg-[#08172a] p-5 text-white shadow-lg shadow-slate-300/60">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h3 class="text-xl font-black">Güvenlik Notu</h3>
                            <p class="mt-3 text-sm leading-6 text-slate-300">Tek aktif Supervisor korunur. Mağaza dışı işlemler API katmanında engellenir.</p>
                        </div>
                        <span class="text-5xl font-black leading-none text-[#2d789d]">*</span>
                    </div>
                </section>
            </aside>
        </section>

        @if (TeamResponse is not null)
        {
            <TeamMemberDrawer StoreId="@TeamResponse.Context.MagazaId"
                              Context="@TeamResponse.Context"
                              Member="@SelectedMember"
                              OnClose="CloseDrawer"
                              OnChanged="LoadTeamAsync" />
        }
    </section>
</AuthGate>

@code {
    private DashboardSummaryDto Summary { get; set; } = new();
    private IReadOnlyList<DashboardRecentOrderDto> RecentOrders { get; set; } = Array.Empty<DashboardRecentOrderDto>();
    private StoreTeamResponseDto? TeamResponse { get; set; }
    private StoreTeamMemberDto? SelectedMember { get; set; }
    private string Message { get; set; } = string.Empty;
    private int OpenOrders => Math.Max(0, Summary.ToplamSiparis - Summary.TeslimEdildiSayisi - Summary.IptalSayisi);
    private string TeamCountText => $"{TeamResponse?.Members.Count ?? 0}";
    private int FillRatePercent => Summary.ToplamUrun <= 0 ? 0 : Math.Clamp((int)Math.Round((double)Summary.AktifUrun / Summary.ToplamUrun * 100), 0, 100);
    private string FillRateText => $"{FillRatePercent}%";
    private static readonly int[] ChartBars = [35, 58, 42, 76, 48, 62, 84, 55, 70, 45, 92, 64];

    protected override async Task OnInitializedAsync()
    {
        StoreState.Changed += OnStoreChanged;
        await StoreState.LoadAsync(StoreApi);
        await LoadDashboardAsync();
        await LoadTeamAsync();
    }

    private async void OnStoreChanged()
    {
        await LoadDashboardAsync();
        await LoadTeamAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            Summary = await DashboardApi.GetSummaryAsync(StoreState.SelectedStoreId);
            RecentOrders = await DashboardApi.GetRecentOrdersAsync(StoreState.SelectedStoreId);
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private async Task LoadTeamAsync()
    {
        if (StoreState.SelectedStoreId is not int storeId)
            return;

        try
        {
            TeamResponse = await TeamApi.GetTeamAsync(storeId);
        }
        catch
        {
            TeamResponse = null;
        }
    }

    private void SelectMember(StoreTeamMemberDto member) => SelectedMember = member;
    private void CloseDrawer() => SelectedMember = null;

    private static string StatusTone(string status)
    {
        return status switch
        {
            "Teslim Edildi" => "success",
            "Hazirlaniyor" => "info",
            "Hazırlanıyor" => "info",
            "Iptal" => "danger",
            "İptal" => "danger",
            _ => "warning"
        };
    }
}
