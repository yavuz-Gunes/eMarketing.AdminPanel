<article class="rounded-[1.35rem] border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/70">
    <div class="flex items-start justify-between gap-4">
        <div>
            <p class="text-sm font-bold uppercase tracking-wide text-slate-500">@Label</p>
            <p class="mt-3 text-3xl font-black text-slate-950">@Value</p>
        </div>
        <span class="@IconClass">
            <AppIcon Name="@Icon" CssClass="h-6 w-6" />
        </span>
    </div>
    <p class="mt-5 text-sm font-medium text-slate-500">@Detail</p>
    <div class="mt-4 h-2 overflow-hidden rounded-full bg-slate-100">
        <div class="@BarClass"></div>
    </div>
</article>

@code {
    [Parameter] public string Icon { get; set; } = "chart";
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Detail { get; set; } = string.Empty;
    [Parameter] public string Tone { get; set; } = "blue";

    private string IconClass => Tone switch
    {
        "amber" => "flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-50 text-amber-600",
        "rose" => "flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-50 text-rose-600",
        "emerald" => "flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600",
        _ => "flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-50 text-blue-600"
    };

    private string BarClass => Tone switch
    {
        "amber" => "h-full w-2/3 rounded-full bg-amber-500",
        "rose" => "h-full w-1/2 rounded-full bg-rose-500",
        "emerald" => "h-full w-4/5 rounded-full bg-emerald-500",
        _ => "h-full w-3/4 rounded-full bg-blue-600"
    };
}
