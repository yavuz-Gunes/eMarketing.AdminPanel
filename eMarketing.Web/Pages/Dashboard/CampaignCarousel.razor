@implements IDisposable
@inject CampaignApiClient CampaignApi
@inject ActiveStoreState StoreState

@if (Campaigns.Count > 0)
{
    <section class="overflow-hidden rounded-[1.35rem] border border-slate-200 bg-white shadow-sm">
        <div class="relative bg-slate-100">
            <a href="@Current.DetailUrl" class="block h-[120px] w-full overflow-hidden sm:h-[190px]" title="Kampanya detayına git">
                @if (!string.IsNullOrWhiteSpace(Current.ImageUrl))
                {
                    <img class="h-full w-full object-cover" src="@Current.ImageUrl" alt="Kampanya görseli" />
                }
                else
                {
                    <div class="flex h-full w-full items-center justify-center bg-slate-100 text-sm font-bold text-slate-400">
                        Kampanya görseli yok
                    </div>
                }
            </a>

            @if (Campaigns.Count > 1)
            {
                <button class="absolute left-4 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/70 bg-white/85 text-slate-800 shadow-sm transition hover:bg-white"
                        type="button"
                        title="Önceki kampanya"
                        @onclick="Previous">
                    <span class="sr-only">Önceki</span>
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
                </button>

                <button class="absolute right-4 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/70 bg-white/85 text-slate-800 shadow-sm transition hover:bg-white"
                        type="button"
                        title="Sonraki kampanya"
                        @onclick="Next">
                    <span class="sr-only">Sonraki</span>
                    <AppIcon Name="chevron-right" CssClass="h-5 w-5" />
                </button>

                <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2">
                    @for (int i = 0; i < Campaigns.Count; i++)
                    {
                        int index = i;
                        <button class="@DotClass(index)"
                                type="button"
                                title="@($"{index + 1}. kampanya")"
                                @onclick="() => GoTo(index)">
                            <span class="sr-only">@($"{index + 1}. kampanya")</span>
                        </button>
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private int _activeIndex;
    private IReadOnlyList<Campaign> Campaigns { get; set; } = Array.Empty<Campaign>();

    private Campaign Current => Campaigns[Math.Clamp(_activeIndex, 0, Campaigns.Count - 1)];

    protected override async Task OnInitializedAsync()
    {
        StoreState.Changed += OnStoreChanged;
        await LoadCampaignsAsync();
        _ = RotateAsync(_cts.Token);
    }

    private async void OnStoreChanged()
    {
        await LoadCampaignsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCampaignsAsync()
    {
        try
        {
            IReadOnlyList<DashboardCampaignDto> campaigns = await CampaignApi.GetActiveCampaignsAsync(StoreState.SelectedStoreId, _cts.Token);
            Campaigns = campaigns
                .OrderBy(campaign => campaign.Oncelik)
                .Select(campaign => new Campaign(
                    NormalizeImageUrl(campaign.GorselUrl),
                    campaign.KampanyaId > 0 ? $"/campaigns/{campaign.KampanyaId}" : "/products"))
                .ToArray();
        }
        catch
        {
            Campaigns = Array.Empty<Campaign>();
        }

        _activeIndex = 0;
    }

    private async Task RotateAsync(CancellationToken cancellationToken)
    {
        using PeriodicTimer timer = new(TimeSpan.FromMilliseconds(4500));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (Campaigns.Count > 1)
                {
                    Next();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void Previous()
    {
        if (Campaigns.Count == 0)
            return;

        _activeIndex = (_activeIndex - 1 + Campaigns.Count) % Campaigns.Count;
    }

    private void Next()
    {
        if (Campaigns.Count == 0)
            return;

        _activeIndex = (_activeIndex + 1) % Campaigns.Count;
    }

    private void GoTo(int index)
    {
        _activeIndex = index;
    }

    private string DotClass(int index)
    {
        return index == _activeIndex
            ? "h-2 w-7 rounded-full bg-white shadow-sm transition"
            : "h-2 w-2 rounded-full bg-white/60 shadow-sm transition hover:bg-white";
    }

    private static string? NormalizeImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return null;

        string normalized = imageUrl.Replace("\\", "/").Trim();
        return normalized.StartsWith("http", StringComparison.OrdinalIgnoreCase) || normalized.StartsWith("/")
            ? normalized
            : "/" + normalized;
    }

    public void Dispose()
    {
        StoreState.Changed -= OnStoreChanged;
        _cts.Cancel();
        _cts.Dispose();
    }

    private sealed record Campaign(string? ImageUrl, string DetailUrl);
}
