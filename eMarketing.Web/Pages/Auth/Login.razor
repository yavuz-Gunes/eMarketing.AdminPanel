@page "/login"
@inject AuthApiClient AuthApi
@inject AuthSession Auth
@inject ActiveStoreState Stores
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Giriş - ParçaPortal</PageTitle>

<section class="login-page min-h-screen overflow-hidden bg-slate-50 text-slate-950">
    <div class="login-shell">
        <div class="relative flex items-center border-r border-slate-200 bg-white px-6 py-8 shadow-2xl shadow-slate-200/60 lg:px-10">
            <div class="w-full max-w-sm">
                <div class="flex items-center gap-3">
                    <div class="relative flex h-12 w-12 items-center justify-center rounded-2xl border border-blue-100 bg-blue-50 text-blue-700 shadow-sm">
                        <AppIcon Name="part-logo" CssClass="h-7 w-7" />
                        <span class="absolute -right-1 -top-1 h-3 w-3 rounded-full border-2 border-white bg-emerald-500"></span>
                    </div>
                    <div>
                        <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-600">Bayi Portalı</p>
                        <div class="mt-1 text-2xl font-black tracking-tight text-slate-950">ParçaPortal</div>
                        <p class="mt-1 text-xs font-bold text-slate-500">Yedek Parça Bayi Portalı</p>
                    </div>
                </div>

                <p class="mt-5 text-sm font-semibold leading-7 text-slate-600">
                    Parça stoku, bayi ekibi ve sipariş akışını tek operasyon panelinden yönetin.
                </p>

                <EditForm Model="Model"
                          OnValidSubmit="LoginAsync"
                          class="mt-7 rounded-2xl border border-slate-200 bg-white p-5 shadow-xl shadow-slate-200/70">
                    <DataAnnotationsValidator />

                    <div class="mb-5 flex items-start justify-between gap-3">
                        <div>
                            <p class="text-base font-black text-slate-950">Giriş</p>
                            <p class="mt-1 text-sm font-semibold text-slate-500">Aktif bayi operasyonuna devam edin.</p>
                        </div>
                        <span class="shrink-0 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">Güvenli</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-bold text-rose-700">@Message</div>
                    }

                    <div class="space-y-4">
                        <label class="block space-y-2 text-sm font-black text-slate-700">
                            <span>Kullanıcı adı</span>
                            <input class="h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm font-semibold text-slate-950 outline-none transition focus:border-blue-300 focus:bg-white focus:ring-4 focus:ring-blue-100"
                                   value="@Model.KullaniciAdi"
                                   @oninput="args => Model.KullaniciAdi = args.Value?.ToString() ?? string.Empty"
                                   autocomplete="username" />
                        </label>

                        <label class="block space-y-2 text-sm font-black text-slate-700">
                            <span>Şifre</span>
                            <input type="password"
                                   class="h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm font-semibold text-slate-950 outline-none transition focus:border-blue-300 focus:bg-white focus:ring-4 focus:ring-blue-100"
                                   value="@Model.Sifre"
                                   @oninput="args => Model.Sifre = args.Value?.ToString() ?? string.Empty"
                                   autocomplete="current-password" />
                        </label>

                        <ValidationSummary class="text-sm font-bold text-rose-600" />

                        <button class="flex h-11 w-full items-center justify-center rounded-xl bg-blue-600 px-4 text-sm font-black text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-slate-300"
                                disabled="@Busy">
                            @(Busy ? "Giriş yapılıyor..." : "Giriş yap")
                        </button>
                    </div>
                </EditForm>

                <div class="mt-5 grid grid-cols-3 gap-2 text-xs font-black text-slate-600">
                    <span class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">Filtre</span>
                    <span class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">Fren</span>
                    <span class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">Motor</span>
                </div>
            </div>
        </div>

        <div class="login-hero relative overflow-hidden bg-slate-100">
            <div class="absolute inset-0"
                 style="background:
                    linear-gradient(90deg, rgba(255,255,255,.92) 0%, rgba(248,250,252,.78) 42%, rgba(226,232,240,.58) 100%),
                    linear-gradient(rgba(37,99,235,.08) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(37,99,235,.08) 1px, transparent 1px);
                    background-size: auto, 44px 44px, 44px 44px;"></div>

            <div class="absolute inset-y-0 right-0 z-0 w-[62%] origin-top-right scale-90 opacity-90 lg:w-[56%] lg:scale-90 lg:opacity-95">
                <div class="absolute left-28 right-6 top-6 h-20 rounded-lg border border-slate-200 bg-white/80 shadow-xl shadow-slate-300/40"></div>
                <div class="absolute left-36 right-10 top-24 h-20 rounded-lg border border-slate-200 bg-white/70 shadow-xl shadow-slate-300/30"></div>
                <div class="absolute left-24 right-0 top-40 h-20 rounded-lg border border-slate-200 bg-white/75 shadow-xl shadow-slate-300/30"></div>

                <div class="absolute right-20 top-10 grid grid-cols-4 gap-3">
                    @foreach (string color in ShelfColors)
                    {
                        <span class="h-14 w-12 rounded-md border border-slate-200 shadow-sm" style="@color"></span>
                    }
                </div>

                <div class="absolute right-12 top-28 grid grid-cols-5 gap-3">
                    @foreach (string color in ShelfColorsAlt)
                    {
                        <span class="h-12 w-11 rounded-md border border-slate-200 shadow-sm" style="@color"></span>
                    }
                </div>

                <div class="absolute right-10 top-48 flex items-end gap-4">
                    <div class="relative h-28 w-20 rounded-xl border border-slate-300 bg-slate-300 shadow-lg shadow-slate-400/30">
                        <div class="absolute left-1/2 top-4 h-4 w-10 -translate-x-1/2 rounded bg-slate-400/50"></div>
                        <div class="absolute bottom-4 left-1/2 h-10 w-10 -translate-x-1/2 rounded-full border-[6px] border-slate-500/45 bg-white/50"></div>
                    </div>
                    <div class="h-32 w-12 rounded-full border border-amber-300 shadow-lg shadow-amber-200/40"
                         style="background: repeating-linear-gradient(180deg, #f59e0b, #f59e0b 5px, #92400e 5px, #92400e 10px);"></div>
                    <div class="relative h-24 w-24 rounded-full border-[14px] border-slate-400 bg-white shadow-lg shadow-slate-400/30">
                        <div class="absolute left-1/2 top-1/2 h-7 w-7 -translate-x-1/2 -translate-y-1/2 rounded-full border-4 border-slate-300 bg-white"></div>
                    </div>
                </div>
            </div>

            <div class="relative z-10 flex h-full items-center px-10 lg:px-14 xl:px-16">
                <div class="max-w-[34rem]">
                    <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-700">Operasyon özeti</p>
                    <h2 class="mt-4 text-4xl font-black leading-tight tracking-tight text-slate-950">
                        Yedek parça stok ve bayi operasyonu tek ekranda.
                    </h2>
                    <p class="mt-5 max-w-md text-base font-semibold leading-7 text-slate-600">
                        Filtre, fren ve motor parçası hareketlerini bayi siparişleriyle birlikte temiz bir operasyon panelinden takip edin.
                    </p>

                    <div class="mt-7 grid max-w-[27rem] grid-cols-3 gap-3">
                        <div class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-lg shadow-slate-300/30">
                            <p class="text-xs font-black uppercase text-slate-400">Parça stoku</p>
                            <p class="mt-2 text-3xl font-black text-slate-950">32</p>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-lg shadow-slate-300/30">
                            <p class="text-xs font-black uppercase text-slate-400">Uyumlu ürün</p>
                            <p class="mt-2 text-3xl font-black text-slate-950">194</p>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-lg shadow-slate-300/30">
                            <p class="text-xs font-black uppercase text-slate-400">Bayi siparişi</p>
                            <p class="mt-2 text-3xl font-black text-slate-950">128</p>
                        </div>
                    </div>

                    <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-black text-emerald-700">
                        <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                        Canlı bayi operasyonu
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private static readonly string[] ShelfColors =
    [
        "background: linear-gradient(180deg, #dbeafe, #93c5fd);",
        "background: linear-gradient(180deg, #dcfce7, #86efac);",
        "background: linear-gradient(180deg, #fef3c7, #fbbf24);",
        "background: linear-gradient(180deg, #e2e8f0, #94a3b8);"
    ];

    private static readonly string[] ShelfColorsAlt =
    [
        "background: linear-gradient(180deg, #e0f2fe, #38bdf8);",
        "background: linear-gradient(180deg, #f1f5f9, #cbd5e1);",
        "background: linear-gradient(180deg, #dcfce7, #4ade80);",
        "background: linear-gradient(180deg, #ffedd5, #fb923c);",
        "background: linear-gradient(180deg, #dbeafe, #60a5fa);"
    ];

    private LoginRequest Model { get; set; } = new();
    private string Message { get; set; } = string.Empty;
    private bool Busy { get; set; }

    protected override void OnInitialized()
    {
        if (Auth.IsAuthenticated)
            Navigation.NavigateTo("/");
    }

    private async Task LoginAsync()
    {
        Busy = true;
        Message = string.Empty;

        try
        {
            await AuthApi.LoginAsync(Model.KullaniciAdi, Model.Sifre);
            await JS.InvokeVoidAsync("eMarketing.auth.save", Auth.ToStoredSession());
            await Stores.ClearAsync();
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }
}
