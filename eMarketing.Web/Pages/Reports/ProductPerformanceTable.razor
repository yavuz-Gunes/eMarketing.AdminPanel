@if (Products.Length == 0)
{
    <EmptyState Text="Bu dönem ürün performansı oluşmadı." />
}
else
{
    <div class="overflow-hidden rounded-xl border border-slate-100">
        <div class="hidden grid-cols-[minmax(220px,1fr)_110px_130px_120px] bg-slate-50 px-4 py-3 text-xs font-black uppercase tracking-wide text-slate-500 md:grid">
            <span>Ürün</span>
            <span>Satış</span>
            <span>Ciro</span>
            <span>Stok</span>
        </div>
        <div class="divide-y divide-slate-100">
            @foreach (ReportProductPerformanceDto product in Products)
            {
                <a href="@($"/products?urunId={product.UrunId}")" class="@RowClass(product)">
                    <div class="min-w-0">
                        <p class="truncate text-sm font-black text-slate-950">@DisplayTextNormalizer.Normalize(product.UrunAdi)</p>
                        <p class="mt-1 truncate text-xs font-bold text-slate-500">@DisplayTextNormalizer.Normalize(product.KategoriAdi)</p>
                    </div>
                    <div class="text-sm font-black text-slate-900">@product.SatisAdedi.ToString("N0", Tr)</div>
                    <div class="text-sm font-black text-blue-700">@product.ToplamTutar.ToString("C", Tr)</div>
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="@StockTextClass(product)">@product.BayiStok.ToString("N0", Tr)</span>
                        @if (product.KritikMi)
                        {
                            <span class="rounded-full bg-rose-50 px-2 py-1 text-[11px] font-black text-rose-700">Kritik</span>
                        }
                        @if (product.PasifMi)
                        {
                            <span class="rounded-full bg-slate-100 px-2 py-1 text-[11px] font-black text-slate-700">Pasif</span>
                        }
                    </div>
                </a>
            }
        </div>
    </div>
}

@code {
    private static readonly CultureInfo Tr = CultureInfo.GetCultureInfo("tr-TR");

    [Parameter] public ReportProductPerformanceDto[] Products { get; set; } = [];

    private static string RowClass(ReportProductPerformanceDto product)
    {
        string risk = product.KritikMi ? "border-l-rose-300 bg-rose-50/30" : "border-l-transparent bg-white";
        return $"grid gap-3 border-l-4 px-4 py-3 transition hover:bg-blue-50/40 md:grid-cols-[minmax(220px,1fr)_110px_130px_120px] md:items-center {risk}";
    }

    private static string StockTextClass(ReportProductPerformanceDto product) =>
        product.BayiStok <= 0
            ? "text-sm font-black text-rose-600"
            : product.KritikMi
                ? "text-sm font-black text-amber-600"
                : "text-sm font-black text-emerald-600";
}
