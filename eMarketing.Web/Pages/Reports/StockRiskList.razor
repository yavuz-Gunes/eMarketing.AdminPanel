@if (Risks.Length == 0)
{
    <EmptyState Text="Öncelikli stok riski yok." />
}
else
{
    <div class="space-y-3">
        @foreach (ReportStockRiskDto risk in Risks)
        {
            <a href="@($"/products?urunId={risk.UrunId}")" class="@RiskRowClass(risk)">
                <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                        <p class="truncate text-sm font-black text-slate-950">@DisplayTextNormalizer.Normalize(risk.UrunAdi)</p>
                        <span class="@RiskBadgeClass(risk)">@DisplayTextNormalizer.Normalize(risk.Durum)</span>
                    </div>
                    <p class="mt-1 truncate text-xs font-bold text-slate-500">@DisplayTextNormalizer.Normalize(risk.KategoriAdi)</p>
                </div>
                <div class="mt-3 grid grid-cols-3 gap-2 text-xs font-bold text-slate-500">
                    <span>Bayi <b class="@QuantityClass(risk.BayiStok)">@risk.BayiStok.ToString("N0", Tr)</b></span>
                    <span>Merkez <b class="text-slate-900">@risk.MerkezStok.ToString("N0", Tr)</b></span>
                    <span>Min <b class="text-slate-900">@risk.MinimumStok.ToString("N0", Tr)</b></span>
                </div>
            </a>
        }
    </div>
}

@code {
    private static readonly CultureInfo Tr = CultureInfo.GetCultureInfo("tr-TR");

    [Parameter] public ReportStockRiskDto[] Risks { get; set; } = [];

    private static string RiskRowClass(ReportStockRiskDto risk) => risk.Durum switch
    {
        "Stok yok" => "block rounded-xl border border-rose-200 bg-rose-50 p-3 transition hover:bg-rose-100/60",
        "Kritik" => "block rounded-xl border border-amber-200 bg-amber-50 p-3 transition hover:bg-amber-100/60",
        "Pasif" => "block rounded-xl border border-slate-200 bg-slate-50 p-3 transition hover:bg-slate-100",
        _ => "block rounded-xl border border-slate-100 bg-white p-3 transition hover:bg-blue-50/40"
    };

    private static string RiskBadgeClass(ReportStockRiskDto risk) => risk.Durum switch
    {
        "Stok yok" => "rounded-full bg-white px-2 py-1 text-[11px] font-black text-rose-700",
        "Kritik" => "rounded-full bg-white px-2 py-1 text-[11px] font-black text-amber-700",
        "Pasif" => "rounded-full bg-white px-2 py-1 text-[11px] font-black text-slate-700",
        _ => "rounded-full bg-blue-50 px-2 py-1 text-[11px] font-black text-blue-700"
    };

    private static string QuantityClass(int quantity) =>
        quantity <= 0 ? "text-rose-700" : quantity <= 5 ? "text-amber-700" : "text-emerald-700";
}
