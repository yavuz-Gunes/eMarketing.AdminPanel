    private static int MetricWidth(ReportMetricDto metric)
    {
        decimal value = Math.Abs(metric.Value);
        if (value <= 0)
            return 18;

        return (int)Math.Clamp(34 + Math.Min(value, 100) / 100 * 56, 24, 92);
    }

    private int CategoryWidth(ReportCategoryPerformanceDto category)
    {
        decimal max = Report?.Categories.Select(x => x.ToplamTutar).DefaultIfEmpty(0).Max() ?? 0;
        if (max <= 0)
            return 12;

        return (int)Math.Clamp(category.ToplamTutar / max * 100, 12, 100);
    }

    private int ProductWidth(ReportProductPerformanceDto product)
    {
        decimal max = TopProducts.Select(x => x.ToplamTutar).DefaultIfEmpty(0).Max();
        if (max <= 0)
            return 12;

        return (int)Math.Clamp(product.ToplamTutar / max * 100, 12, 100);
    }

