                    <div class="flex items-center gap-2 text-xs font-black">
                        <button class="rounded-lg border border-slate-200 px-3 py-2 text-blue-700 hover:bg-blue-50" @onclick="() => EditCategory(category)">Düzenle</button>
                        <button class="@CategoryStatusButtonClass(category)" @onclick="() => ToggleCategoryStatusAsync(category)">@(category.AktifMi ? "Pasife al" : "Aktif yap")</button>
