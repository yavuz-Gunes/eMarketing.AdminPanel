    private RenderFragment MovementsModalContent() => @<div class="p-5">
        <div class="mb-4 grid gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4 sm:grid-cols-[1fr_auto] sm:items-center">
            <div>
                <p class="text-xs font-black uppercase text-slate-500">Ürün</p>
                <h3 class="mt-1 text-lg font-black text-slate-950">@SelectedProduct?.UrunAdi</h3>
                <p class="mt-1 text-sm font-semibold text-slate-500">@((StoreState.SelectedStore?.MagazaAdi ?? "Aktif bayi") + " ve merkez stok hareketleri")</p>
            </div>
            @if (SelectedProduct is not null)
            {
                StockItemDto stock = GetDisplayStock(SelectedProduct);
                <div class="grid grid-cols-2 gap-2 text-center text-xs font-black">
                    <span class="rounded-lg bg-white px-3 py-2 text-slate-600 ring-1 ring-slate-200">
                        <span class="block text-[10px] uppercase text-slate-400">Bu bayi</span>
                        <span class="@StockTextClass(stock.BayiStok)">@stock.BayiStok</span>
                    </span>
                    <span class="rounded-lg bg-white px-3 py-2 text-slate-600 ring-1 ring-slate-200">
                        <span class="block text-[10px] uppercase text-slate-400">Merkez</span>
                        <span class="text-slate-950">@stock.MerkezStok</span>
                    </span>
                </div>
            }
        </div>

        <div class="mb-4 flex flex-wrap gap-2 rounded-lg border border-slate-200 bg-white p-1">
            <button class="@MovementTabClass(MovementViewMode.Store)" @onclick="() => CurrentMovementView = MovementViewMode.Store">Bayi hareketleri</button>
            <button class="@MovementTabClass(MovementViewMode.Central)" @onclick="() => CurrentMovementView = MovementViewMode.Central">Merkez hareketleri</button>
        </div>

        @if (IsMovementsLoading)
        {
            <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm font-bold text-slate-500">Stok hareketleri yükleniyor...</div>
        }
        else if (CurrentMovementView == MovementViewMode.Store && !StoreState.SelectedStoreId.HasValue)
        {
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm font-bold text-amber-800">Bayi hareketleri için aktif bayi seçin.</div>
        }
        else if (!CurrentMovementItems.Any())
        {
            <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm font-bold text-slate-500">Bu ürün için hareket bulunamadı.</div>
        }
        else
        {
            <div class="overflow-hidden rounded-lg border border-slate-200">
                @foreach (StockMovementDto movement in CurrentMovementItems)
                {
                    <div class="grid gap-3 border-b border-slate-100 p-3 text-sm transition last:border-b-0 hover:bg-blue-50/40 md:grid-cols-[1fr_.8fr_.6fr_.8fr]">
                        <div>
                            <p class="font-black text-slate-950">@MovementTitle(movement)</p>
                            <p class="text-xs font-semibold text-slate-500">@MovementDescription(movement)</p>
                        </div>
                        <p class="font-bold text-slate-600">@movement.OlusturmaTarihi?.ToString("dd.MM.yyyy HH:mm", TrCulture)</p>
                        <p><span class="@MovementQuantityClass(movement)">@MovementQuantityText(movement)</span></p>
                        <p class="font-bold text-slate-600">@MovementReferenceText(movement)</p>
                    </div>
                }
            </div>
        }
    </div>;

    private IReadOnlyList<StockMovementDto> CurrentMovementItems =>
        CurrentMovementView == MovementViewMode.Central ? SelectedCentralMovements : SelectedMovements;

    private string MovementTabClass(MovementViewMode mode)
    {
        return CurrentMovementView == mode
            ? "rounded-md bg-slate-950 px-4 py-2 text-xs font-black text-white shadow-sm"
            : "rounded-md px-4 py-2 text-xs font-black text-slate-600 transition hover:bg-slate-100";
    }

    private static string MovementTitle(StockMovementDto movement)
    {
        return movement.HareketTipi switch
        {
            "SiparisTeslimGiris" => "Sipariş teslim girişi",
            "ManuelGiris" => "Manuel stok girişi",
            "ManuelCikis" => "Manuel stok çıkışı",
            "MerkezGiris" => "Merkez stok girişi",
            "SiparisIptalCikis" => "Sipariş iptal/iade çıkışı",
            "BayiSatisCikis" => "Bayi satış çıkışı",
            "DuzeltmeGiris" => "Düzeltme girişi",
            "DuzeltmeCikis" => "Düzeltme çıkışı",
            "OrderOut" => "Sipariş merkez çıkışı",
            "OrderCancelIn" => "Sipariş iptal/iade girişi",
            "DeliveredOrderCancelReturn" => "Teslim iptal/iade girişi",
            _ => string.IsNullOrWhiteSpace(movement.HareketAciklama)
                ? CleanMovementText(movement.HareketTipi)
                : CleanMovementText(movement.HareketAciklama)
        };
    }

    private static string MovementDescription(StockMovementDto movement)
    {
        if (!string.IsNullOrWhiteSpace(movement.Aciklama))
            return CleanMovementText(movement.Aciklama);

        return string.IsNullOrWhiteSpace(movement.SiparisNo) ? "Manuel stok hareketi" : $"Sipariş: {movement.SiparisNo}";
    }

    private static string MovementQuantityText(StockMovementDto movement)
    {
        string prefix = IsOutgoingMovement(movement) ? "-" : "+";
        return $"{prefix}{movement.Miktar} adet";
    }

    private static string MovementQuantityClass(StockMovementDto movement)
    {
        return IsOutgoingMovement(movement)
            ? "inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700 ring-1 ring-rose-100"
            : "inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700 ring-1 ring-emerald-100";
    }

    private static string MovementReferenceText(StockMovementDto movement)
    {
        if (movement.MagazaId <= 0 && movement.OncekiStok == 0 && movement.SonrakiStok == 0)
            return string.IsNullOrWhiteSpace(movement.SiparisNo) ? "Merkez stok kaydı" : $"Sipariş: {movement.SiparisNo}";

        return $"Önceki: {movement.OncekiStok} · Son: {movement.SonrakiStok}";
    }

    private static bool IsOutgoingMovement(StockMovementDto movement)
    {
        if (movement.HareketTipi is "BayiSatisCikis" or "ManuelCikis" or "DuzeltmeCikis" or "SiparisIptalCikis" or "OrderOut" or "SiparisOlusturma" or "MerkezCikis")
            return true;

        string direction = CleanMovementText(movement.HareketYonu);
        return direction.Contains("Cikis", StringComparison.OrdinalIgnoreCase)
            || direction.Contains("Çıkış", StringComparison.OrdinalIgnoreCase)
            || direction.Contains("çıkış", StringComparison.OrdinalIgnoreCase);
    }

    private static string CleanMovementText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        return value
            .Replace("Ãœ", "Ü", StringComparison.Ordinal)
            .Replace("Ã–", "Ö", StringComparison.Ordinal)
            .Replace("Ã‡", "Ç", StringComparison.Ordinal)
            .Replace("Ã¼", "ü", StringComparison.Ordinal)
            .Replace("Ã¶", "ö", StringComparison.Ordinal)
            .Replace("Ã§", "ç", StringComparison.Ordinal)
            .Replace("Ä±", "ı", StringComparison.Ordinal)
            .Replace("Ä°", "İ", StringComparison.Ordinal)
            .Replace("ÄŸ", "ğ", StringComparison.Ordinal)
            .Replace("Äž", "Ğ", StringComparison.Ordinal)
            .Replace("ÅŸ", "ş", StringComparison.Ordinal)
            .Replace("Åž", "Ş", StringComparison.Ordinal);
    }

    private enum ProductViewMode
    {
        Cards,
        Table
    }

    private enum MovementViewMode
    {
        Store,
        Central
    }

    private enum StockFilterMode
    {
        All,
        InStock,
        OutOfStock,
        Critical
    }

    private enum CatalogModalMode
    {
        None,
        Product,
        Categories,
        Transfer,
        CentralStock,
        Movements
    }

    private sealed class ProductCropInfo
    {
        public string DataUrl { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
    }

    private sealed record SavedProductImage(string Url, string FullPath);
}
