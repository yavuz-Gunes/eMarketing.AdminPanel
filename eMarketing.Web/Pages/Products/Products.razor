                <span class="text-xs font-black uppercase text-slate-500">Kategori adı</span>
                <input class="mt-1 h-11 w-full rounded-lg border border-slate-200 bg-white px-4 text-sm font-semibold outline-none focus:border-blue-300 focus:ring-4 focus:ring-blue-100" @bind="CategoryForm.KategoriAdi" />
            </label>
            <label class="mt-3 flex items-center justify-between text-sm font-black text-slate-700">
