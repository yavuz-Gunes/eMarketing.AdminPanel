    private StockItemDto? GetStock(int productId)
    {
        return StockByProductId.TryGetValue(productId, out StockItemDto? stock) ? stock : null;
    }

    private StockItemDto GetDisplayStock(ProductDto product)
    {
        return GetStock(product.UrunId) ?? new StockItemDto
        {
            UrunId = product.UrunId,
            UrunAdi = product.UrunAdi,
            Aciklama = product.Aciklama,
            Fiyat = product.Fiyat,
            KategoriId = product.KategoriId,
            KategoriAdi = product.KategoriAdi,
            GorselUrl = product.GorselUrl,
            MerkezStok = product.Stok,
            BayiStok = 0,
            StokDurumu = "Stok Yok",
            AktifMi = product.AktifMi,
            OlusturmaTarihi = product.OlusturmaTarihi
        };
    }

    private bool MatchesStockFilter(ProductDto product)
    {
        StockItemDto stock = GetDisplayStock(product);
        return CurrentStockFilter switch
        {
            StockFilterMode.InStock => product.AktifMi && stock.BayiStok > 0,
            StockFilterMode.OutOfStock => product.AktifMi && stock.BayiStok <= 0,
            StockFilterMode.Critical => product.AktifMi && IsCriticalStock(stock),
            _ => true
        };
    }

    private static bool IsCriticalStock(StockItemDto stock)
    {
        if (!string.IsNullOrWhiteSpace(stock.StokDurumu) &&
            stock.StokDurumu.Contains("kritik", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return stock.BayiStok > 0 && (stock.MinimumStok > 0 ? stock.BayiStok <= stock.MinimumStok : stock.BayiStok <= 5);
    }

    private static string ProductTableRowClass(ProductDto product, StockItemDto stock)
    {
        string baseClass = "grid grid-cols-[1.45fr_.75fr_.65fr_.55fr_.55fr_.7fr_1.85fr] items-center border-b border-l-4 px-4 py-3 text-sm transition last:border-b-0 hover:shadow-md";
        return product.AktifMi && IsCriticalStock(stock)
            ? $"{baseClass} border-rose-100 border-l-rose-400 bg-rose-50/35 hover:border-rose-200 hover:bg-rose-50/70"
            : $"{baseClass} border-l-transparent border-slate-100 hover:border-blue-200 hover:bg-blue-50/50";
    }

    private void AddToCart(ProductDto product)
    {
        if (!StoreState.SelectedStoreId.HasValue || product.Stok <= 0 || !product.AktifMi)
            return;

        Cart.Add(product);
        IsError = false;
        Message = $"{product.UrunAdi} sepete eklendi.";
    }

