@page "/products"
@inject ProductApiClient ProductsApi
@inject CartState Cart
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi

<PageTitle>Ürünler - eMarketing</PageTitle>

<AuthGate>
    <section class="space-y-6 px-4 py-6 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <p class="text-sm font-bold uppercase text-slate-500">Ürünler</p>
                <h1 class="mt-1 text-3xl font-bold tracking-normal text-slate-950">Ürün kataloğu</h1>
                <p class="mt-1 text-sm text-slate-500">Aktif mağaza: @(StoreState.SelectedStore?.MagazaAdi ?? "-")</p>
            </div>
            <a href="/cart" class="rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm shadow-blue-200 hover:bg-blue-700">Sepet (@Cart.Count)</a>
        </div>

        <div class="grid gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/60 lg:grid-cols-[1fr_auto]">
            <label class="relative block">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-xl text-slate-400">⌕</span>
                <input class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 pl-12 pr-4 outline-none focus:border-blue-300 focus:bg-white focus:ring-4 focus:ring-blue-100"
                       @bind="Search"
                       @bind:event="oninput"
                       placeholder="Ürün, kategori veya açıklama ara" />
            </label>
            <button class="rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50" @onclick="LoadProductsAsync">Yenile</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700">@Message</div>
        }

        <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
            @foreach (ProductDto product in FilteredProducts)
            {
                <ProductCard Product="product" OnAdd="AddToCart" />
            }
        </div>
    </section>
</AuthGate>

@code {
    [SupplyParameterFromQuery(Name = "kategoriId")]
    public int? CategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "urunId")]
    public int? ProductId { get; set; }

    private IReadOnlyList<ProductDto> ProductList { get; set; } = Array.Empty<ProductDto>();
    private string Search { get; set; } = string.Empty;
    private string Message { get; set; } = string.Empty;

    private IEnumerable<ProductDto> FilteredProducts => ProductList.Where(product =>
        (!ProductId.HasValue || product.UrunId == ProductId.Value)
        && (string.IsNullOrWhiteSpace(Search)
            || $"{product.UrunAdi} {product.KategoriAdi} {product.Aciklama}".Contains(Search, StringComparison.CurrentCultureIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await StoreState.LoadAsync(StoreApi);
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        ProductList = await ProductsApi.GetProductsAsync(categoryId: CategoryId.GetValueOrDefault());
    }

    private void AddToCart(ProductDto product)
    {
        Cart.Add(product);
        Message = $"{product.UrunAdi} sepete eklendi.";
    }
}
