                <button class="rounded-lg bg-slate-950 px-4 py-2 text-xs font-black text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300" disabled="@IsSaving" @onclick="SaveCategoryAsync">
