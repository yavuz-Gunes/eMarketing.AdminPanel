@page "/products"
@implements IDisposable
@inject ProductApiClient ProductsApi
@inject CartState Cart
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject StockApiClient StockApi
@inject AuthSession Auth
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject NavigationManager Navigation

<PageTitle>Ürünler - eMarketing</PageTitle>

<AuthGate>
    <section class="space-y-5 px-4 py-5 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <p class="text-sm font-bold uppercase text-slate-500">Ürünler</p>
                <h1 class="mt-1 text-3xl font-black tracking-normal text-slate-950">Ürün kataloğu</h1>
                <p class="mt-1 text-sm font-semibold text-slate-500">Tüm ürünler görünür; stok ve sepete ekleme aktif bayiye göre çalışır.</p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
                @if (Auth.CanManageProducts)
                {
                    <button class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700"
                            @onclick="OpenCategoriesModal">
                        Kategoriler
                    </button>
                    <button class="rounded-lg bg-blue-600 px-5 py-3 text-sm font-black text-white shadow-sm shadow-blue-200 transition hover:bg-blue-700"
                            @onclick="OpenNewProductModal">
                        Yeni Ürün
                    </button>
                }
                <a href="/cart" class="rounded-lg bg-slate-950 px-5 py-3 text-sm font-black text-white shadow-sm transition hover:bg-slate-800">Sepet (@Cart.Count)</a>
            </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
            <button class="@MetricCardClass(StockFilterMode.All)" type="button" @onclick="() => SetStockFilter(StockFilterMode.All)">
                <span class="rounded-lg bg-blue-50 p-3 text-blue-700"><AppIcon Name="package" CssClass="h-5 w-5" /></span>
                <span>
                    <span class="block text-xs font-black uppercase text-slate-500">Tüm ürünler</span>
                    <span class="mt-1 block text-2xl font-black text-slate-950">@ProductList.Count</span>
                </span>
            </button>

            <button class="@MetricCardClass(StockFilterMode.InStock)" type="button" @onclick="() => SetStockFilter(StockFilterMode.InStock)">
                <span class="rounded-lg bg-emerald-50 p-3 text-emerald-700"><AppIcon Name="check-circle" CssClass="h-5 w-5" /></span>
                <span>
                    <span class="block text-xs font-black uppercase text-slate-500">Stokta var</span>
                    <span class="mt-1 block text-2xl font-black text-slate-950">@InStockCount</span>
                </span>
            </button>

            <button class="@MetricCardClass(StockFilterMode.Critical)" type="button" @onclick="() => SetStockFilter(StockFilterMode.Critical)">
                <span class="rounded-lg bg-amber-50 p-3 text-amber-700"><AppIcon Name="alert" CssClass="h-5 w-5" /></span>
                <span>
                    <span class="block text-xs font-black uppercase text-slate-500">Kritik stok</span>
                    <span class="mt-1 block text-2xl font-black text-slate-950">@CriticalStockCount</span>
                </span>
            </button>

            <button class="@MetricCardClass(StockFilterMode.OutOfStock)" type="button" @onclick="() => SetStockFilter(StockFilterMode.OutOfStock)">
                <span class="rounded-lg bg-rose-50 p-3 text-rose-700"><AppIcon Name="x" CssClass="h-5 w-5" /></span>
                <span>
                    <span class="block text-xs font-black uppercase text-slate-500">Stok yok</span>
                    <span class="mt-1 block text-2xl font-black text-slate-950">@OutOfStockCount</span>
                </span>
            </button>

            @if (Auth.CanManageProducts)
            {
                <button class="@StatusMetricCardClass()" type="button" @onclick="TogglePassiveFilterAsync">
                    <span class="rounded-lg bg-slate-100 p-3 text-slate-700"><AppIcon Name="sliders" CssClass="h-5 w-5" /></span>
                    <span>
                        <span class="block text-xs font-black uppercase text-slate-500">Pasif ürün</span>
                        <span class="mt-1 block text-2xl font-black text-slate-950">@PassiveCount</span>
                    </span>
                </button>
            }
        </div>

        <div class="grid gap-3 rounded-xl border border-slate-200 bg-white p-3 shadow-sm shadow-slate-200/60 xl:grid-cols-[1fr_auto_auto_auto]">
            <label class="relative block">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <AppIcon Name="search" CssClass="h-5 w-5" />
                </span>
                <input class="h-12 w-full rounded-lg border border-slate-200 bg-slate-50 pl-12 pr-4 outline-none transition placeholder:text-slate-400 focus:border-blue-300 focus:bg-white focus:ring-4 focus:ring-blue-100"
                       @bind="Search"
                       @bind:event="oninput"
                       placeholder="Ürün, kategori veya açıklama ara" />
            </label>

            @if (Auth.CanManageProducts)
            {
                <select class="h-12 rounded-lg border border-slate-200 bg-white px-4 text-sm font-black text-slate-700 outline-none focus:border-blue-300 focus:ring-4 focus:ring-blue-100"
                        @bind="ProductStatusFilter">
                    <option value="-1">Tüm durumlar</option>
                    <option value="1">Aktif</option>
                    <option value="0">Pasif</option>
                </select>

                <div class="grid grid-cols-2 rounded-lg border border-slate-200 bg-slate-50 p-1">
                    <button class="@ViewButtonClass(ProductViewMode.Cards)" @onclick="() => SetViewModeAsync(ProductViewMode.Cards)">Kart</button>
                    <button class="@ViewButtonClass(ProductViewMode.Table)" @onclick="() => SetViewModeAsync(ProductViewMode.Table)">Tablo</button>
                </div>
            }

            <button class="rounded-lg border border-slate-200 px-4 py-3 text-sm font-bold text-slate-500 transition hover:bg-slate-50 hover:text-slate-700" @onclick="RefreshAsync">Yenile</button>
        </div>

        @if (Categories.Any())
        {
            <div class="flex gap-2 overflow-x-auto pb-1">
                <button class="@CategoryChipClass(null)" @onclick="() => SelectCategory(null)">Tüm kategoriler</button>
                @foreach (CategoryDto category in Categories.Where(category => category.AktifMi))
                {
                    <button class="@CategoryChipClass(category.KategoriId)" @onclick="() => SelectCategory(category.KategoriId)">
                        @category.KategoriAdi
                    </button>
                }
            </div>
        }

        @if (!StoreState.SelectedStoreId.HasValue)
        {
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm font-semibold text-amber-800">
                Lütfen aktif bayi seçin. Ürünler listelenir; sepete ekleme seçili bayi stoklarına göre çalışır.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="@MessageClass">@Message</div>
        }

        @if (IsLoading)
        {
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-sm font-semibold text-slate-500 shadow-sm">Ürünler yükleniyor...</div>
        }
        else if (!FilteredProducts.Any())
        {
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-sm font-semibold text-slate-500 shadow-sm">Ürün bulunamadı.</div>
        }
        else if (CurrentViewMode == ProductViewMode.Table && Auth.CanManageProducts)
        {
            <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
                <div class="min-w-[1120px]">
                    <div class="grid grid-cols-[1.45fr_.75fr_.65fr_.55fr_.55fr_.7fr_1.85fr] border-b border-slate-100 bg-slate-50 px-4 py-3 text-xs font-black uppercase text-slate-500">
                        <span>Ürün</span>
                        <span>Kategori</span>
                        <span>Fiyat</span>
                        <span>Merkez</span>
                        <span>Bu bayi</span>
                        <span>Durum</span>
                        <span class="text-right">İşlemler</span>
                    </div>

                    @foreach (ProductDto product in FilteredProducts)
                    {
                        StockItemDto stock = GetDisplayStock(product);
                        <div class="@ProductTableRowClass(product, stock)">
                            <div class="flex min-w-0 items-center gap-3">
                            @if (!string.IsNullOrWhiteSpace(product.GorselUrl))
                            {
                                <img class="relative z-10 h-12 w-12 rounded-lg object-cover transition duration-200 hover:z-30 hover:scale-175 hover:shadow-xl hover:ring-2 hover:ring-white" src="@NormalizeImage(product.GorselUrl)" alt="@product.UrunAdi" />
                            }
                                else
                                {
                                    <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-slate-100 text-xs font-black text-slate-400">@Initials(product.UrunAdi)</div>
                                }
                                <div class="min-w-0">
                                    <p class="truncate font-black text-slate-950">@product.UrunAdi</p>
                                    <p class="truncate text-xs font-semibold text-slate-500">@product.Aciklama</p>
                                </div>
                            </div>
                            <span class="truncate font-bold text-slate-600">@product.KategoriAdi</span>
                            <span class="font-black text-slate-950">@product.Fiyat.ToString("C", TrCulture)</span>
                            <span class="font-black text-slate-950">@stock.MerkezStok</span>
                            <span class="@StockTextClass(stock.BayiStok)">
                                @stock.BayiStok
                                @if (product.AktifMi && IsCriticalStock(stock))
                                {
                                    <span class="ml-2 rounded-full bg-rose-50 px-2 py-0.5 text-[10px] font-black text-rose-700 ring-1 ring-rose-100">Kritik</span>
                                }
                            </span>
                            <span><span class="@ProductStatusBadgeClass(product)">@ProductStatusText(product)</span></span>
                            <div class="flex justify-end gap-2 text-xs font-black">
                                <button class="rounded-lg bg-blue-600 px-3 py-2 text-white shadow-sm shadow-blue-100 transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none"
                                        disabled="@IsAddToCartDisabled(product, stock)"
                                        @onclick="() => AddToCart(WithSelectedStoreStock(product, stock))">
                                    Sepete ekle
                                </button>
                                <button class="rounded-lg border border-slate-200 px-3 py-2 text-blue-700 hover:bg-blue-50" @onclick="() => OpenEditProductModal(product)">Düzenle</button>
                                <button class="rounded-lg border border-slate-200 px-3 py-2 text-slate-700 hover:bg-slate-50" @onclick="() => OpenCentralStockModal(product)">Merkez</button>
                                @if (stock.MerkezStok > 0)
                                {
                                    <button class="rounded-lg border border-emerald-200 px-3 py-2 text-emerald-700 hover:bg-emerald-50" @onclick="() => OpenTransferModal(stock)">Aktar</button>
                                }
                                <button class="@StatusTableButtonClass(product)" @onclick="() => ToggleProductStatusAsync(product)">@(product.AktifMi ? "Pasife al" : "Aktif yap")</button>
                                <button class="rounded-lg border border-slate-200 px-3 py-2 text-slate-700 hover:bg-slate-50" @onclick="() => OpenMovementsModal(product)">Hareketler</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
                @foreach (ProductDto product in FilteredProducts)
                {
                    StockItemDto stock = GetDisplayStock(product);
                    <ProductCard Product="@WithSelectedStoreStock(product, stock)"
                                 Stock="@stock"
                                 CentralStock="@product.Stok"
                                 IsCritical="@IsCriticalStock(stock)"
                                 ShowAdminStock="@Auth.CanManageProducts"
                                 OnAdd="AddToCart"
                                 OnEdit="OpenEditProductModal"
                                 OnTransfer="OpenTransferModal"
                                 OnToggleStatus="ToggleProductStatusAsync"
                                 OnCentralStock="OpenCentralStockModal"
                                 OnMovements="OpenMovementsModal" />
                }
            </div>
        }
    </section>

    @if (IsModalOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/35 p-4 backdrop-blur-sm"
             tabindex="0"
             @onclick="CloseModal"
             @onkeydown="HandleModalKeyDown">
            <div class="@ModalContainerClass" @onclick:stopPropagation="true">
                <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-5">
                    <div>
                        <p class="text-xs font-black uppercase tracking-wide text-blue-700">Web Admin</p>
                        <h2 class="mt-1 text-2xl font-black text-slate-950">@ModalTitle</h2>
                        <p class="mt-1 text-sm font-semibold text-slate-500">@ModalDescription</p>
                    </div>
                    <button class="rounded-lg border border-slate-200 p-3 text-slate-500 transition hover:bg-slate-50 hover:text-slate-700" @onclick="CloseModal" aria-label="Kapat">
                        <AppIcon Name="x" CssClass="h-5 w-5" />
                    </button>
                </div>

                @switch (ModalMode)
                {
                    case CatalogModalMode.Product:
                        @ProductModalContent()
                        break;
                    case CatalogModalMode.Categories:
                        @CategoriesModalContent()
                        break;
                    case CatalogModalMode.Transfer:
                        @TransferModalContent()
                        break;
                    case CatalogModalMode.CentralStock:
                        @CentralStockModalContent()
                        break;
                    case CatalogModalMode.Movements:
                        @MovementsModalContent()
                        break;
                }
            </div>
        </div>
    }
</AuthGate>

@code {
    [SupplyParameterFromQuery(Name = "kategoriId")]
    public int? CategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "urunId")]
    public int? ProductId { get; set; }

    [SupplyParameterFromQuery(Name = "stok")]
    public string? StockQuery { get; set; }

    private static readonly CultureInfo TrCulture = CultureInfo.GetCultureInfo("tr-TR");
    private const string ViewStorageKey = "emarketing.products.view";
    private const long MaxProductImageBytes = 5 * 1024 * 1024;
    private const string ProductImageInputId = "productImageInput";
    private const string ProductCropImageId = "productCropImage";
    private const string ProductCropPreviewSelector = ".product-crop-preview";
    private static readonly HashSet<string> AllowedProductImageExtensions = new(StringComparer.OrdinalIgnoreCase) { ".jpg", ".jpeg", ".png", ".webp" };

    private IReadOnlyList<ProductDto> ProductList { get; set; } = Array.Empty<ProductDto>();
    private IReadOnlyList<CategoryDto> Categories { get; set; } = Array.Empty<CategoryDto>();
    private IReadOnlyList<StockMovementDto> SelectedMovements { get; set; } = Array.Empty<StockMovementDto>();
    private IReadOnlyList<StockMovementDto> SelectedCentralMovements { get; set; } = Array.Empty<StockMovementDto>();
    private IReadOnlyDictionary<int, StockItemDto> StockByProductId { get; set; } = new Dictionary<int, StockItemDto>();
    private ProductSaveRequest ProductForm { get; set; } = new();
    private CategorySaveRequest CategoryForm { get; set; } = new();
    private ProductDto? SelectedProduct { get; set; }
    private StockItemDto? TransferTarget { get; set; }
    private IBrowserFile? SelectedProductImage { get; set; }
    private int? EditingProductId { get; set; }
    private int? EditingCategoryId { get; set; }
    private int ProductStatusFilter { get; set; } = -1;
    private ProductViewMode CurrentViewMode { get; set; } = ProductViewMode.Cards;
    private MovementViewMode CurrentMovementView { get; set; } = MovementViewMode.Store;
    private StockFilterMode CurrentStockFilter { get; set; } = StockFilterMode.All;
    private CatalogModalMode ModalMode { get; set; } = CatalogModalMode.None;
    private string Search { get; set; } = string.Empty;
    private string Message { get; set; } = string.Empty;
    private string TransferNote { get; set; } = string.Empty;
    private string CentralStockNote { get; set; } = string.Empty;
    private string ProductImagePreviewUrl { get; set; } = string.Empty;
    private string SelectedProductImageName { get; set; } = string.Empty;
    private int TransferQuantity { get; set; } = 1;
    private int CentralStockQuantity { get; set; } = 1;
    private bool IsError { get; set; }
    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private bool ImagePreviewFailed { get; set; }
    private bool IsProductCropperVisible { get; set; }
    private bool IsMovementsLoading { get; set; }
    private string LastQuerySignature { get; set; } = string.Empty;

    private bool IsModalOpen => ModalMode != CatalogModalMode.None && Auth.CanManageProducts;
    private bool IsTransferInvalid => TransferTarget is null || TransferQuantity <= 0 || TransferQuantity > TransferTarget.MerkezStok;
    private bool IsCentralStockInvalid => SelectedProduct is null || CentralStockQuantity <= 0;
    private int EffectiveProductStatus => Auth.CanManageProducts ? -1 : 1;
    private string ModalTitle => ModalMode switch
    {
        CatalogModalMode.Product => EditingProductId.HasValue ? "Ürün düzenle" : "Yeni Ürün",
        CatalogModalMode.Categories => "Kategoriler",
        CatalogModalMode.Transfer => "Merkezden aktar",
        CatalogModalMode.CentralStock => "Merkez stok ekle",
        CatalogModalMode.Movements => "Stok hareketleri",
        _ => string.Empty
    };
    private string ModalDescription => ModalMode switch
    {
        CatalogModalMode.Product => "Merkez katalog bilgisini yönetin; bayi stoğu transfer ile dağıtılır.",
        CatalogModalMode.Categories => "Kategori ekleyin, düzenleyin ve aktiflik durumunu yönetin.",
        CatalogModalMode.Transfer => "Merkez stoktan aktif bayiye hareket oluşturun.",
        CatalogModalMode.CentralStock => "Merkez stoğu artırın ve hareket açıklamasını kaydedin.",
        CatalogModalMode.Movements => "Seçili ürün için aktif bayi stok hareketlerini inceleyin.",
        _ => string.Empty
    };
    private string ModalContainerClass => ModalMode == CatalogModalMode.Movements
        ? "max-h-[88vh] w-full max-w-4xl overflow-y-auto rounded-xl bg-white shadow-2xl shadow-slate-950/20"
        : "max-h-[88vh] w-full max-w-3xl overflow-y-auto rounded-xl bg-white shadow-2xl shadow-slate-950/20";
    private string MessageClass => IsError
        ? "rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm font-semibold text-rose-700"
        : "rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm font-semibold text-emerald-700";
    private int ActiveCount => ProductList.Count(product => product.AktifMi);
    private int PassiveCount => ProductList.Count(product => !product.AktifMi);
    private int InStockCount => ProductList.Count(product => product.AktifMi && GetDisplayStock(product).BayiStok > 0);
    private int OutOfStockCount => ProductList.Count(product => product.AktifMi && GetDisplayStock(product).BayiStok <= 0);
    private int CriticalStockCount => ProductList.Count(product => product.AktifMi && IsCriticalStock(GetDisplayStock(product)));

    private IEnumerable<ProductDto> FilteredProducts => ProductList.Where(product =>
        (!ProductId.HasValue || product.UrunId == ProductId.Value)
        && (!CategoryId.HasValue || product.KategoriId == CategoryId.Value)
        && MatchesStatusFilter(product)
        && MatchesStockFilter(product)
        && (string.IsNullOrWhiteSpace(Search)
            || $"{product.UrunAdi} {product.KategoriAdi} {product.Aciklama} {GetStock(product.UrunId)?.StokDurumu}".Contains(Search, StringComparison.CurrentCultureIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.CanManageProducts)
            ProductStatusFilter = 1;

        StoreState.Changed += OnStoreChanged;
        await StoreState.LoadAsync(StoreApi);
        await LoadCategoriesAsync();
        await LoadProductsAsync();
        await LoadStocksAsync();
    }

    protected override void OnParametersSet()
    {
        string querySignature = $"{ProductId?.ToString(CultureInfo.InvariantCulture) ?? "-"}|{CategoryId?.ToString(CultureInfo.InvariantCulture) ?? "-"}|{StockQuery ?? "-"}";
        if (string.Equals(querySignature, LastQuerySignature, StringComparison.Ordinal))
            return;

        LastQuerySignature = querySignature;

        if (string.Equals(StockQuery, "kritik", StringComparison.OrdinalIgnoreCase))
        {
            ProductId = null;
            CurrentStockFilter = StockFilterMode.Critical;
            ProductStatusFilter = -1;
            Search = string.Empty;
            return;
        }

        if (ProductId.HasValue || CategoryId.HasValue)
        {
            CurrentStockFilter = StockFilterMode.All;
            ProductStatusFilter = -1;
            Search = string.Empty;
            return;
        }

        CurrentStockFilter = StockFilterMode.All;
        ProductStatusFilter = Auth.CanManageProducts ? -1 : 1;
        Search = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Auth.CanManageProducts)
            return;

        try
        {
            string? stored = await JS.InvokeAsync<string?>("localStorage.getItem", ViewStorageKey);
            if (Enum.TryParse(stored, ignoreCase: true, out ProductViewMode mode))
            {
                CurrentViewMode = mode;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Browser storage is optional; default card view is fine.
        }
    }

    private async Task RefreshAsync()
    {
        await LoadCategoriesAsync();
        await LoadProductsAsync();
        await LoadStocksAsync();
    }

    private async Task LoadProductsAsync()
    {
        IsLoading = true;
        Message = string.Empty;

        try
        {
            ProductList = await ProductsApi.GetProductsAsync(status: EffectiveProductStatus);
        }
        catch
        {
            ProductList = Array.Empty<ProductDto>();
            IsError = true;
            Message = "Ürünler yüklenemedi. Oturumunuzu ve API bağlantısını kontrol edin.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadCategoriesAsync()
    {
        try
        {
            Categories = await ProductsApi.GetCategoriesAsync(status: -1);
        }
        catch
        {
            Categories = Array.Empty<CategoryDto>();
            IsError = true;
            Message = "Kategoriler yüklenemedi. Oturumunuzu ve API bağlantısını kontrol edin.";
        }
    }

    private async Task LoadStocksAsync()
    {
        if (!StoreState.SelectedStoreId.HasValue)
        {
            StockByProductId = new Dictionary<int, StockItemDto>();
            return;
        }

        try
        {
            IReadOnlyList<StockItemDto> stocks = await StockApi.GetStocksAsync(StoreState.SelectedStoreId.Value);
            StockByProductId = stocks
                .GroupBy(stock => stock.UrunId)
                .ToDictionary(group => group.Key, group => group.First());
        }
        catch
        {
            StockByProductId = new Dictionary<int, StockItemDto>();
            IsError = true;
            Message = "Bayi stok bilgileri yüklenemedi. Aktif bayi erişimini kontrol edin.";
        }
    }

    private async Task SetViewModeAsync(ProductViewMode mode)
    {
        CurrentViewMode = mode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", ViewStorageKey, mode.ToString());
        }
        catch
        {
            // Non-critical preference.
        }
    }

    private void SetStockFilter(StockFilterMode mode)
    {
        if (mode == StockFilterMode.All)
        {
            CurrentStockFilter = StockFilterMode.All;
            ProductStatusFilter = -1;
            ProductId = null;
            CategoryId = null;
            StockQuery = null;
            Search = string.Empty;
            Navigation.NavigateTo("/products");
            return;
        }

        CurrentStockFilter = CurrentStockFilter == mode ? StockFilterMode.All : mode;
    }

    private void TogglePassiveFilterAsync()
    {
        if (!Auth.CanManageProducts)
            return;

        CurrentStockFilter = StockFilterMode.All;
        ProductStatusFilter = ProductStatusFilter == 0 ? -1 : 0;
    }

    private void OpenNewProductModal()
    {
        _ = DestroyProductCropperAsync();
        ResetProductForm();
        ImagePreviewFailed = false;
        SelectedProductImage = null;
        SelectedProductImageName = string.Empty;
        ProductImagePreviewUrl = string.Empty;
        IsProductCropperVisible = false;
        ModalMode = CatalogModalMode.Product;
    }

    private void OpenEditProductModal(ProductDto product)
    {
        _ = DestroyProductCropperAsync();
        ProductDto source = ProductList.FirstOrDefault(item => item.UrunId == product.UrunId) ?? product;
        EditingProductId = source.UrunId;
        ProductForm = new ProductSaveRequest
        {
            KategoriId = source.KategoriId,
            UrunAdi = source.UrunAdi,
            Aciklama = source.Aciklama,
            Fiyat = source.Fiyat,
            Stok = source.Stok,
            GorselUrl = source.GorselUrl,
            AktifMi = source.AktifMi
        };
        ImagePreviewFailed = false;
        SelectedProductImage = null;
        SelectedProductImageName = string.Empty;
        ProductImagePreviewUrl = NormalizeImage(source.GorselUrl);
        IsProductCropperVisible = false;
        ModalMode = CatalogModalMode.Product;
        Message = string.Empty;
    }

    private void OpenCategoriesModal()
    {
        ResetCategoryForm();
        ModalMode = CatalogModalMode.Categories;
    }

    private void OpenTransferModal(StockItemDto stock)
    {
        TransferTarget = stock;
        TransferQuantity = stock.MerkezStok > 0 ? 1 : 0;
        TransferNote = string.Empty;
        ModalMode = CatalogModalMode.Transfer;
    }

    private void OpenCentralStockModal(ProductDto product)
    {
        SelectedProduct = ProductList.FirstOrDefault(item => item.UrunId == product.UrunId) ?? product;
        CentralStockQuantity = 1;
        CentralStockNote = string.Empty;
        ModalMode = CatalogModalMode.CentralStock;
    }

    private async Task OpenMovementsModal(ProductDto product)
    {
        SelectedProduct = ProductList.FirstOrDefault(item => item.UrunId == product.UrunId) ?? product;
        SelectedMovements = Array.Empty<StockMovementDto>();
        SelectedCentralMovements = Array.Empty<StockMovementDto>();
        CurrentMovementView = MovementViewMode.Store;
        IsMovementsLoading = false;
        ModalMode = CatalogModalMode.Movements;

        await LoadMovementDataAsync(product.UrunId);
    }

    private async Task LoadMovementDataAsync(int productId)
    {
        if (!StoreState.SelectedStoreId.HasValue)
            CurrentMovementView = MovementViewMode.Central;

        IsMovementsLoading = true;
        try
        {
            Task<IReadOnlyList<StockMovementDto>> storeTask = StoreState.SelectedStoreId.HasValue
                ? StockApi.GetMovementsAsync(StoreState.SelectedStoreId.Value, productId, count: 30)
                : Task.FromResult<IReadOnlyList<StockMovementDto>>(Array.Empty<StockMovementDto>());
            Task<IReadOnlyList<StockMovementDto>> centralTask = StockApi.GetCentralMovementsAsync(productId, count: 30);

            await Task.WhenAll(storeTask, centralTask);
            SelectedMovements = await storeTask;
            SelectedCentralMovements = await centralTask;
        }
        catch
        {
            IsError = true;
            Message = "Stok hareketleri yüklenemedi.";
        }
        finally
        {
            IsMovementsLoading = false;
        }
    }

    private void CloseModal()
    {
        _ = DestroyProductCropperAsync();
        ModalMode = CatalogModalMode.None;
        ResetProductForm();
        ResetCategoryForm();
        TransferTarget = null;
        SelectedProduct = null;
        SelectedMovements = Array.Empty<StockMovementDto>();
        SelectedCentralMovements = Array.Empty<StockMovementDto>();
        CurrentMovementView = MovementViewMode.Store;
        TransferQuantity = 1;
        CentralStockQuantity = 1;
        TransferNote = string.Empty;
        CentralStockNote = string.Empty;
        SelectedProductImage = null;
        SelectedProductImageName = string.Empty;
        ProductImagePreviewUrl = string.Empty;
        ImagePreviewFailed = false;
        IsProductCropperVisible = false;
        IsMovementsLoading = false;
    }

    private void HandleModalKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
            CloseModal();
    }

    private async Task OnProductImageSelected(InputFileChangeEventArgs eventArgs)
    {
        try
        {
            IBrowserFile file = eventArgs.File;
            ValidateProductImage(file);

            SelectedProductImage = file;
            SelectedProductImageName = file.Name;
            ImagePreviewFailed = false;
            ProductImagePreviewUrl = string.Empty;
            IsProductCropperVisible = true;
            await InvokeAsync(StateHasChanged);

            ProductCropInfo info = await JS.InvokeAsync<ProductCropInfo>("eMarketing.productCrop.load", ProductImageInputId, ProductCropImageId, ProductCropPreviewSelector, MaxProductImageBytes);
            ProductImagePreviewUrl = info.DataUrl;
        }
        catch (Exception ex)
        {
            SelectedProductImage = null;
            SelectedProductImageName = string.Empty;
            ProductImagePreviewUrl = string.Empty;
            ImagePreviewFailed = true;
            IsProductCropperVisible = false;
            IsError = true;
            Message = $"Görsel seçilemedi. {ex.Message}";
        }
    }

    private async Task SaveProductAsync()
    {
        if (string.IsNullOrWhiteSpace(ProductForm.UrunAdi) || ProductForm.KategoriId <= 0)
        {
            IsError = true;
            Message = "Ürün adı ve kategori zorunludur.";
            return;
        }

        IsSaving = true;
        SavedProductImage? savedImage = null;
        try
        {
            string productName = ProductForm.UrunAdi.Trim();
            ProductForm.UrunAdi = productName;
            ProductForm.Aciklama = ProductForm.Aciklama?.Trim() ?? string.Empty;

            if (SelectedProductImage is not null)
            {
                savedImage = await SaveProductImageAsync(SelectedProductImage);
                ProductForm.GorselUrl = savedImage.Url;
            }

            if (EditingProductId.HasValue)
            {
                await ProductsApi.UpdateProductAsync(EditingProductId.Value, ProductForm);
                Message = $"{productName} güncellendi.";
            }
            else
            {
                await ProductsApi.CreateProductAsync(ProductForm);
                Message = $"{productName} ürün kataloğuna eklendi.";
            }

            IsError = false;
            CloseModal();
            await LoadProductsAsync();
            await LoadStocksAsync();
        }
        catch (Exception ex)
        {
            if (savedImage is not null && File.Exists(savedImage.FullPath))
                File.Delete(savedImage.FullPath);

            IsError = true;
            Message = $"Ürün kaydedilemedi. {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task ToggleProductStatusAsync(ProductDto product)
    {
        try
        {
            await ProductsApi.SetProductStatusAsync(product.UrunId, !product.AktifMi);
            IsError = false;
            Message = product.AktifMi
                ? $"{product.UrunAdi} pasife alındı. Tüm durumlar veya Pasif filtresinden tekrar aktif yapabilirsiniz."
                : $"{product.UrunAdi} aktif yapıldı.";

            if (Auth.CanManageProducts)
                ProductStatusFilter = -1;

            await LoadProductsAsync();
            await LoadStocksAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = $"Ürün durumu güncellenemedi. {ex.Message}";
        }
    }

