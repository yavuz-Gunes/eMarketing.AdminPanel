    private async Task TransferAsync()
    {
        if (IsTransferInvalid || TransferTarget is null || !StoreState.SelectedStoreId.HasValue)
        {
            IsError = true;
            Message = "Transfer miktarını ve aktif bayi seçimini kontrol edin.";
            return;
        }

        IsSaving = true;
        try
        {
            await StockApi.TransferFromCentralAsync(StoreState.SelectedStoreId.Value, TransferTarget.UrunId, TransferQuantity, TransferNote);
            string productName = TransferTarget.UrunAdi;
            CloseModal();
            await LoadStocksAsync();
            IsError = false;
            Message = $"{productName} için transfer tamamlandı. Stok hareketlerinden takip edebilirsiniz.";
        }
        catch
        {
            IsError = true;
            Message = "Transfer yapılamadı. Merkez stoğu, bayi erişimi veya yetkinizi kontrol edin.";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task IncreaseCentralStockAsync()
    {
        if (IsCentralStockInvalid || SelectedProduct is null)
        {
            IsError = true;
            Message = "Merkez stok miktarını kontrol edin.";
            return;
        }

        IsSaving = true;
        try
        {
            int quantity = CentralStockQuantity;
            int productId = SelectedProduct.UrunId;
            string productName = SelectedProduct.UrunAdi;
            await StockApi.IncreaseCentralStockAsync(productId, quantity, CentralStockNote);
            CloseModal();
            await LoadProductsAsync();
            await LoadStocksAsync();
            IsError = false;
            Message = $"{productName} merkez stoğuna {quantity} adet eklendi.";
        }
        catch
        {
            IsError = true;
            Message = "Merkez stok artırılamadı. Yetkinizi ve ürün bilgisini kontrol edin.";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task<SavedProductImage> SaveProductImageAsync(IBrowserFile image)
    {
        ValidateProductImage(image);

        string dataUrl = await JS.InvokeAsync<string>("eMarketing.productCrop.cropToDataUrl", 1400, 963, 0.9);
        const string prefix = "data:image/jpeg;base64,";
        if (string.IsNullOrWhiteSpace(dataUrl) || !dataUrl.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            throw new InvalidOperationException("Kırpılmış görsel hazırlanamadı.");

        byte[] bytes = Convert.FromBase64String(dataUrl[prefix.Length..]);
        string folder = Path.Combine(Environment.WebRootPath, "Images", "Products");
        Directory.CreateDirectory(folder);

        string fileName = $"{Guid.NewGuid():N}.jpg";
        string fullPath = Path.Combine(folder, fileName);

        await File.WriteAllBytesAsync(fullPath, bytes);

        return new SavedProductImage($"/Images/Products/{fileName}", fullPath);
    }

    private async Task DestroyProductCropperAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eMarketing.productCrop.destroy");
        }
        catch
        {
            // The cropper is a progressive enhancement; closing the modal must never fail.
        }
    }

    private static void ValidateProductImage(IBrowserFile image)
    {
        string extension = Path.GetExtension(image.Name);
        if (!AllowedProductImageExtensions.Contains(extension))
            throw new InvalidOperationException("Sadece JPG, PNG veya WebP görsel seçilebilir.");

        if (image.Size > MaxProductImageBytes)
            throw new InvalidOperationException("Görsel en fazla 5 MB olabilir.");
    }

