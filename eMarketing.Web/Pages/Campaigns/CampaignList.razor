@page "/campaigns"
@implements IDisposable
@inject CampaignApiClient CampaignApi
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject AuthSession Auth
@inject NavigationManager Navigation

<PageTitle>Kampanyalar - eMarketing</PageTitle>

<AuthGate>
    <section class="mx-auto max-w-[1120px] space-y-5 px-4 py-6 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-black uppercase tracking-wide text-blue-700">Kampanyalar</p>
                <h1 class="mt-2 text-3xl font-black text-slate-950">Aktif Kampanyalar</h1>
                <p class="mt-1 text-sm text-slate-600">Seçili mağaza için geçerli kampanyaları buradan inceleyin.</p>
                <div class="mt-3 inline-flex max-w-full items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-black text-blue-700">
                    <AppIcon Name="store" CssClass="h-4 w-4 shrink-0" />
                    <span class="truncate">Seçili mağaza: @SelectedStoreName</span>
                </div>
            </div>

            <button class="inline-flex h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-black text-slate-700 shadow-sm transition hover:border-blue-200 hover:text-blue-700"
                    type="button"
                    @onclick="GoBack">
                Dashboard'a Dön
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm font-bold text-rose-700">@Message</div>
        }

        @if (Loading)
        {
            <div class="rounded-3xl border border-slate-200 bg-white p-8 text-sm font-bold text-slate-500 shadow-sm">
                Kampanyalar yükleniyor...
            </div>
        }
        else if (Campaigns.Count == 0)
        {
            <div class="rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-sm">
                <p class="font-black text-slate-950">Aktif kampanya yok</p>
                <p class="mt-1 text-sm text-slate-500">Bu mağaza için geçerli kampanya olduğunda burada görünecek.</p>
            </div>
        }
        else
        {
            <div class="grid gap-4 md:grid-cols-2">
                @foreach (DashboardCampaignDto campaign in Campaigns)
                {
                    <a href="@($"/campaigns/{campaign.KampanyaId}")"
                       class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-lg">
                        @if (!string.IsNullOrWhiteSpace(NormalizeImageUrl(campaign.GorselUrl)))
                        {
                            <img class="h-32 w-full bg-slate-100 object-cover sm:h-40" src="@NormalizeImageUrl(campaign.GorselUrl)" alt="Kampanya görseli" />
                        }
                        <div class="p-5">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="rounded-full bg-blue-50 px-2.5 py-1 text-[11px] font-black uppercase text-blue-700">Kampanya</span>
                                <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-black uppercase text-emerald-700">@ValidityText(campaign)</span>
                            </div>
                            <h2 class="mt-3 line-clamp-2 text-lg font-black text-slate-950">@DisplayTitle(campaign)</h2>
                            @if (!string.IsNullOrWhiteSpace(campaign.Aciklama))
                            {
                                <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-600">@campaign.Aciklama</p>
                            }
                            <span class="mt-4 inline-flex text-sm font-black text-blue-700 transition group-hover:text-blue-800">Detaya git</span>
                        </div>
                    </a>
                }
            </div>
        }
    </section>
</AuthGate>

@code {
    private IReadOnlyList<DashboardCampaignDto> Campaigns { get; set; } = Array.Empty<DashboardCampaignDto>();
    private bool Loading { get; set; }
    private string Message { get; set; } = string.Empty;
    private string SelectedStoreName => StoreState.SelectedStore?.MagazaAdi ?? "Mağaza seçilmedi";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        await StoreState.LoadAsync(StoreApi);
        StoreState.Changed += OnStoreChanged;
        await LoadAsync();
    }

    private async void OnStoreChanged()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        try
        {
            Loading = true;
            Message = string.Empty;
            Campaigns = await CampaignApi.GetActiveCampaignsAsync(StoreState.SelectedStoreId);
        }
        catch (Exception ex)
        {
            Campaigns = Array.Empty<DashboardCampaignDto>();
            Message = "Kampanyalar yüklenemedi: " + ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private static string DisplayTitle(DashboardCampaignDto campaign)
    {
        return string.IsNullOrWhiteSpace(campaign.Baslik) ? "Kampanya" : campaign.Baslik;
    }

    private static string ValidityText(DashboardCampaignDto campaign)
    {
        if (campaign.BaslangicTarihi.HasValue && campaign.BitisTarihi.HasValue)
            return $"{campaign.BaslangicTarihi.Value:dd.MM.yyyy} - {campaign.BitisTarihi.Value:dd.MM.yyyy}";

        if (campaign.BitisTarihi.HasValue)
            return $"{campaign.BitisTarihi.Value:dd.MM.yyyy} bitiş";

        return "Aktif";
    }

    private static string? NormalizeImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return null;

        string normalized = imageUrl.Replace("\\", "/").Trim();
        return normalized.StartsWith("http", StringComparison.OrdinalIgnoreCase) || normalized.StartsWith("/")
            ? normalized
            : "/" + normalized;
    }

    public void Dispose()
    {
        StoreState.Changed -= OnStoreChanged;
    }
}
