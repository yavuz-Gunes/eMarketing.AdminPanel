@page "/cart"
@implements IDisposable
@inject CartState CartState
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi
@inject OrderApiClient OrdersApi

<PageTitle>Sepet - eMarketing</PageTitle>

<AuthGate>
    <section class="space-y-6 px-4 py-6 sm:px-6 lg:px-8">
        <div>
            <p class="text-sm font-bold uppercase text-slate-500">Sepet</p>
            <h1 class="mt-1 text-3xl font-bold tracking-normal text-slate-950">Sipariş özeti</h1>
            <p class="mt-1 text-sm text-slate-500">Tek sepet, tek sipariş numarası olarak oluşturulur.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="@MessageClass">@Message</div>
        }

        <div class="grid gap-6 lg:grid-cols-[1fr_390px]">
            <section class="space-y-4">
                @if (CartState.Items.Count == 0)
                {
                    <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center shadow-sm shadow-slate-200/60">
                        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
                            <AppIcon Name="cart" CssClass="h-7 w-7" />
                        </div>
                        <p class="mt-4 font-semibold text-slate-950">Sepet boş</p>
                        <p class="mt-2 text-sm text-slate-500">Ürün kataloğundan ürün ekleyerek sipariş oluşturabilirsiniz.</p>
                    </div>
                }
                @foreach (CartItem item in CartState.Items)
                {
                    <article class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/60 sm:flex-row sm:items-center">
                        @if (!string.IsNullOrWhiteSpace(item.Product.GorselUrl))
                        {
                            <img class="h-24 w-24 rounded-xl object-cover" src="@item.Product.GorselUrl.Replace("\\", "/")" alt="@item.Product.UrunAdi" />
                        }
                        else
                        {
                            <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-xl font-bold text-slate-400">@Initials(item.Product.UrunAdi)</div>
                        }
                        <div class="min-w-0 flex-1">
                            <h2 class="font-bold text-slate-950">@item.Product.UrunAdi</h2>
                            <p class="mt-1 text-sm text-slate-500">@item.Product.KategoriAdi · @item.Product.Fiyat.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                        </div>
                        <div class="flex items-center gap-2">
                            <button class="h-10 w-10 rounded-xl border border-slate-200 text-lg font-bold hover:bg-slate-50" @onclick="() => CartState.Decrease(item.Product.UrunId)">-</button>
                            <span class="w-10 text-center text-sm font-bold">@item.Quantity</span>
                            <button class="h-10 w-10 rounded-xl border border-slate-200 text-lg font-bold hover:bg-slate-50" @onclick="() => CartState.Increase(item.Product.UrunId)">+</button>
                        </div>
                        <div class="min-w-28 text-right">
                            <p class="font-bold text-slate-950">@item.LineTotal.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                            <button class="mt-2 text-sm font-semibold text-rose-600 hover:text-rose-700" @onclick="() => CartState.Remove(item.Product.UrunId)">Sil</button>
                        </div>
                    </article>
                }
            </section>

            <aside class="h-fit rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
                <h2 class="text-xl font-bold text-slate-950">Sipariş</h2>
                <div class="mt-5 space-y-3 text-sm">
                    <InfoRow Label="Aktif bayi" Value="@(StoreState.SelectedStore?.MagazaAdi ?? "-")" />
                    <InfoRow Label="Ürün adedi" Value="@CartState.Count.ToString(CultureInfo.InvariantCulture)" />
                    <InfoRow Label="Kalem" Value="@CartState.Items.Count.ToString(CultureInfo.InvariantCulture)" />
                    <InfoRow Label="Toplam" Value="@CartState.Total.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))" />
                </div>

                <label class="mt-5 block space-y-2 text-sm font-semibold text-slate-700">
                    <span>Sipariş yetkilisi</span>
                    <select class="h-12 w-full rounded-xl border border-slate-200 px-3 outline-none focus:border-blue-300 focus:ring-4 focus:ring-blue-100 disabled:bg-slate-100 disabled:text-slate-400"
                            disabled="@(AuthoritiesLoading || Authorities.Count == 0)"
                            @bind="SelectedAuthorityId">
                        <option value="0">Seçiniz</option>
                        @foreach (SiparisYetkilisiDto authority in Authorities)
                        {
                            <option value="@authority.BayiYetkiliId">@authority.AdSoyad</option>
                        }
                    </select>
                </label>

                @if (AuthoritiesLoading)
                {
                    <p class="mt-2 text-xs font-bold text-slate-500">Sipariş yetkilileri yükleniyor...</p>
                }
                else if (!string.IsNullOrWhiteSpace(AuthorityMessage))
                {
                    <p class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-bold leading-5 text-amber-800">@AuthorityMessage</p>
                }

                <button class="mt-5 w-full rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm shadow-blue-200 hover:bg-blue-700 disabled:bg-slate-300 disabled:shadow-none" disabled="@(!CanCheckout)" @onclick="OpenPaymentModal">
                    Ödeme yap ve siparişi oluştur
                </button>
            </aside>
        </div>

        @if (ShowPaymentModal)
        {
            <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/45 px-4 py-6 backdrop-blur-sm">
                <section class="w-full max-w-2xl overflow-hidden rounded-2xl bg-white shadow-2xl shadow-slate-950/20">
                    <div class="flex items-start justify-between gap-4 border-b border-slate-100 bg-slate-50 px-5 py-4">
                        <div>
                            <p class="text-xs font-black uppercase tracking-wide text-blue-600">Simülasyon ödeme</p>
                            <h2 class="mt-1 text-xl font-black text-slate-950">Kart ile ödeme</h2>
                            <p class="mt-1 text-sm text-slate-500">Test kartı başarılıysa sipariş oluşturulur; kart bilgisi kaydedilmez.</p>
                        </div>
                        <button class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:bg-slate-100"
                                @onclick="ClosePaymentModal"
                                disabled="@ProcessingPayment"
                                aria-label="Kapat">
                            <AppIcon Name="x" CssClass="h-5 w-5" />
                        </button>
                    </div>

                    <div class="grid gap-5 p-5 lg:grid-cols-[1fr_240px]">
                        <div class="space-y-4">
                            @if (!string.IsNullOrWhiteSpace(PaymentError))
                            {
                                <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-bold text-rose-700">@PaymentError</div>
                            }

                            <TextField Label="Kart sahibi" Kind="person" Placeholder="Ad Soyad" @bind-Value="PaymentForm.CardHolder" />
                            <TextField Label="Kart numarası" Kind="numeric" MaxLength="19" Placeholder="4242 4242 4242 4242" @bind-Value="PaymentForm.CardNumber" />
                            <div class="grid gap-3 sm:grid-cols-2">
                                <TextField Label="Son kullanma" Kind="expiry" MaxLength="5" Placeholder="12/30" Hint="AA/YY formatında girin." @bind-Value="PaymentForm.Expiry" />
                                <TextField Label="CVV" Kind="numeric" MaxLength="4" Placeholder="123" @bind-Value="PaymentForm.Cvv" />
                            </div>

                            <div class="rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-xs font-bold leading-5 text-blue-800">
                                Başarılı test kartı: 4242 4242 4242 4242 · Reddedilen kart: 4000 0000 0000 0002
                            </div>
                        </div>

                        <aside class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/70">
                            <p class="text-xs font-black uppercase tracking-wide text-slate-500">Ödenecek tutar</p>
                            <p class="mt-2 text-2xl font-black text-slate-950">@CartState.Total.ToString("C", CultureInfo.GetCultureInfo("tr-TR"))</p>
                            <div class="mt-4 space-y-3 text-sm">
                                <InfoRow Label="Aktif bayi" Value="@(StoreState.SelectedStore?.MagazaAdi ?? "-")" />
                                <InfoRow Label="Yetkili" Value="@(Authorities.FirstOrDefault(x => x.BayiYetkiliId == SelectedAuthorityId)?.AdSoyad ?? "-")" />
                                <InfoRow Label="Ürün adedi" Value="@CartState.Count.ToString(CultureInfo.InvariantCulture)" />
                            </div>
                        </aside>
                    </div>

                    <div class="flex flex-col-reverse gap-2 border-t border-slate-100 bg-white p-4 sm:flex-row sm:justify-end">
                        <button class="rounded-xl border border-slate-200 px-4 py-3 text-sm font-bold text-slate-600 hover:bg-slate-50 disabled:opacity-60"
                                @onclick="ClosePaymentModal"
                                disabled="@ProcessingPayment">
                            Vazgeç
                        </button>
                        <button class="rounded-xl bg-slate-950 px-5 py-3 text-sm font-black text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300"
                                @onclick="PayAndCheckoutAsync"
                                disabled="@(!CanSubmitPayment)">
                            @(ProcessingPayment ? "Ödeme alınıyor..." : "Ödemeyi tamamla")
                        </button>
                    </div>
                </section>
            </div>
        }
    </section>
</AuthGate>

@code {
    private IReadOnlyList<SiparisYetkilisiDto> Authorities { get; set; } = Array.Empty<SiparisYetkilisiDto>();
    private int SelectedAuthorityId { get; set; }
    private string Message { get; set; } = string.Empty;
    private string AuthorityMessage { get; set; } = string.Empty;
    private bool IsError { get; set; }
    private bool AuthoritiesLoading { get; set; }
    private bool ShowPaymentModal { get; set; }
    private bool ProcessingPayment { get; set; }
    private string PaymentError { get; set; } = string.Empty;
    private PaymentSimulationRequest PaymentForm { get; set; } = NewPaymentForm();
    private int AuthoritiesLoadVersion { get; set; }
    private string MessageClass => IsError
        ? "rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"
        : "rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700";
    private bool CanCheckout => StoreState.SelectedStore is not null && SelectedAuthorityId > 0 && CartState.Items.Count > 0 && !AuthoritiesLoading;
    private bool CanSubmitPayment => CanCheckout
        && !ProcessingPayment
        && !string.IsNullOrWhiteSpace(PaymentForm.CardHolder)
        && !string.IsNullOrWhiteSpace(PaymentForm.CardNumber)
        && !string.IsNullOrWhiteSpace(PaymentForm.Expiry)
        && !string.IsNullOrWhiteSpace(PaymentForm.Cvv);

    protected override async Task OnInitializedAsync()
    {
        StoreState.Changed += OnStoreChanged;
        await StoreState.LoadAsync(StoreApi);
        await LoadAuthoritiesAsync();
    }

    private async void OnStoreChanged()
    {
        await LoadAuthoritiesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAuthoritiesAsync()
    {
        int version = ++AuthoritiesLoadVersion;
        int? storeId = StoreState.SelectedStoreId;

        Authorities = Array.Empty<SiparisYetkilisiDto>();
        SelectedAuthorityId = 0;
        AuthorityMessage = string.Empty;
        AuthoritiesLoading = storeId.HasValue;

        if (storeId is not int activeStoreId)
        {
            AuthorityMessage = "Sipariş oluşturmak için aktif bayi seçin.";
            AuthoritiesLoading = false;
            return;
        }

        try
        {
            IReadOnlyList<SiparisYetkilisiDto> authorities = await StoreApi.GetOrderAuthoritiesAsync(activeStoreId);
            if (version != AuthoritiesLoadVersion || StoreState.SelectedStoreId != activeStoreId)
                return;

            Authorities = authorities;
            SelectedAuthorityId = Authorities.FirstOrDefault()?.BayiYetkiliId ?? 0;
            AuthorityMessage = Authorities.Count == 0
                ? "Bu bayide sipariş oluşturmak için aktif sipariş yetkiniz bulunmuyor."
                : string.Empty;
        }
        catch (Exception ex)
        {
            if (version != AuthoritiesLoadVersion || StoreState.SelectedStoreId != activeStoreId)
                return;

            Authorities = Array.Empty<SiparisYetkilisiDto>();
            SelectedAuthorityId = 0;
            AuthorityMessage = FriendlyAuthorityError(ex.Message);
        }
        finally
        {
            if (version == AuthoritiesLoadVersion)
                AuthoritiesLoading = false;
        }
    }

    private void OpenPaymentModal()
    {
        if (!CanCheckout)
            return;

        PaymentError = string.Empty;
        PaymentForm = NewPaymentForm();
        ShowPaymentModal = true;
    }

    private void ClosePaymentModal()
    {
        if (ProcessingPayment)
            return;

        ShowPaymentModal = false;
        PaymentError = string.Empty;
    }

    private async Task PayAndCheckoutAsync()
    {
        if (StoreState.SelectedStore is null)
            return;

        SiparisYetkilisiDto? authority = Authorities.FirstOrDefault(x => x.BayiYetkiliId == SelectedAuthorityId);
        if (authority is null)
        {
            PaymentError = "Sipariş oluşturmak için geçerli bir sipariş yetkilisi seçin.";
            return;
        }

        try
        {
            ProcessingPayment = true;
            PaymentError = string.Empty;
            PaidCartOrderResponseDto result = await OrdersApi.CreatePaidCartOrderAsync(StoreState.SelectedStore, authority, CartState.Items.ToList(), PaymentForm);
            CartState.Clear();
            ShowPaymentModal = false;
            IsError = false;
            Message = result.SiparisId > 0
                ? $"Ödeme alındı ve sipariş oluşturuldu. Sipariş ID: {result.SiparisId}"
                : "Ödeme alındı ve sipariş oluşturuldu.";
        }
        catch (Exception ex)
        {
            PaymentError = ex.Message;
        }
        finally
        {
            ProcessingPayment = false;
        }
    }

    private static string FriendlyAuthorityError(string message)
    {
        if (message.Contains("403", StringComparison.OrdinalIgnoreCase)
            || message.Contains("Yasak", StringComparison.OrdinalIgnoreCase)
            || message.Contains("yetki", StringComparison.CurrentCultureIgnoreCase))
            return "Bu bayi için sipariş yetkiniz bulunmuyor. Yetki verildiyse çıkış yapıp tekrar giriş deneyin.";

        return string.IsNullOrWhiteSpace(message)
            ? "Sipariş yetkilileri yüklenemedi."
            : message;
    }

    private static string Initials(string text)
    {
        return string.Join("", text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper(new CultureInfo("tr-TR"));
    }

    private static PaymentSimulationRequest NewPaymentForm() => new()
    {
        CardNumber = "4242 4242 4242 4242",
        Expiry = DateTime.Today.AddYears(2).ToString("MM/yy", CultureInfo.InvariantCulture),
        Cvv = "123"
    };

    public void Dispose()
    {
        StoreState.Changed -= OnStoreChanged;
    }
}
