@page "/stores"
@inject ActiveStoreState StoreState
@inject StoreApiClient StoreApi

<PageTitle>Mağazalar - eMarketing</PageTitle>

<AuthGate>
    <section class="space-y-6 px-4 py-6 sm:px-6 lg:px-8">
        <div>
            <p class="text-sm font-bold uppercase text-slate-500">Mağaza Seçimi</p>
            <h1 class="mt-1 text-3xl font-bold tracking-normal text-slate-950">Bağlı mağazalarım</h1>
            <p class="mt-1 text-sm text-slate-500">Yalnızca aktif bağlı olduğunuz mağazalar gösterilir.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">@Message</div>
        }

        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            @foreach (StoreDto store in StoreState.Stores)
            {
                <button class="@StoreClass(store)" @onclick="() => StoreState.Select(store.MagazaId)">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-bold text-slate-950">@store.MagazaAdi</h2>
                            <p class="mt-1 text-sm text-slate-500">@store.MusteriAdi</p>
                        </div>
                        @if (StoreState.SelectedStoreId == store.MagazaId)
                        {
                            <StatusBadge Text="Aktif" Tone="success" />
                        }
                    </div>
                    <dl class="mt-6 grid grid-cols-2 gap-4 text-sm">
                        <div class="rounded-xl bg-slate-50 p-3">
                            <dt class="text-slate-500">Şehir</dt>
                            <dd class="mt-1 font-bold text-slate-900">@store.Sehir</dd>
                        </div>
                        <div class="rounded-xl bg-slate-50 p-3">
                            <dt class="text-slate-500">Personel</dt>
                            <dd class="mt-1 font-bold text-slate-900">@store.PersonelSayisi</dd>
                        </div>
                        <div class="rounded-xl bg-slate-50 p-3">
                            <dt class="text-slate-500">Sipariş yetkilisi</dt>
                            <dd class="mt-1 font-bold text-slate-900">@store.SiparisYetkilisiSayisi</dd>
                        </div>
                        <div class="rounded-xl bg-slate-50 p-3">
                            <dt class="text-slate-500">Ciro</dt>
                            <dd class="mt-1 font-bold text-slate-900">@store.ToplamCiro.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))</dd>
                        </div>
                    </dl>
                </button>
            }
        </div>
    </section>
</AuthGate>

@code {
    private string Message { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await StoreState.LoadAsync(StoreApi);
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private string StoreClass(StoreDto store)
    {
        return StoreState.SelectedStoreId == store.MagazaId
            ? "rounded-2xl border border-blue-300 bg-white p-5 text-left shadow-md shadow-blue-100 ring-4 ring-blue-100"
            : "rounded-2xl border border-slate-200 bg-white p-5 text-left shadow-sm shadow-slate-200/60 transition hover:border-blue-200 hover:shadow-md";
    }
}
