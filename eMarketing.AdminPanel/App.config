<configuration>
	<appSettings>
		<add key="ApiBaseUrl" value="http://localhost:5088/api" />
	</appSettings>
	<connectionStrings>
		<add name="DbConnection"
connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=EMarketingDb;Integrated Security=True;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>
